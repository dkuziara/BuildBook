<div class="list-pager" aria-label="@AriaLabel">
    <p class="list-pager-summary">Showing @StartRecord-@EndRecord of @TotalCount @ItemLabel</p>

    <div class="list-pager-controls">
        <label class="list-pager-label" for="@PageSizeInputId">Rows per page</label>
        <select id="@PageSizeInputId" class="text-input list-pager-select" value="@PageSize" @onchange="HandlePageSizeChangedAsync" disabled="@Disabled">
            @foreach (var option in PageSizeOptions)
            {
                <option value="@option">@option</option>
            }
        </select>

        <button type="button" class="secondary-button" disabled="@(!HasPreviousPage || Disabled)" @onclick="GoToPreviousPageAsync">Previous</button>
        <span class="list-pager-status">Page @PageNumber of @TotalPages</span>
        <button type="button" class="secondary-button" disabled="@(!HasNextPage || Disabled)" @onclick="GoToNextPageAsync">Next</button>
    </div>
</div>

@code {
    private readonly string PageSizeInputId = $"pager-size-{Guid.NewGuid():N}";
    private static readonly int[] PageSizeOptions = [10, 50, 100];

    [Parameter]
    public string AriaLabel { get; set; } = "Pagination";

    [Parameter]
    public string ItemLabel { get; set; } = "records";

    [Parameter]
    public int TotalCount { get; set; }

    [Parameter]
    public int PageNumber { get; set; } = 1;

    [Parameter]
    public int TotalPages { get; set; } = 1;

    [Parameter]
    public int PageSize { get; set; } = 10;

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public EventCallback<int> PageNumberChanged { get; set; }

    [Parameter]
    public EventCallback<int> PageSizeChanged { get; set; }

    private int StartRecord => TotalCount == 0 ? 0 : ((PageNumber - 1) * PageSize) + 1;

    private int EndRecord => TotalCount == 0 ? 0 : Math.Min(TotalCount, StartRecord + PageSize - 1);

    private bool HasPreviousPage => PageNumber > 1;

    private bool HasNextPage => PageNumber < TotalPages;

    private Task GoToPreviousPageAsync()
    {
        return PageNumberChanged.InvokeAsync(PageNumber - 1);
    }

    private Task GoToNextPageAsync()
    {
        return PageNumberChanged.InvokeAsync(PageNumber + 1);
    }

    private Task HandlePageSizeChangedAsync(ChangeEventArgs args)
    {
        if (int.TryParse(args.Value?.ToString(), out var pageSize))
        {
            return PageSizeChanged.InvokeAsync(pageSize);
        }

        return Task.CompletedTask;
    }
}
