@using System.Security.Claims
@using BuildBook.Web.Authorization

@inherits LayoutComponentBase

<div class="app-shell">
    <header class="app-header">
        <div class="app-header-inner">
            <div class="app-header-top">
                <a class="brand" href="/">
                    <img class="brand-mark" src="/images/charthouse-tile.png" alt="Charthouse" />
                    <span>
                        <span class="brand-name">BuildBook</span>
                        <span class="brand-subtitle">Internal build records</span>
                    </span>
                </a>

                <AuthorizeView>
                    <Authorized Context="authenticationState">
                        <div class="current-user-panel">
                            <span class="current-user-label">Signed in as</span>
                            <strong>@authenticationState.User.Identity?.Name</strong>
                            <span class="current-user-mode">@GetAuthenticationMode(authenticationState.User)</span>
                        </div>
                    </Authorized>
                </AuthorizeView>
            </div>

            <nav class="primary-nav" aria-label="Primary navigation">
                <AuthorizeView Policy="@BuildBookPolicies.ViewBuildRecords">
                    <Authorized>
                        <NavLink href="/" Match="NavLinkMatch.All">Home</NavLink>
                        <NavLink href="/build-register">Build Register</NavLink>
                        <NavLink href="/products">Products</NavLink>
                    </Authorized>
                </AuthorizeView>
                <AuthorizeView Policy="@BuildBookOrderPolicies.ViewOrders">
                    <Authorized>
                        <NavLink href="/orders">Orders</NavLink>
                    </Authorized>
                </AuthorizeView>
                <AuthorizeView Policy="@BuildBookRmaPolicies.ViewRmas">
                    <Authorized>
                        <NavLink href="/rmas">RMAs</NavLink>
                    </Authorized>
                </AuthorizeView>
                <AuthorizeView Policy="@BuildBookPolicies.ViewCustomers">
                    <Authorized>
                        <NavLink href="/customers">Customers</NavLink>
                    </Authorized>
                </AuthorizeView>
                <AuthorizeView Policy="@BuildBookPolicies.ManageUsers">
                    <Authorized>
                        <NavLink href="/admin">Admin</NavLink>
                    </Authorized>
                </AuthorizeView>
            </nav>
        </div>
    </header>

    <main class="main-content">
        <div class="page-container">
            @Body
        </div>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">x</span>
</div>

@code {
    private static string GetAuthenticationMode(ClaimsPrincipal user)
    {
        return user.Identity?.AuthenticationType == BuildBookAuthenticationSchemes.Development
            ? "Local development authentication bypass"
            : "Windows Authentication";
    }
}
