@page "/build-records/new"
@rendermode InteractiveServer

@using BuildBook.Application.Orders

@attribute [Authorize(Policy = BuildBookPolicies.EditBuildRecords)]

@inject IBuildRecordCreator BuildRecordCreator
@inject IOrderIntegrationService OrderIntegrationService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager

<PageTitle>Add Build Record</PageTitle>

<section class="page-heading">
    <div class="page-heading-copy">
        <p class="eyebrow">Build Records</p>
        <h1>Add a new Build Record.</h1>
        <p>Create the required product and serial details here, then complete the rest from the record page.</p>
    </div>
</section>

@if (SourceOrderId is not null)
{
    <section class="detail-panel">
        <div class="detail-panel-header">
            <div>
                <h2>Order Context</h2>
                <p>This Build Record will be created from Order @DisplaySourceOrder().</p>
            </div>
        </div>
    </section>
}

<section class="form-panel" aria-labelledby="add-build-record-heading">
    <h2 id="add-build-record-heading">Required details</h2>

    @if (serverErrors.Count > 0)
    {
        <div class="status-message error" role="alert">
            <p>The Build Record could not be saved.</p>
            <ul>
                @foreach (var error in serverErrors)
                {
                    <li>@error</li>
                }
            </ul>
        </div>
    }

    <EditForm Model="model" OnValidSubmit="CreateAsync" FormName="create-build-record">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="form-grid">
            <div class="form-field">
                <label for="product-code">Product code</label>
                <InputText id="product-code" class="text-input" @bind-Value="model.ProductCode" />
                <ValidationMessage For="() => model.ProductCode" />
            </div>

            <div class="form-field">
                <label for="product-name">Product name</label>
                <InputText id="product-name" class="text-input" @bind-Value="model.ProductName" />
                <ValidationMessage For="() => model.ProductName" />
            </div>

            <div class="form-field">
                <label for="serial-number">Serial number</label>
                <InputText id="serial-number" class="text-input" @bind-Value="model.SerialNumber" />
                <ValidationMessage For="() => model.SerialNumber" />
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="primary-button" disabled="@isSaving">
                @(isSaving ? "Saving..." : "Create Build Record")
            </button>
            <a class="action-link" href="/build-register">Back to Build Register</a>
        </div>
    </EditForm>
</section>

@code {
    private CreateBuildRecordRequest model = new();
    private readonly List<string> serverErrors = [];
    private bool isSaving;
    private bool hasInitializedFromQuery;

    [SupplyParameterFromQuery]
    public int? SourceOrderId { get; set; }

    [SupplyParameterFromQuery]
    public string? SourceOrderNumber { get; set; }

    [SupplyParameterFromQuery]
    public string? SourceOrderTitle { get; set; }

    [SupplyParameterFromQuery]
    public int? CustomerId { get; set; }

    [SupplyParameterFromQuery]
    public string? CustomerOrder { get; set; }

    protected override void OnParametersSet()
    {
        if (hasInitializedFromQuery)
        {
            return;
        }

        model.CustomerId = CustomerId;
        model.CustomerOrder = CustomerOrder;

        if (!string.IsNullOrWhiteSpace(SourceOrderTitle) && string.IsNullOrWhiteSpace(model.ProductName))
        {
            model.ProductName = SourceOrderTitle;
        }

        hasInitializedFromQuery = true;
    }

    private async Task CreateAsync()
    {
        isSaving = true;
        serverErrors.Clear();

        try
        {
            var authenticationState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var userName = authenticationState.User.Identity?.Name ?? "Unknown";
            var result = await BuildRecordCreator.CreateAsync(model, userName);

            if (result.Succeeded)
            {
                var buildRecordId = result.BuildRecordId!.Value;

                if (SourceOrderId is not null)
                {
                    var linkResult = await OrderIntegrationService.LinkBuildRecordAsync(SourceOrderId.Value, buildRecordId, userName);
                    if (!linkResult.Succeeded)
                    {
                        serverErrors.Add($"Build Record {buildRecordId} was created but could not be linked back to the Order.");
                        serverErrors.AddRange(linkResult.Errors);
                        return;
                    }
                }

                NavigationManager.NavigateTo($"/build-records/{buildRecordId}");
            }
            else
            {
                serverErrors.AddRange(result.Errors);
            }
        }
        catch
        {
            serverErrors.Add("Check the database connection and try again.");
        }
        finally
        {
            isSaving = false;
        }
    }

    private string DisplaySourceOrder()
    {
        return string.IsNullOrWhiteSpace(SourceOrderNumber)
            ? SourceOrderId?.ToString() ?? "current order"
            : SourceOrderNumber;
    }
}
