@page "/rmas/new"
@rendermode InteractiveServer

@using BuildBook.Application.BuildRecords
@using BuildBook.Application.Settings
@using BuildBook.Domain.Rmas

@attribute [Authorize(Policy = BuildBookRmaPolicies.CreateRmas)]

@inject IRmaRecordService RmaRecordService
@inject ISystemSettingsService SystemSettingsService
@inject ICustomerOptionsReader CustomerOptionsReader
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager

<PageTitle>Add RMA</PageTitle>

<section class="page-heading">
    <div class="page-heading-copy">
        <p class="eyebrow">RMAs</p>
        <h1>Add a new RMA record.</h1>
        <p>Capture the core intake information now, then continue the repair workflow from the full RMA detail page.</p>
    </div>
    <div class="page-actions">
        <a class="secondary-button" href="/rmas">Back to RMA Register</a>
    </div>
</section>

<section class="form-panel" aria-labelledby="add-rma-heading">
    <div class="detail-panel-header">
        <div>
            <h2 id="add-rma-heading">Required details</h2>
            <p>Capture the customer, device and fault summary first. Planner migration traceability can be added below when this record is being recreated from the old workflow.</p>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(prefillMessage))
    {
        <div class="status-message success" role="status">
            <p>@prefillMessage</p>
        </div>
    }

    @if (serverErrors.Count > 0)
    {
        <div class="status-message error" role="alert">
            <p>The RMA record could not be saved.</p>
            <ul>
                @foreach (var error in serverErrors)
                {
                    <li>@error</li>
                }
            </ul>
        </div>
    }

    <EditForm Model="model" OnValidSubmit="CreateAsync" FormName="create-rma-record">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="form-grid">
            <div class="form-field">
                <label for="rma-customer-id">Customer</label>
                <InputSelect id="rma-customer-id" class="text-input" @bind-Value="selectedCustomerId" @bind-Value:after="HandleCustomerSelectionChangedAsync">
                    <option value="">Select customer</option>
                    @foreach (var customer in customerOptions)
                    {
                        <option value="@customer.Id">@customer.Name</option>
                    }
                </InputSelect>
                <ValidationMessage For="() => model.CustomerName" />
            </div>

            <div class="form-field">
                <label for="rma-product-name">Product name</label>
                <InputText id="rma-product-name" class="text-input" @bind-Value="model.ProductName" @bind-Value:after="RefreshSuggestionsAsync" />
                <ValidationMessage For="() => model.ProductName" />
            </div>

            <div class="form-field">
                <label for="rma-product-code">Product code</label>
                <InputText id="rma-product-code" class="text-input" @bind-Value="model.ProductCode" @bind-Value:after="RefreshSuggestionsAsync" />
            </div>

            <div class="form-field">
                <label for="rma-serial-number">Serial number</label>
                <InputText id="rma-serial-number" class="text-input" @bind-Value="model.SerialNumber" @bind-Value:after="RefreshSuggestionsAsync" />
            </div>

            <div class="form-field">
                <label for="rma-fault-summary">Fault summary</label>
                <InputText id="rma-fault-summary" class="text-input" @bind-Value="model.FaultSummary" />
                <ValidationMessage For="() => model.FaultSummary" />
            </div>

            <div class="form-field">
                <label for="rma-support-ticket">@SupportTicketLabel</label>
                <InputText id="rma-support-ticket" class="text-input" @bind-Value="model.SupportTicketNumber" />
            </div>

            <div class="form-field">
                <label for="rma-contact-name">Contact name</label>
                <InputText id="rma-contact-name" class="text-input" @bind-Value="model.ContactName" />
            </div>

            <div class="form-field">
                <label for="rma-contact-email">Contact email</label>
                <InputText id="rma-contact-email" class="text-input" @bind-Value="model.ContactEmail" />
            </div>

            <div class="form-field">
                <label for="rma-contact-phone">Contact phone</label>
                <InputText id="rma-contact-phone" class="text-input" @bind-Value="model.ContactPhone" />
            </div>

            <div class="form-field">
                <label for="rma-order-number">Original order number</label>
                <InputText id="rma-order-number" class="text-input" @bind-Value="model.OriginalOrderNumber" />
            </div>

            <div class="form-field">
                <label for="rma-invoice-number">Original invoice number</label>
                <InputText id="rma-invoice-number" class="text-input" @bind-Value="model.OriginalInvoiceNumber" />
            </div>
        </div>

        <div class="form-field form-field-wide">
            <label for="rma-fault-description">Fault description</label>
            <InputTextArea id="rma-fault-description" class="text-input" @bind-Value="model.InitialFaultDescription" />
            <ValidationMessage For="() => model.InitialFaultDescription" />
        </div>

        <section class="detail-panel detail-section rma-migration-panel" aria-labelledby="rma-migration-heading">
            <div class="detail-panel-header">
                <div>
                    <h2 id="rma-migration-heading">Planner Migration Traceability</h2>
                    <p>Use these fields when manually recreating an active Planner item in BuildBook. Leave them blank for normal new RMAs.</p>
                </div>
            </div>

            <div class="form-grid">
                <div class="form-field">
                    <label for="rma-migration-source">Migration source</label>
                    <InputText id="rma-migration-source" class="text-input" @bind-Value="model.MigrationSource" />
                </div>

                <div class="form-field">
                    <label for="rma-planner-task-title">Original Planner task title</label>
                    <InputText id="rma-planner-task-title" class="text-input" @bind-Value="model.OriginalPlannerTaskTitle" />
                </div>
            </div>

            <div class="form-field form-field-wide">
                <label for="rma-planner-notes">Original Planner notes</label>
                <InputTextArea id="rma-planner-notes" class="text-input" @bind-Value="model.OriginalPlannerNotes" />
            </div>
        </section>

        <div class="detail-panel detail-section" aria-labelledby="rma-build-record-matches-heading">
            <div class="detail-panel-header">
                <div>
                    <h2 id="rma-build-record-matches-heading">Suggested Build Records</h2>
                    <p>When serial number, product or customer details are entered, possible Build Record matches appear here.</p>
                </div>
            </div>

            @if (isLoadingSuggestions)
            {
                <p class="empty-state">Checking for matching Build Records...</p>
            }
            else if (buildRecordMatches.Count == 0)
            {
                <p class="empty-state">No Build Record suggestions yet. Continue unlinked if no match exists.</p>
            }
            else
            {
                <ul class="recent-record-list">
                    @foreach (var match in buildRecordMatches)
                    {
                        <li>
                            <button type="button" class="recent-record-link" @onclick="@(() => SelectBuildRecordMatch(match.BuildRecordId))">
                                <span class="recent-record-title">@match.ProductCode - Serial @match.SerialNumber</span>
                                <span class="recent-record-meta">@match.ProductName</span>
                                <span class="recent-record-meta">@Display(match.CustomerName)</span>
                                <span class="recent-record-meta">@string.Join(", ", match.MatchReasons)</span>
                            </button>
                        </li>
                    }
                </ul>
            }

            <div class="detail-actions">
                <span class="empty-state">
                    @(model.LinkedBuildRecordId is null
                        ? "Creating this RMA without a Build Record link."
                        : $"Linked to suggested Build Record #{model.LinkedBuildRecordId}.")
                </span>
                @if (model.LinkedBuildRecordId is not null)
                {
                    <button type="button" class="secondary-button button-small" @onclick="ClearBuildRecordMatch">Continue unlinked</button>
                }
            </div>
        </div>

        <div class="detail-panel detail-section" aria-labelledby="rma-repeat-return-heading">
            <div class="detail-panel-header">
                <div>
                    <h2 id="rma-repeat-return-heading">Repeat Return Check</h2>
                    <p>See whether this serial number or linked Build Record already has previous RMAs.</p>
                </div>
            </div>

            @if (isLoadingRepeatSummary)
            {
                <p class="empty-state">Checking previous RMAs...</p>
            }
            else if (!repeatReturnSummary.HasPreviousRmas)
            {
                <p class="empty-state">No previous RMAs were found for the current serial number or linked Build Record.</p>
            }
            else
            {
                <div class="status-message warning" role="status">
                    <p>This device has @repeatReturnSummary.PreviousRmaCount previous RMA@(repeatReturnSummary.PreviousRmaCount == 1 ? string.Empty : "s").</p>
                </div>

                <div class="table-scroll">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th scope="col">RMA number</th>
                                <th scope="col">Status</th>
                                <th scope="col">Customer</th>
                                <th scope="col">Fault summary</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var previousRma in repeatReturnSummary.PreviousRmas.Take(5))
                            {
                                <tr>
                                    <td><a class="table-link" href="@($"/rmas/{previousRma.Id}")">@previousRma.RmaNumber</a></td>
                                    <td>@FormatStatus(previousRma.Status)</td>
                                    <td>@Display(previousRma.CustomerName)</td>
                                    <td>@previousRma.FaultSummary</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        <div class="form-actions">
            <button type="submit" class="primary-button" disabled="@isSaving">
                @(isSaving ? "Saving..." : "Create RMA")
            </button>
        </div>
    </EditForm>
</section>

@code {
    [SupplyParameterFromQuery(Name = "buildRecordId")]
    public int? PrefillBuildRecordId { get; set; }

    private CreateRmaRequest model = new();
    private readonly List<string> serverErrors = [];
    private IReadOnlyList<CustomerOption> customerOptions = [];
    private IReadOnlyList<RmaBuildRecordMatchSuggestion> buildRecordMatches = [];
    private RmaRepeatReturnSummary repeatReturnSummary = RmaRepeatReturnSummary.Empty;
    private bool isSaving;
    private bool isLoadingSuggestions;
    private bool isLoadingRepeatSummary;
    private int? selectedCustomerId;
    private int? loadedPrefillBuildRecordId;
    private string? prefillMessage;
    private string supportTicketLabel = SupportTicketSettingsValidator.DefaultSupportTicketLabel;
    private string SupportTicketLabel => supportTicketLabel;

    protected override async Task OnParametersSetAsync()
    {
        await LoadSupportTicketSettingsAsync();
        await LoadCustomerOptionsAsync();

        if (PrefillBuildRecordId is not null && PrefillBuildRecordId != loadedPrefillBuildRecordId)
        {
            await LoadPrefillAsync(PrefillBuildRecordId.Value);
            loadedPrefillBuildRecordId = PrefillBuildRecordId;
        }
        else if (PrefillBuildRecordId is null && loadedPrefillBuildRecordId is not null)
        {
            loadedPrefillBuildRecordId = null;
            prefillMessage = null;
        }

        await RefreshRepeatReturnSummaryAsync();
    }

    private async Task LoadSupportTicketSettingsAsync()
    {
        var settings = await SystemSettingsService.GetSupportTicketSettingsAsync();
        supportTicketLabel = settings.SupportTicketLabel;
    }

    private async Task CreateAsync()
    {
        isSaving = true;
        serverErrors.Clear();

        try
        {
            model.CustomerName = customerOptions
                .FirstOrDefault(customer => customer.Id == selectedCustomerId)?
                .Name ?? string.Empty;

            var authenticationState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var userName = authenticationState.User.Identity?.Name ?? "Unknown";
            var result = await RmaRecordService.CreateAsync(model, userName);

            if (result.Succeeded && result.RmaRecordId is not null)
            {
                NavigationManager.NavigateTo($"/rmas/{result.RmaRecordId}");
            }
            else
            {
                serverErrors.AddRange(result.Errors);
            }
        }
        catch
        {
            serverErrors.Add("Check the database connection and try again.");
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task LoadCustomerOptionsAsync()
    {
        customerOptions = await CustomerOptionsReader.ListActiveAsync();

        if (selectedCustomerId is not null && customerOptions.Any(customer => customer.Id == selectedCustomerId.Value))
        {
            return;
        }

        var matchedCustomer = customerOptions.FirstOrDefault(
            customer => string.Equals(customer.Name, model.CustomerName, StringComparison.OrdinalIgnoreCase));
        selectedCustomerId = matchedCustomer?.Id;
    }

    private async Task HandleCustomerSelectionChangedAsync()
    {
        model.CustomerName = customerOptions
            .FirstOrDefault(customer => customer.Id == selectedCustomerId)?
            .Name ?? string.Empty;

        await RefreshSuggestionsAsync();
    }

    private async Task RefreshSuggestionsAsync()
    {
        isLoadingSuggestions = true;

        try
        {
            buildRecordMatches = await RmaRecordService.SuggestBuildRecordMatchesAsync(
                new RmaBuildRecordMatchRequest(
                    model.SerialNumber,
                    model.ProductCode,
                    model.ProductName,
                    model.CustomerName));
        }
        finally
        {
            isLoadingSuggestions = false;
        }

        await RefreshRepeatReturnSummaryAsync();
    }

    private async Task SelectBuildRecordMatch(int buildRecordId)
    {
        model.LinkedBuildRecordId = buildRecordId;
        await RefreshRepeatReturnSummaryAsync();
    }

    private async Task ClearBuildRecordMatch()
    {
        model.LinkedBuildRecordId = null;
        await RefreshRepeatReturnSummaryAsync();
    }

    private async Task LoadPrefillAsync(int buildRecordId)
    {
        var prefill = await RmaRecordService.GetCreatePrefillAsync(buildRecordId);

        if (prefill is null)
        {
            serverErrors.Clear();
            serverErrors.Add("The selected Build Record could not be loaded.");
            prefillMessage = null;
            return;
        }

        model.LinkedBuildRecordId = prefill.BuildRecordId;
        model.ProductCode = prefill.ProductCode;
        model.ProductName = prefill.ProductName;
        model.SerialNumber = prefill.SerialNumber;
        model.CustomerName = prefill.CustomerName ?? string.Empty;
        selectedCustomerId = customerOptions
            .FirstOrDefault(customer => string.Equals(customer.Name, model.CustomerName, StringComparison.OrdinalIgnoreCase))?
            .Id;
        prefillMessage = $"Pre-filled from Build Record #{prefill.BuildRecordId}.";
        await RefreshSuggestionsAsync();
    }

    private async Task RefreshRepeatReturnSummaryAsync()
    {
        isLoadingRepeatSummary = true;

        try
        {
            repeatReturnSummary = await RmaRecordService.GetRepeatReturnSummaryAsync(
                new RmaRepeatReturnRequest(
                    CurrentRmaRecordId: null,
                    LinkedBuildRecordId: model.LinkedBuildRecordId,
                    SerialNumber: model.SerialNumber));
        }
        finally
        {
            isLoadingRepeatSummary = false;
        }
    }

    private static string Display(string? value) => string.IsNullOrWhiteSpace(value) ? "Not recorded" : value;

    private static string FormatStatus(RmaStatus status) => status switch
    {
        RmaStatus.BookedIn => "Booked In",
        RmaStatus.WorkInProgress => "Work In Progress",
        RmaStatus.ReadyToShip => "Ready To Ship",
        RmaStatus.CancelledNoReply => "Cancelled / No Reply",
        RmaStatus.CustomerFixed => "Customer Fixed",
        _ => status.ToString()
    };
}
