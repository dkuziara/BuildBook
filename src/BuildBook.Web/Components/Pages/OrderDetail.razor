@page "/orders/{OrderId:int}"
@rendermode InteractiveServer

@using BuildBook.Application.Orders
@using BuildBook.Application.Security
@using BuildBook.Domain.Orders
@using Microsoft.AspNetCore.Components.Forms

@attribute [Authorize(Policy = BuildBookOrderPolicies.ViewOrders)]

@inject IOrderDetailReader OrderDetailReader
@inject IOrderWorkflowService OrderWorkflowService
@inject IApplicationUserManagementService ApplicationUserManagementService
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>@PageTitleText</PageTitle>

@if (isLoading)
{
    <section class="placeholder-panel" aria-live="polite">
        <p>Loading order details...</p>
    </section>
}
else if (orderRecord is null)
{
    <section class="page-heading">
        <div class="page-heading-copy">
            <p class="eyebrow">Orders</p>
            <h1>Order not found.</h1>
            <p>The order may not exist, or it may no longer be active.</p>
        </div>
        <div class="page-actions">
            <a class="secondary-button" href="/orders">Back to Orders</a>
        </div>
    </section>
}
else
{
    <section class="page-heading">
        <div class="page-heading-copy">
            <p class="eyebrow">Orders</p>
            <h1>@orderRecord.OrderTitle</h1>
            <p>Order workflow, assignments, checklist progress and imported Planner context.</p>
        </div>
        <div class="page-actions">
            <a class="secondary-button" href="/orders">Back to Orders</a>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <div class="status-message @(statusIsError ? "error" : "success")" role="status">
            <p>@statusMessage</p>
        </div>
    }

    <section class="detail-panel" aria-labelledby="order-summary-heading">
        <div class="detail-panel-header">
            <div>
                <h2 id="order-summary-heading">Summary</h2>
                <p>Operational highlights for this Order.</p>
            </div>
        </div>

        <dl class="summary-list">
            <div>
                <dt>Order number</dt>
                <dd>@orderRecord.OrderNumber</dd>
            </div>
            <div>
                <dt>Status</dt>
                <dd>@orderRecord.Status</dd>
            </div>
            <div>
                <dt>Customer</dt>
                <dd>
                    @if (orderRecord.CustomerId is not null && !string.IsNullOrWhiteSpace(orderRecord.CustomerName))
                    {
                        <a class="table-link" href="@($"/customers/{orderRecord.CustomerId.Value}")">@orderRecord.CustomerName</a>
                    }
                    else
                    {
                        @Display(orderRecord.CustomerName)
                    }
                </dd>
            </div>
            <div>
                <dt>Priority</dt>
                <dd>@Display(orderRecord.Priority?.ToString() ?? orderRecord.ImportedPriorityText)</dd>
            </div>
            <div>
                <dt>Assigned users</dt>
                <dd>@(orderRecord.Assignments.Count == 0 ? "Unassigned" : string.Join(", ", orderRecord.Assignments.Select(assignment => assignment.DisplayName)))</dd>
            </div>
            <div>
                <dt>Checklist progress</dt>
                <dd>@($"{orderRecord.ChecklistItems.Count(item => item.IsCompleted)} / {orderRecord.ChecklistItems.Count}")</dd>
            </div>
            <div>
                <dt>Linked Build Records</dt>
                <dd>@orderRecord.LinkedBuildRecords.Count</dd>
            </div>
            <div>
                <dt>Support ticket no.</dt>
                <dd>@Display(orderRecord.SupportTicketNo)</dd>
            </div>
        </dl>
    </section>

    <section class="detail-panel detail-section" aria-labelledby="order-workflow-heading">
        <div class="detail-panel-header">
            <div>
                <h2 id="order-workflow-heading">Workflow</h2>
                <p>Priority and planning dates for this Order.</p>
            </div>
            <AuthorizeView Policy="@BuildBookOrderPolicies.EditOrders">
                <Authorized Context="workflowAuthorization">
                    @if (!isEditingWorkflow)
                    {
                        <button type="button" class="secondary-button" @onclick="StartEditingWorkflow">Edit</button>
                    }
                </Authorized>
            </AuthorizeView>
        </div>

        @if (isEditingWorkflow)
        {
            @SectionErrors(workflowErrors, "Workflow details could not be saved.")

            <EditForm Model="workflowModel" OnValidSubmit="SaveWorkflowAsync" FormName="edit-order-workflow">
                <div class="form-grid">
                    <div class="form-field">
                        <label for="edit-order-priority">Priority</label>
                        <InputSelect TValue="OrderPriority?" id="edit-order-priority" class="text-input" @bind-Value="workflowModel.Priority">
                            <option value="">Not set</option>
                            @foreach (var priority in Enum.GetValues<OrderPriority>())
                            {
                                <option value="@priority">@priority</option>
                            }
                        </InputSelect>
                    </div>

                    <div class="form-field">
                        <label for="edit-order-start-date">Start date</label>
                        <InputDate id="edit-order-start-date" class="text-input" @bind-Value="workflowModel.StartDate" />
                    </div>

                    <div class="form-field">
                        <label for="edit-order-due-date">Due date</label>
                        <InputDate id="edit-order-due-date" class="text-input" @bind-Value="workflowModel.DueDate" />
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="primary-button" disabled="@isSavingWorkflow">@(isSavingWorkflow ? "Saving..." : "Save workflow details")</button>
                    <button type="button" class="secondary-button" disabled="@isSavingWorkflow" @onclick="CancelWorkflowEdit">Cancel</button>
                </div>
            </EditForm>
        }
        else
        {
            <dl class="summary-list">
                <div>
                    <dt>Priority</dt>
                    <dd>@Display(orderRecord.Priority?.ToString() ?? orderRecord.ImportedPriorityText)</dd>
                </div>
                <div>
                    <dt>Start date</dt>
                    <dd>@Display(orderRecord.StartDate)</dd>
                </div>
                <div>
                    <dt>Due date</dt>
                    <dd>@Display(orderRecord.DueDate)</dd>
                </div>
                <div>
                    <dt>Completed date</dt>
                    <dd>@Display(orderRecord.CompletedAt)</dd>
                </div>
                <div>
                    <dt>Completed by</dt>
                    <dd>@Display(orderRecord.CompletedBy)</dd>
                </div>
            </dl>
        }
    </section>

    <section class="detail-panel detail-section" aria-labelledby="order-status-heading">
        <div class="detail-panel-header">
            <div>
                <h2 id="order-status-heading">Status Workflow</h2>
                <p>Move the Order through the configured workflow with readiness warnings.</p>
            </div>
            <AuthorizeView Policy="@BuildBookOrderPolicies.ChangeOrderStatus">
                <Authorized Context="statusAuthorization">
                    @if (!isEditingStatus)
                    {
                        <button type="button" class="secondary-button" @onclick="StartEditingStatus">Change status</button>
                    }
                </Authorized>
            </AuthorizeView>
        </div>

        @if (isEditingStatus)
        {
            @SectionErrors(statusErrors, "Status change could not be saved.")

            @if (statusWarnings.Count > 0)
            {
                <div class="status-message warning" role="alert">
                    <p>Workflow warnings were found.</p>
                    <ul>
                        @foreach (var warning in statusWarnings)
                        {
                            <li>@warning</li>
                        }
                    </ul>
                </div>

                <label class="role-checkbox">
                    <InputCheckbox @bind-Value="confirmStatusWarnings" class="darker-border-checkbox form-check-input" />
                    <span>Continue with the status change anyway</span>
                </label>
            }

            <EditForm Model="statusModel" OnValidSubmit="SaveStatusAsync" FormName="change-order-status">
                <div class="form-grid">
                    <div class="form-field">
                        <label for="edit-order-status">New status</label>
                        <InputSelect id="edit-order-status" class="text-input" @bind-Value="statusModel.NewStatus">
                            @foreach (var status in BuildBookOrderStatuses.DefaultWorkflow)
                            {
                                <option value="@status">@status</option>
                            }
                        </InputSelect>
                    </div>
                </div>

                <div class="form-field form-field-wide">
                    <label for="edit-order-status-reason">Status note</label>
                    <InputTextArea id="edit-order-status-reason" class="text-input" @bind-Value="statusModel.Reason" />
                </div>

                <div class="form-actions">
                    <button type="submit" class="primary-button" disabled="@isSavingStatus">@(isSavingStatus ? "Saving..." : "Save status change")</button>
                    <button type="button" class="secondary-button" disabled="@isSavingStatus" @onclick="CancelStatusEdit">Cancel</button>
                </div>
            </EditForm>
        }
        else
        {
            <dl class="summary-list">
                <div>
                    <dt>Current status</dt>
                    <dd>@orderRecord.Status</dd>
                </div>
                <div>
                    <dt>Status note</dt>
                    <dd>@Display(orderRecord.StatusHistory.FirstOrDefault()?.Reason)</dd>
                </div>
            </dl>
        }
    </section>

    <section class="detail-panel detail-section" aria-labelledby="order-overview-heading">
        <div class="detail-panel-header">
            <div>
                <h2 id="order-overview-heading">Overview</h2>
                <p>The main order description and compact planner-derived summary.</p>
            </div>
        </div>

        <dl class="summary-list">
            <div>
                <dt>Order description / notes</dt>
                <dd>@Display(orderRecord.OrderDescription)</dd>
            </div>
            <div>
                <dt>Notes summary</dt>
                <dd>@Display(orderRecord.NotesSummary)</dd>
            </div>
            <div>
                <dt>Recurring</dt>
                <dd>@(orderRecord.IsRecurring ? "Yes" : "No")</dd>
            </div>
            <div>
                <dt>Imported late flag</dt>
                <dd>@DisplayBoolean(orderRecord.ImportedLateFlag)</dd>
            </div>
            <div>
                <dt>Labels</dt>
                <dd>@FormatLabels()</dd>
            </div>
        </dl>
    </section>

    <section class="detail-panel detail-section" aria-labelledby="order-details-heading">
        <div class="detail-panel-header">
            <div>
                <h2 id="order-details-heading">Order Details</h2>
                <p>Reference fields and owner details stored against the Order.</p>
            </div>
        </div>

        <dl class="summary-list">
            <div>
                <dt>Customer reference</dt>
                <dd>@Display(orderRecord.CustomerReference)</dd>
            </div>
            <div>
                <dt>Customer purchase order no.</dt>
                <dd>@Display(orderRecord.CustomerPurchaseOrderNumber)</dd>
            </div>
            <div>
                <dt>Internal order reference</dt>
                <dd>@Display(orderRecord.InternalOrderReference)</dd>
            </div>
            <div>
                <dt>Quote number</dt>
                <dd>@Display(orderRecord.QuoteNumber)</dd>
            </div>
            <div>
                <dt>Sales / Admin owner</dt>
                <dd>@Display(orderRecord.SalesAdminOwner)</dd>
            </div>
            <div>
                <dt>Production owner</dt>
                <dd>@Display(orderRecord.ProductionOwner)</dd>
            </div>
        </dl>
    </section>

    <section class="detail-panel detail-section" aria-labelledby="order-dates-heading">
        <div class="detail-panel-header">
            <div>
                <h2 id="order-dates-heading">Dates</h2>
                <p>Tracked dates for creation, planned work and completion.</p>
            </div>
        </div>

        <dl class="summary-list">
            <div>
                <dt>Start date</dt>
                <dd>@Display(orderRecord.StartDate)</dd>
            </div>
            <div>
                <dt>Due date</dt>
                <dd>@Display(orderRecord.DueDate)</dd>
            </div>
            <div>
                <dt>Completed date</dt>
                <dd>@Display(orderRecord.CompletedAt)</dd>
            </div>
            <div>
                <dt>Completed by</dt>
                <dd>@Display(orderRecord.CompletedBy)</dd>
            </div>
            <div>
                <dt>Created</dt>
                <dd>@orderRecord.CreatedAt.ToLocalTime().ToString("d MMM yyyy HH:mm")</dd>
            </div>
            <div>
                <dt>Created by</dt>
                <dd>@Display(orderRecord.CreatedBy)</dd>
            </div>
            <div>
                <dt>Last updated</dt>
                <dd>@orderRecord.LastUpdatedAt.ToLocalTime().ToString("d MMM yyyy HH:mm")</dd>
            </div>
            <div>
                <dt>Last updated by</dt>
                <dd>@Display(orderRecord.LastUpdatedBy)</dd>
            </div>
        </dl>
    </section>

    <section class="table-panel compact-table-panel detail-section" aria-labelledby="order-assignments-heading">
        <div class="table-panel-heading">
            <div>
                <h2 id="order-assignments-heading">Assignments</h2>
                <p>@orderRecord.Assignments.Count assignments</p>
            </div>
        </div>

        <AuthorizeView Policy="@BuildBookOrderPolicies.EditOrders">
            <Authorized Context="assignmentAuthorization">
                @SectionErrors(assignmentErrors, "Assignment could not be saved.")

                <EditForm Model="assignmentModel" OnValidSubmit="SaveAssignmentAsync" FormName="add-order-assignment">
                    <div class="form-grid">
                        <div class="form-field">
                            <label for="edit-order-assignment-user">BuildBook user</label>
                            <InputSelect TValue="int?" id="edit-order-assignment-user" class="text-input" @bind-Value="assignmentModel.ApplicationUserId">
                                <option value="">Select user</option>
                                @foreach (var user in userOptions)
                                {
                                    <option value="@user.Id">@user.Label</option>
                                }
                            </InputSelect>
                        </div>

                        <div class="form-field">
                            <label for="edit-order-assignment-type">Assignment type</label>
                            <InputSelect TValue="OrderAssignmentType?" id="edit-order-assignment-type" class="text-input" @bind-Value="assignmentModel.AssignmentType">
                                <option value="">Not set</option>
                                @foreach (var assignmentType in Enum.GetValues<OrderAssignmentType>())
                                {
                                    <option value="@assignmentType">@assignmentType</option>
                                }
                            </InputSelect>
                        </div>

                        <div class="form-field">
                            <label for="edit-order-imported-user-text">Imported / external user</label>
                            <InputText id="edit-order-imported-user-text" class="text-input" @bind-Value="assignmentModel.ImportedUserText" />
                        </div>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="primary-button" disabled="@isSavingAssignment">@(isSavingAssignment ? "Saving..." : "Add assignment")</button>
                    </div>
                </EditForm>
            </Authorized>
        </AuthorizeView>

        @if (orderRecord.Assignments.Count == 0)
        {
            <p class="empty-state">No assignments have been recorded for this Order yet.</p>
        }
        else
        {
            <div class="table-scroll">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th scope="col">Assigned to</th>
                            <th scope="col">Assignment type</th>
                            <th scope="col">Assigned at</th>
                            <AuthorizeView Policy="@BuildBookOrderPolicies.EditOrders">
                                <Authorized>
                                    <th scope="col">Actions</th>
                                </Authorized>
                            </AuthorizeView>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var assignment in orderRecord.Assignments)
                        {
                            <tr>
                                <td>@assignment.DisplayName</td>
                                <td>@Display(assignment.AssignmentType)</td>
                                <td>@assignment.AssignedAt.ToLocalTime().ToString("d MMM yyyy HH:mm")</td>
                                <AuthorizeView Policy="@BuildBookOrderPolicies.EditOrders">
                                    <Authorized>
                                        <td>
                                            <button type="button" class="secondary-button" @onclick="() => RemoveAssignmentAsync(assignment.Id)">Remove</button>
                                        </td>
                                    </Authorized>
                                </AuthorizeView>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>

    <section class="table-panel compact-table-panel detail-section" aria-labelledby="order-checklist-heading">
        <div class="table-panel-heading">
            <div>
                <h2 id="order-checklist-heading">Checklist</h2>
                <p>@orderRecord.ChecklistItems.Count checklist items</p>
            </div>
        </div>

        <AuthorizeView Policy="@BuildBookOrderPolicies.CompleteOrderChecklist">
            <Authorized Context="checklistAuthorization">
                @SectionErrors(checklistErrors, "Checklist could not be updated.")

                <EditForm Model="checklistModel" OnValidSubmit="AddChecklistItemAsync" FormName="add-order-checklist-item">
                    <div class="form-grid">
                        <div class="form-field form-field-wide">
                            <label for="edit-order-checklist-text">Checklist item</label>
                            <InputText id="edit-order-checklist-text" class="text-input" @bind-Value="checklistModel.Text" />
                        </div>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="primary-button" disabled="@isSavingChecklist">@(isSavingChecklist ? "Saving..." : "Add checklist item")</button>
                    </div>
                </EditForm>
            </Authorized>
        </AuthorizeView>

        @if (orderRecord.ChecklistItems.Count == 0)
        {
            <p class="empty-state">No checklist items are recorded for this Order yet.</p>
        }
        else
        {
            <div class="table-scroll">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th scope="col">Done</th>
                            <th scope="col">Checklist item</th>
                            <th scope="col">Completed by</th>
                            <th scope="col">Completed at</th>
                            <AuthorizeView Policy="@BuildBookOrderPolicies.CompleteOrderChecklist">
                                <Authorized>
                                    <th scope="col">Actions</th>
                                </Authorized>
                            </AuthorizeView>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var checklistItem in orderRecord.ChecklistItems)
                        {
                            <tr>
                                <td>@(checklistItem.IsCompleted ? "Yes" : "No")</td>
                                <td>@checklistItem.Text</td>
                                <td>@Display(checklistItem.CompletedBy)</td>
                                <td>@Display(checklistItem.CompletedAt)</td>
                                <AuthorizeView Policy="@BuildBookOrderPolicies.CompleteOrderChecklist">
                                    <Authorized>
                                        <td>
                                            <button type="button" class="secondary-button" @onclick="() => ToggleChecklistItemAsync(checklistItem)">
                                                @(checklistItem.IsCompleted ? "Mark incomplete" : "Mark complete")
                                            </button>
                                        </td>
                                    </Authorized>
                                </AuthorizeView>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>

    <section class="table-panel compact-table-panel detail-section" aria-labelledby="order-linked-build-records-heading">
        <div class="table-panel-heading">
            <h2 id="order-linked-build-records-heading">Linked Build Records</h2>
            <p>@orderRecord.LinkedBuildRecords.Count linked Build Records</p>
        </div>

        @if (orderRecord.LinkedBuildRecords.Count == 0)
        {
            <p class="empty-state">No Build Records are linked to this Order yet.</p>
        }
        else
        {
            <div class="table-scroll">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th scope="col">Build Record</th>
                            <th scope="col">Serial number</th>
                            <th scope="col">Machine name</th>
                            <th scope="col">Link type</th>
                            <th scope="col">Linked at</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var buildRecordLink in orderRecord.LinkedBuildRecords)
                        {
                            <tr>
                                <td><a class="table-link" href="@($"/build-records/{buildRecordLink.BuildRecordId}")">@buildRecordLink.ProductCode / @buildRecordLink.ProductName</a></td>
                                <td>@buildRecordLink.SerialNumber</td>
                                <td>@Display(buildRecordLink.MachineName)</td>
                                <td>@Display(buildRecordLink.LinkType)</td>
                                <td>@buildRecordLink.LinkedAt.ToLocalTime().ToString("d MMM yyyy HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>

    <section class="detail-panel detail-section" aria-labelledby="order-notes-heading">
        <div class="detail-panel-header">
            <div>
                <h2 id="order-notes-heading">Notes</h2>
                <p>Imported planner notes and future operational notes appear here.</p>
            </div>
        </div>

        @if (orderRecord.Notes.Count == 0)
        {
            <p class="empty-state">No notes have been recorded for this Order yet.</p>
        }
        else
        {
            <ul class="recent-record-list">
                @foreach (var note in orderRecord.Notes)
                {
                    <li>
                        <strong>@note.NoteType</strong>
                        <div>@note.NoteText</div>
                        <div>@Display(note.CreatedBy) | @note.CreatedAt.ToLocalTime().ToString("d MMM yyyy HH:mm")</div>
                    </li>
                }
            </ul>
        }
    </section>

    <section class="table-panel compact-table-panel detail-section" aria-labelledby="order-history-heading">
        <div class="table-panel-heading">
            <h2 id="order-history-heading">History</h2>
            <p>@orderRecord.StatusHistory.Count recorded status changes</p>
        </div>

        @if (orderRecord.StatusHistory.Count == 0)
        {
            <p class="empty-state">No status history has been recorded for this Order yet.</p>
        }
        else
        {
            <div class="table-scroll">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th scope="col">Changed at</th>
                            <th scope="col">Old status</th>
                            <th scope="col">New status</th>
                            <th scope="col">Changed by</th>
                            <th scope="col">Reason</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var statusHistoryEntry in orderRecord.StatusHistory)
                        {
                            <tr>
                                <td>@statusHistoryEntry.ChangedAt.ToLocalTime().ToString("d MMM yyyy HH:mm")</td>
                                <td>@Display(statusHistoryEntry.OldStatus)</td>
                                <td>@statusHistoryEntry.NewStatus</td>
                                <td>@Display(statusHistoryEntry.ChangedBy)</td>
                                <td>@Display(statusHistoryEntry.Reason)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>

    <section class="detail-panel detail-section" aria-labelledby="order-planner-heading">
        <div class="detail-panel-header">
            <div>
                <h2 id="order-planner-heading">Planner Import Traceability</h2>
                <p>Original Planner identifiers are kept for historic import review and reconciliation.</p>
            </div>
        </div>

        <dl class="summary-list">
            <div>
                <dt>Planner task ID</dt>
                <dd>@Display(orderRecord.PlannerTaskId)</dd>
            </div>
            <div>
                <dt>Planner plan ID</dt>
                <dd>@Display(orderRecord.PlannerPlanId)</dd>
            </div>
            <div>
                <dt>Planner bucket ID</dt>
                <dd>@Display(orderRecord.PlannerBucketId)</dd>
            </div>
            <div>
                <dt>Planner bucket name</dt>
                <dd>@Display(orderRecord.PlannerBucketName)</dd>
            </div>
            <div>
                <dt>Planner source</dt>
                <dd>@Display(orderRecord.PlannerSource)</dd>
            </div>
            <div>
                <dt>Planner status</dt>
                <dd>@Display(orderRecord.PlannerStatus)</dd>
            </div>
            <div>
                <dt>Planner goal</dt>
                <dd>@Display(orderRecord.PlannerGoal)</dd>
            </div>
        </dl>
    </section>
}

@code {
    [Parameter]
    public int OrderId { get; set; }

    private OrderDetailModel? orderRecord;
    private bool isLoading = true;
    private bool statusIsError;
    private string? statusMessage;
    private bool isEditingWorkflow;
    private bool isSavingWorkflow;
    private bool isEditingStatus;
    private bool isSavingStatus;
    private bool isSavingAssignment;
    private bool isSavingChecklist;
    private bool confirmStatusWarnings;
    private UpdateOrderWorkflowRequest workflowModel = new();
    private ChangeOrderStatusRequest statusModel = new();
    private SaveOrderAssignmentRequest assignmentModel = new();
    private UpdateOrderChecklistItemRequest checklistModel = new();
    private List<string> workflowErrors = [];
    private List<string> statusErrors = [];
    private List<string> statusWarnings = [];
    private List<string> assignmentErrors = [];
    private List<string> checklistErrors = [];
    private IReadOnlyList<OrderUserOption> userOptions = [];

    private string PageTitleText => orderRecord is null ? "Order Detail" : $"{orderRecord.OrderNumber} | Order Detail";

    protected override async Task OnParametersSetAsync()
    {
        await LoadOrderAsync();
    }

    private async Task LoadOrderAsync()
    {
        isLoading = true;

        try
        {
            orderRecord = await OrderDetailReader.GetByIdAsync(OrderId);
            var users = await ApplicationUserManagementService.ListAsync();
            userOptions = users
                .Where(user => user.IsActive)
                .Select(user => new OrderUserOption(
                    user.Id,
                    user.DisplayName ?? user.EmailAddress ?? user.WindowsUserName))
                .OrderBy(user => user.Label, StringComparer.OrdinalIgnoreCase)
                .ToArray();
        }
        finally
        {
            isLoading = false;
        }
    }

    private void StartEditingWorkflow()
    {
        if (orderRecord is null)
        {
            return;
        }

        workflowModel = new UpdateOrderWorkflowRequest
        {
            Priority = orderRecord.Priority,
            StartDate = orderRecord.StartDate,
            DueDate = orderRecord.DueDate
        };

        workflowErrors.Clear();
        statusMessage = null;
        isEditingWorkflow = true;
    }

    private async Task SaveWorkflowAsync()
    {
        isSavingWorkflow = true;
        workflowErrors.Clear();

        try
        {
            var result = await OrderWorkflowService.UpdateWorkflowAsync(OrderId, workflowModel, await GetCurrentUserNameAsync());
            if (result.Succeeded)
            {
                await LoadOrderAsync();
                isEditingWorkflow = false;
                statusMessage = "Workflow details were updated.";
                statusIsError = false;
            }
            else
            {
                workflowErrors.AddRange(result.Errors);
            }
        }
        catch
        {
            workflowErrors.Add("Check the database connection and try again.");
        }
        finally
        {
            isSavingWorkflow = false;
        }
    }

    private void CancelWorkflowEdit()
    {
        workflowErrors.Clear();
        isEditingWorkflow = false;
    }

    private void StartEditingStatus()
    {
        if (orderRecord is null)
        {
            return;
        }

        statusModel = new ChangeOrderStatusRequest
        {
            NewStatus = orderRecord.Status
        };

        statusErrors.Clear();
        statusWarnings.Clear();
        confirmStatusWarnings = false;
        statusMessage = null;
        isEditingStatus = true;
    }

    private async Task SaveStatusAsync()
    {
        isSavingStatus = true;
        statusErrors.Clear();

        try
        {
            statusModel.IgnoreReadinessWarnings = confirmStatusWarnings;
            var result = await OrderWorkflowService.ChangeStatusAsync(OrderId, statusModel, await GetCurrentUserNameAsync());
            if (result.Succeeded)
            {
                await LoadOrderAsync();
                isEditingStatus = false;
                statusWarnings.Clear();
                confirmStatusWarnings = false;
                statusMessage = "Order status was updated.";
                statusIsError = false;
            }
            else if (result.RequiresConfirmation)
            {
                statusWarnings = [.. result.Warnings];
            }
            else
            {
                statusErrors.AddRange(result.Errors);
            }
        }
        catch
        {
            statusErrors.Add("Check the database connection and try again.");
        }
        finally
        {
            isSavingStatus = false;
        }
    }

    private void CancelStatusEdit()
    {
        statusErrors.Clear();
        statusWarnings.Clear();
        confirmStatusWarnings = false;
        isEditingStatus = false;
    }

