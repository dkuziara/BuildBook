@page "/build-register"
@rendermode InteractiveServer

@attribute [Authorize(Policy = BuildBookPolicies.ViewBuildRecords)]

@inject IBuildRegisterReader BuildRegisterReader

<PageTitle>Build Register</PageTitle>

<section class="page-heading">
    <div class="page-heading-copy">
        <p class="eyebrow">Build Register</p>
        <h1>Build Register</h1>
        <p>Open Build Records and review key product, customer, software and shipping details.</p>
    </div>
    <div class="page-actions">
        <AuthorizeView Policy="@BuildBookPolicies.ExportNonSensitiveData">
            <Authorized>
                <a class="secondary-button" href="/reports">Reports</a>
            </Authorized>
        </AuthorizeView>
        <AuthorizeView Policy="@BuildBookPolicies.EditBuildRecords">
            <Authorized>
                <a class="primary-button" href="/build-records/new">Add Build Record</a>
            </Authorized>
        </AuthorizeView>
    </div>
</section>

<section class="filter-panel compact-filter-panel" aria-labelledby="build-register-filters-heading">
    <div class="table-panel-heading compact-panel-title">
        <div>
            <h2 id="build-register-filters-heading">Filters</h2>
            <p>Refine the active register without pushing the list too far down the page.</p>
        </div>
    </div>

    <EditForm Model="filterModel" OnValidSubmit="ApplyFiltersAsync" FormName="build-register-filters">
        <div class="filter-grid">
            <div class="form-field">
                <label for="filter-customer">Customer</label>
                <InputText id="filter-customer" class="text-input" @bind-Value="filterModel.Customer" />
            </div>

            <div class="form-field">
                <label for="filter-product-code">Product code</label>
                <InputText id="filter-product-code" class="text-input" @bind-Value="filterModel.ProductCode" />
            </div>

            <div class="form-field">
                <label for="filter-date-shipped">Date shipped</label>
                <InputDate id="filter-date-shipped" class="text-input" @bind-Value="filterModel.DateShipped" />
            </div>

            <div class="form-field">
                <label for="filter-radsight-version">RadSight version</label>
                <InputText id="filter-radsight-version" class="text-input" @bind-Value="filterModel.RadSightVersion" />
            </div>

            <div class="form-field">
                <label for="filter-windows-version">Windows version</label>
                <InputText id="filter-windows-version" class="text-input" @bind-Value="filterModel.WindowsVersion" />
            </div>
        </div>

        <div class="form-actions register-actions">
            <button type="submit" class="primary-button" disabled="@isLoading">Apply filters</button>
            <button type="button" class="secondary-button" disabled="@(!canClearFilters)" @onclick="ClearFiltersAsync">Clear filters</button>
            <AuthorizeView Policy="@BuildBookPolicies.ExportNonSensitiveData">
                <Authorized Context="exportAuthorizationState">
                    @if (buildRecords is { Count: > 0 })
                    {
                        <a class="action-link" href="@BuildRegisterCsvDownloadUrl">Export current results to CSV</a>
                        <a class="action-link" href="@BuildRegisterExcelDownloadUrl">Export current results to Excel</a>
                    }
                </Authorized>
            </AuthorizeView>
        </div>
    </EditForm>
</section>

@if (buildRecords is null)
{
    <section class="placeholder-panel" aria-live="polite">
        <p>Loading Build Records...</p>
    </section>
}
else if (buildRecords.Count == 0)
{
    <section class="placeholder-panel" aria-labelledby="empty-build-register-heading">
        <h2 id="empty-build-register-heading">No Build Records found</h2>
        <p>@(hasActiveFilters ? "No Build Records match the current filters." : "Add the first Build Record to start replacing the spreadsheet.")</p>
    </section>
}
else
{
    <section class="table-panel compact-table-panel" aria-labelledby="build-register-table-heading">
        <div class="table-panel-heading">
            <h2 id="build-register-table-heading">Build Records</h2>
            <p>@buildRecords.Count @(hasActiveFilters ? "matching" : "active") records</p>
        </div>

        <div class="table-scroll">
            <table class="data-table">
                <thead>
                    <tr>
                        <th scope="col"><button type="button" class="sort-button" @onclick="@(() => SortByAsync(BuildRegisterSortColumn.ProductCode))">Product code @SortIndicator(BuildRegisterSortColumn.ProductCode)</button></th>
                        <th scope="col"><button type="button" class="sort-button" @onclick="@(() => SortByAsync(BuildRegisterSortColumn.ProductName))">Product name @SortIndicator(BuildRegisterSortColumn.ProductName)</button></th>
                        <th scope="col"><button type="button" class="sort-button" @onclick="@(() => SortByAsync(BuildRegisterSortColumn.SerialNumber))">Serial number @SortIndicator(BuildRegisterSortColumn.SerialNumber)</button></th>
                        <th scope="col"><button type="button" class="sort-button" @onclick="@(() => SortByAsync(BuildRegisterSortColumn.Customer))">Customer @SortIndicator(BuildRegisterSortColumn.Customer)</button></th>
                        <th scope="col"><button type="button" class="sort-button" @onclick="@(() => SortByAsync(BuildRegisterSortColumn.MachineName))">Machine name @SortIndicator(BuildRegisterSortColumn.MachineName)</button></th>
                        <th scope="col"><button type="button" class="sort-button" @onclick="@(() => SortByAsync(BuildRegisterSortColumn.RadSightVersion))">RadSight version @SortIndicator(BuildRegisterSortColumn.RadSightVersion)</button></th>
                        <th scope="col"><button type="button" class="sort-button" @onclick="@(() => SortByAsync(BuildRegisterSortColumn.WindowsVersion))">Windows version @SortIndicator(BuildRegisterSortColumn.WindowsVersion)</button></th>
                        <th scope="col"><button type="button" class="sort-button" @onclick="@(() => SortByAsync(BuildRegisterSortColumn.DateAssembled))">Date assembled @SortIndicator(BuildRegisterSortColumn.DateAssembled)</button></th>
                        <th scope="col"><button type="button" class="sort-button" @onclick="@(() => SortByAsync(BuildRegisterSortColumn.DateShipped))">Date shipped @SortIndicator(BuildRegisterSortColumn.DateShipped)</button></th>
                        <th scope="col"><button type="button" class="sort-button" @onclick="@(() => SortByAsync(BuildRegisterSortColumn.CheckedBy))">Checked by @SortIndicator(BuildRegisterSortColumn.CheckedBy)</button></th>
                        <th scope="col"><button type="button" class="sort-button" @onclick="@(() => SortByAsync(BuildRegisterSortColumn.LastUpdated))">Last updated @SortIndicator(BuildRegisterSortColumn.LastUpdated)</button></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var buildRecord in buildRecords)
                    {
                        <tr>
                            <td>@Display(buildRecord.ProductCode)</td>
                            <td>@Display(buildRecord.ProductName)</td>
                            <td>
                                <a class="table-link" href="@($"/build-records/{buildRecord.Id}")">@buildRecord.SerialNumber</a>
                            </td>
                            <td>@Display(buildRecord.CustomerName)</td>
                            <td>@Display(buildRecord.MachineName)</td>
                            <td>@Display(buildRecord.RadSightVersion)</td>
                            <td>@Display(buildRecord.WindowsVersion)</td>
                            <td>@Display(buildRecord.DateAssembled)</td>
                            <td>@Display(buildRecord.DateShipped)</td>
                            <td>@Display(buildRecord.CheckedBy)</td>
                            <td>@buildRecord.LastUpdatedAt.ToLocalTime().ToString("d MMM yyyy HH:mm")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
}

@code {
    private IReadOnlyList<BuildRegisterRow>? buildRecords;
    private BuildRegisterFilter filterModel = new();
    private bool hasActiveFilters;
    private bool isLoading;
    private bool canClearFilters => !isLoading && hasActiveFilters;
    private string BuildRegisterCsvDownloadUrl => BuildExportUrl();
    private string BuildRegisterExcelDownloadUrl => BuildExportUrl("xlsx");

    protected override async Task OnInitializedAsync()
    {
        await LoadBuildRecordsAsync();
    }

    private async Task ApplyFiltersAsync()
    {
        await LoadBuildRecordsAsync(filterModel);
    }

    private async Task ClearFiltersAsync()
    {
        filterModel = new BuildRegisterFilter();
        await LoadBuildRecordsAsync();
    }

    private async Task SortByAsync(BuildRegisterSortColumn column)
    {
        if (filterModel.SortBy == column)
        {
            filterModel.SortDescending = !filterModel.SortDescending;
        }
        else
        {
            filterModel.SortBy = column;
            filterModel.SortDescending = column == BuildRegisterSortColumn.LastUpdated;
        }

        await LoadBuildRecordsAsync(filterModel);
    }

    private async Task LoadBuildRecordsAsync(BuildRegisterFilter? filter = null)
    {
        isLoading = true;
        hasActiveFilters = filter?.HasAnyFilter() == true;
        buildRecords = await BuildRegisterReader.ListAsync(filter);
        isLoading = false;
    }

    private static string Display(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "Not recorded" : value;
    }

    private static string Display(DateOnly? value)
    {
        return value?.ToString("d MMM yyyy") ?? "Not recorded";
    }

    private string SortIndicator(BuildRegisterSortColumn column)
    {
        if (filterModel.SortBy != column)
        {
            return string.Empty;
        }

        return filterModel.SortDescending ? "v" : "^";
    }

    private string BuildExportUrl(string format = "csv")
    {
        var queryParameters = new List<string>
        {
            CreateQueryParameter("sortBy", filterModel.SortBy.ToString()),
            CreateQueryParameter("sortDescending", filterModel.SortDescending.ToString().ToLowerInvariant())
        };

        AddQueryParameter(queryParameters, "customer", filterModel.Customer);
        AddQueryParameter(queryParameters, "productCode", filterModel.ProductCode);
        AddQueryParameter(queryParameters, "radSightVersion", filterModel.RadSightVersion);
        AddQueryParameter(queryParameters, "windowsVersion", filterModel.WindowsVersion);

        if (filterModel.DateShipped is not null)
        {
            queryParameters.Add(CreateQueryParameter("dateShipped", filterModel.DateShipped.Value.ToString("yyyy-MM-dd")));
        }

        return $"/reports/build-register.{format}?{string.Join("&", queryParameters)}";
    }

    private static void AddQueryParameter(ICollection<string> queryParameters, string key, string? value)
    {
        if (!string.IsNullOrWhiteSpace(value))
        {
            queryParameters.Add(CreateQueryParameter(key, value.Trim()));
        }
    }

    private static string CreateQueryParameter(string key, string value)
    {
        return $"{Uri.EscapeDataString(key)}={Uri.EscapeDataString(value)}";
    }
}
