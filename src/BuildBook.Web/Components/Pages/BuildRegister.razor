@page "/build-register"
@rendermode InteractiveServer

@attribute [Authorize(Policy = BuildBookPolicies.ViewBuildRecords)]

@inject IBuildRegisterReader BuildRegisterReader

<PageTitle>Build Register</PageTitle>

<section class="page-heading">
    <p class="eyebrow">Build Register</p>
    <h1>Build Register</h1>
    <p>Use the register to open Build Records and review the most useful product, customer, software and shipping details.</p>
    <AuthorizeView Policy="@BuildBookPolicies.EditBuildRecords">
        <Authorized>
            <p class="page-actions">
                <a class="primary-button" href="/build-records/new">Add Build Record</a>
            </p>
        </Authorized>
    </AuthorizeView>
</section>

<section class="filter-panel" aria-labelledby="build-register-filters-heading">
    <h2 id="build-register-filters-heading">Filters</h2>

    <EditForm Model="filterModel" OnValidSubmit="ApplyFiltersAsync" FormName="build-register-filters">
        <div class="filter-grid">
            <div class="form-field">
                <label for="filter-customer">Customer</label>
                <InputText id="filter-customer" class="text-input" @bind-Value="filterModel.Customer" />
            </div>

            <div class="form-field">
                <label for="filter-product-code">Product code</label>
                <InputText id="filter-product-code" class="text-input" @bind-Value="filterModel.ProductCode" />
            </div>

            <div class="form-field">
                <label for="filter-date-shipped">Date shipped</label>
                <InputDate id="filter-date-shipped" class="text-input" @bind-Value="filterModel.DateShipped" />
            </div>

            <div class="form-field">
                <label for="filter-radsight-version">RadSight version</label>
                <InputText id="filter-radsight-version" class="text-input" @bind-Value="filterModel.RadSightVersion" />
            </div>

            <div class="form-field">
                <label for="filter-windows-version">Windows version</label>
                <InputText id="filter-windows-version" class="text-input" @bind-Value="filterModel.WindowsVersion" />
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="primary-button" disabled="@isLoading">Apply filters</button>
            <button type="button" class="secondary-button" disabled="@isLoading || !hasActiveFilters" @onclick="ClearFiltersAsync">Clear filters</button>
        </div>
    </EditForm>
</section>

@if (buildRecords is null)
{
    <section class="placeholder-panel" aria-live="polite">
        <p>Loading Build Records...</p>
    </section>
}
else if (buildRecords.Count == 0)
{
    <section class="placeholder-panel" aria-labelledby="empty-build-register-heading">
        <h2 id="empty-build-register-heading">No Build Records found</h2>
        <p>@(hasActiveFilters ? "No Build Records match the current filters." : "Add the first Build Record to start replacing the spreadsheet.")</p>
    </section>
}
else
{
    <section class="table-panel" aria-labelledby="build-register-table-heading">
        <div class="table-panel-heading">
            <h2 id="build-register-table-heading">Build Records</h2>
            <p>@buildRecords.Count @(hasActiveFilters ? "matching" : "active") records</p>
        </div>

        <div class="table-scroll">
            <table class="data-table">
                <thead>
                    <tr>
                        <th scope="col">Product code</th>
                        <th scope="col">Product name</th>
                        <th scope="col">Serial number</th>
                        <th scope="col">Customer</th>
                        <th scope="col">Machine name</th>
                        <th scope="col">RadSight version</th>
                        <th scope="col">Windows version</th>
                        <th scope="col">Date assembled</th>
                        <th scope="col">Date shipped</th>
                        <th scope="col">Checked by</th>
                        <th scope="col">Last updated</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var buildRecord in buildRecords)
                    {
                        <tr>
                            <td>@Display(buildRecord.ProductCode)</td>
                            <td>@Display(buildRecord.ProductName)</td>
                            <td>
                                <a class="table-link" href="@($"/build-records/{buildRecord.Id}")">@buildRecord.SerialNumber</a>
                            </td>
                            <td>@Display(buildRecord.CustomerName)</td>
                            <td>@Display(buildRecord.MachineName)</td>
                            <td>@Display(buildRecord.RadSightVersion)</td>
                            <td>@Display(buildRecord.WindowsVersion)</td>
                            <td>@Display(buildRecord.DateAssembled)</td>
                            <td>@Display(buildRecord.DateShipped)</td>
                            <td>@Display(buildRecord.CheckedBy)</td>
                            <td>@buildRecord.LastUpdatedAt.ToLocalTime().ToString("d MMM yyyy HH:mm")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
}

@code {
    private IReadOnlyList<BuildRegisterRow>? buildRecords;
    private BuildRegisterFilter filterModel = new();
    private bool hasActiveFilters;
    private bool isLoading;

    protected override async Task OnInitializedAsync()
    {
        await LoadBuildRecordsAsync();
    }

    private async Task ApplyFiltersAsync()
    {
        await LoadBuildRecordsAsync(filterModel);
    }

    private async Task ClearFiltersAsync()
    {
        filterModel = new BuildRegisterFilter();
        await LoadBuildRecordsAsync();
    }

    private async Task LoadBuildRecordsAsync(BuildRegisterFilter? filter = null)
    {
        isLoading = true;
        hasActiveFilters = filter?.HasAnyFilter() == true;
        buildRecords = await BuildRegisterReader.ListAsync(filter);
        isLoading = false;
    }

    private static string Display(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "Not recorded" : value;
    }

    private static string Display(DateOnly? value)
    {
        return value?.ToString("d MMM yyyy") ?? "Not recorded";
    }
}
