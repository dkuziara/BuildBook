@page "/rmas"
@rendermode InteractiveServer

@attribute [Authorize(Policy = BuildBookRmaPolicies.ViewRmas)]

@inject IRmaRecordService RmaRecordService

<PageTitle>RMA Register</PageTitle>

<section class="page-heading">
    <div class="page-heading-copy">
        <p class="eyebrow">RMAs</p>
        <h1>RMA Register</h1>
        <p>Open active RMA records quickly and filter by the fields that matter during daily repair work.</p>
    </div>
    <AuthorizeView Policy="@BuildBookRmaPolicies.CreateRmas">
        <Authorized>
            <div class="page-actions">
                <a class="primary-button" href="/rmas/new">Add RMA</a>
            </div>
        </Authorized>
    </AuthorizeView>
</section>

<section class="filter-panel compact-filter-panel" aria-labelledby="rma-register-filters-heading">
    <div class="table-panel-heading compact-panel-title">
        <div>
            <h2 id="rma-register-filters-heading">Filters</h2>
            <p>Refine the active register without losing sight of current work.</p>
        </div>
    </div>

    <EditForm Model="filterModel" OnValidSubmit="ApplyFiltersAsync" FormName="rma-register-filters">
        <div class="filter-grid">
            <div class="form-field">
                <label for="rma-search">Search</label>
                <InputText id="rma-search" class="text-input" @bind-Value="filterModel.Search" />
            </div>

            <div class="form-field">
                <label for="rma-status">Status</label>
                <InputSelect id="rma-status" class="text-input" @bind-Value="filterModel.Status">
                    <option value="">Any status</option>
                    @foreach (var status in Enum.GetValues<RmaStatus>())
                    {
                        <option value="@status">@FormatStatus(status)</option>
                    }
                </InputSelect>
            </div>

            <div class="form-field">
                <label for="rma-customer">Customer</label>
                <InputText id="rma-customer" class="text-input" @bind-Value="filterModel.Customer" />
            </div>

            <div class="form-field">
                <label for="rma-product">Product</label>
                <InputText id="rma-product" class="text-input" @bind-Value="filterModel.Product" />
            </div>

            <div class="form-field">
                <label for="rma-serial">Serial number</label>
                <InputText id="rma-serial" class="text-input" @bind-Value="filterModel.SerialNumber" />
            </div>

            <div class="form-field">
                <label for="rma-assigned">Assigned to</label>
                <InputText id="rma-assigned" class="text-input" @bind-Value="filterModel.AssignedTo" />
            </div>

            <div class="form-field">
                <label for="rma-priority">Priority</label>
                <InputSelect id="rma-priority" class="text-input" @bind-Value="filterModel.Priority">
                    <option value="">Any priority</option>
                    @foreach (var priority in Enum.GetValues<RmaPriority>())
                    {
                        <option value="@priority">@priority</option>
                    }
                </InputSelect>
            </div>

            <div class="form-field">
                <label for="rma-due-date">Due date</label>
                <InputDate id="rma-due-date" class="text-input" @bind-Value="filterModel.DueDate" />
            </div>

            <div class="form-field">
                <label for="rma-link-state">Build Record link</label>
                <InputSelect id="rma-link-state" class="text-input" @bind-Value="linkedBuildRecordFilter">
                    <option value="">Any link state</option>
                    <option value="true">Linked</option>
                    <option value="false">Unlinked</option>
                </InputSelect>
            </div>
        </div>

        <div class="form-actions register-actions">
            <button type="submit" class="primary-button" disabled="@isLoading">Apply filters</button>
            <button type="button" class="secondary-button" disabled="@(!canClearFilters)" @onclick="ClearFiltersAsync">Clear filters</button>
        </div>
    </EditForm>
</section>

@if (rmaRecords is null)
{
    <section class="placeholder-panel" aria-live="polite">
        <p>Loading RMA records...</p>
    </section>
}
else if (rmaRecords.Count == 0)
{
    <section class="placeholder-panel" aria-labelledby="empty-rma-register-heading">
        <h2 id="empty-rma-register-heading">No RMA records found</h2>
        <p>@(hasActiveFilters ? "No RMA records match the current filters." : "Create the first RMA record to begin tracking repairs in BuildBook.")</p>
    </section>
}
else
{
    <section class="table-panel compact-table-panel" aria-labelledby="rma-register-table-heading">
        <div class="table-panel-heading">
            <h2 id="rma-register-table-heading">RMA Records</h2>
            <p>@rmaRecords.Count @(hasActiveFilters ? "matching" : "active") records</p>
        </div>

        <div class="table-scroll">
            <table class="data-table">
                <thead>
                    <tr>
                        <th scope="col"><button type="button" class="sort-button" @onclick="@(() => SortByAsync(RmaRegisterSortColumn.RmaNumber))">RMA number @SortIndicator(RmaRegisterSortColumn.RmaNumber)</button></th>
                        <th scope="col"><button type="button" class="sort-button" @onclick="@(() => SortByAsync(RmaRegisterSortColumn.Status))">Status @SortIndicator(RmaRegisterSortColumn.Status)</button></th>
                        <th scope="col"><button type="button" class="sort-button" @onclick="@(() => SortByAsync(RmaRegisterSortColumn.Customer))">Customer @SortIndicator(RmaRegisterSortColumn.Customer)</button></th>
                        <th scope="col"><button type="button" class="sort-button" @onclick="@(() => SortByAsync(RmaRegisterSortColumn.ProductName))">Product @SortIndicator(RmaRegisterSortColumn.ProductName)</button></th>
                        <th scope="col"><button type="button" class="sort-button" @onclick="@(() => SortByAsync(RmaRegisterSortColumn.SerialNumber))">Serial @SortIndicator(RmaRegisterSortColumn.SerialNumber)</button></th>
                        <th scope="col"><button type="button" class="sort-button" @onclick="@(() => SortByAsync(RmaRegisterSortColumn.FaultSummary))">Fault summary @SortIndicator(RmaRegisterSortColumn.FaultSummary)</button></th>
                        <th scope="col"><button type="button" class="sort-button" @onclick="@(() => SortByAsync(RmaRegisterSortColumn.Priority))">Priority @SortIndicator(RmaRegisterSortColumn.Priority)</button></th>
                        <th scope="col"><button type="button" class="sort-button" @onclick="@(() => SortByAsync(RmaRegisterSortColumn.AssignedTo))">Assigned to @SortIndicator(RmaRegisterSortColumn.AssignedTo)</button></th>
                        <th scope="col"><button type="button" class="sort-button" @onclick="@(() => SortByAsync(RmaRegisterSortColumn.DueDate))">Due date @SortIndicator(RmaRegisterSortColumn.DueDate)</button></th>
                        <th scope="col"><button type="button" class="sort-button" @onclick="@(() => SortByAsync(RmaRegisterSortColumn.LinkedBuildRecord))">Build Record @SortIndicator(RmaRegisterSortColumn.LinkedBuildRecord)</button></th>
                        <th scope="col"><button type="button" class="sort-button" @onclick="@(() => SortByAsync(RmaRegisterSortColumn.LastUpdated))">Last updated @SortIndicator(RmaRegisterSortColumn.LastUpdated)</button></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var rmaRecord in rmaRecords)
                    {
                        <tr>
                            <td><a class="table-link" href="@($"/rmas/{rmaRecord.Id}")">@rmaRecord.RmaNumber</a></td>
                            <td>@FormatStatus(rmaRecord.Status)</td>
                            <td>@Display(rmaRecord.CustomerName)</td>
                            <td>@rmaRecord.ProductName</td>
                            <td>@Display(rmaRecord.SerialNumber)</td>
                            <td>@rmaRecord.FaultSummary</td>
                            <td>@DisplayPriority(rmaRecord.Priority)</td>
                            <td>@Display(rmaRecord.AssignedTo)</td>
                            <td>@Display(rmaRecord.DueDate)</td>
                            <td>@(rmaRecord.HasLinkedBuildRecord ? "Linked" : "Unlinked")</td>
                            <td>@rmaRecord.LastUpdatedAt.ToLocalTime().ToString("d MMM yyyy HH:mm")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
}

@code {
    private IReadOnlyList<RmaRegisterRow>? rmaRecords;
    private RmaRegisterFilter filterModel = new();
    private bool hasActiveFilters;
    private bool isLoading;
    private string? linkedBuildRecordFilter;
    private bool canClearFilters => !isLoading && hasActiveFilters;

    protected override async Task OnInitializedAsync()
    {
        await LoadRmasAsync();
    }

    private async Task ApplyFiltersAsync()
    {
        filterModel.HasLinkedBuildRecord = ParseLinkedBuildRecordFilter();
        await LoadRmasAsync(filterModel);
    }

    private async Task ClearFiltersAsync()
    {
        filterModel = new RmaRegisterFilter();
        linkedBuildRecordFilter = null;
        await LoadRmasAsync();
    }

    private async Task SortByAsync(RmaRegisterSortColumn column)
    {
        if (filterModel.SortBy == column)
        {
            filterModel.SortDescending = !filterModel.SortDescending;
        }
        else
        {
            filterModel.SortBy = column;
            filterModel.SortDescending = column == RmaRegisterSortColumn.LastUpdated;
        }

        filterModel.HasLinkedBuildRecord = ParseLinkedBuildRecordFilter();
        await LoadRmasAsync(filterModel);
    }

    private async Task LoadRmasAsync(RmaRegisterFilter? filter = null)
    {
        isLoading = true;
        hasActiveFilters = filter?.HasAnyFilter() == true;
        rmaRecords = await RmaRecordService.SearchAsync(filter);
        isLoading = false;
    }

    private bool? ParseLinkedBuildRecordFilter()
    {
        return bool.TryParse(linkedBuildRecordFilter, out var parsed)
            ? parsed
            : null;
    }

    private string SortIndicator(RmaRegisterSortColumn column)
    {
        if (filterModel.SortBy != column)
        {
            return string.Empty;
        }

        return filterModel.SortDescending ? "v" : "^";
    }

    private static string Display(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "Not recorded" : value;
    }

    private static string Display(DateOnly? value)
    {
        return value?.ToString("d MMM yyyy") ?? "Not recorded";
    }

    private static string DisplayPriority(RmaPriority? value)
    {
        return value?.ToString() ?? "Not set";
    }

    private static string FormatStatus(RmaStatus status)
    {
        return status switch
        {
            RmaStatus.BookedIn => "Booked In",
            RmaStatus.WorkInProgress => "Work In Progress",
            RmaStatus.ReadyToShip => "Ready To Ship",
            RmaStatus.CancelledNoReply => "Cancelled / No Reply",
            RmaStatus.CustomerFixed => "Customer Fixed",
            _ => status.ToString()
        };
    }
}
