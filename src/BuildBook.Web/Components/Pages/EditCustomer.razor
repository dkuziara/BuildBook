@page "/customers/{CustomerId:int}/edit"
@rendermode InteractiveServer

@attribute [Authorize(Policy = BuildBookPolicies.EditCustomers)]

@inject NavigationManager NavigationManager

<PageTitle>Edit Customer</PageTitle>

<section class="placeholder-panel" aria-live="polite">
    <p>Customer editing now happens section-by-section on the customer detail page.</p>
    <p>
        <a class="primary-button" href="@($"/customers/{CustomerId}")">Open Customer Detail</a>
    </p>
</section>

@code {
    [Parameter]
    public int CustomerId { get; set; }

    protected override void OnAfterRender(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        NavigationManager.NavigateTo($"/customers/{CustomerId}");
    }
}
