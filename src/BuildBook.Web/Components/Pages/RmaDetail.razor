    private string DisplayAllowedStatuses()
    {
        return AllowedNextStatuses.Count == 0
            ? "No further status changes available"
            : string.Join(", ", AllowedNextStatuses.Select(FormatStatus));
    }

    private static string Display(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "Not recorded" : value;
    }

    private static string Display(DateOnly? value)
    {
        return value?.ToString("d MMM yyyy") ?? "Not recorded";
    }

    private static string Display(DateTimeOffset? value)
    {
        return value?.ToLocalTime().ToString("d MMM yyyy HH:mm") ?? "Not recorded";
    }

    private static string DisplayPriority(RmaPriority? value)
    {
        return value?.ToString() ?? "Not set";
    }

    private static string DisplayOutcome(RmaOutcome? value)
    {
        return value is null ? "Not recorded" : FormatOutcome(value.Value);
    }

    private static string FormatStatus(RmaStatus status)
    {
        return status switch
        {
            RmaStatus.BookedIn => "Booked In",
            RmaStatus.WorkInProgress => "Work In Progress",
            RmaStatus.ReadyToShip => "Ready To Ship",
            RmaStatus.CancelledNoReply => "Cancelled / No Reply",
            RmaStatus.CustomerFixed => "Customer Fixed",
            _ => status.ToString()
        };
    }

    private static string FormatOutcome(RmaOutcome outcome)
    {
        return outcome switch
        {
            RmaOutcome.RepairedAndReturned => "Repaired and returned",
            RmaOutcome.ReplacedAndReturned => "Replaced and returned",
            RmaOutcome.NoFaultFound => "No fault found",
            RmaOutcome.CustomerFixed => "Customer fixed",
            RmaOutcome.ReturnedUnrepaired => "Returned unrepaired",
            RmaOutcome.AwaitingCustomerResponseThenClosed => "Awaiting customer response then closed",
            _ => outcome.ToString()
        };
    }

    private static string StatusClass(RmaStatus status)
    {
        return status switch
        {
            RmaStatus.BookedIn => "status-booked-in",
            RmaStatus.WorkInProgress => "status-in-progress",
            RmaStatus.ReadyToShip => "status-ready",
            RmaStatus.Shipped => "status-shipped",
            RmaStatus.OnHold => "status-hold",
            RmaStatus.CancelledNoReply => "status-cancelled",
            RmaStatus.CustomerFixed => "status-customer-fixed",
            RmaStatus.Closed => "status-closed",
            _ => string.Empty
        };
    }
