    private static string Display(string? value) => string.IsNullOrWhiteSpace(value) ? "Not recorded" : value;
    private static string Display(DateOnly? value) => value?.ToString("d MMM yyyy") ?? "Not recorded";
    private static string Display(DateTimeOffset? value) => value?.ToLocalTime().ToString("d MMM yyyy HH:mm") ?? "Not recorded";
    private static string DisplayMetric(int? value) => value?.ToString() ?? "Not recorded";
    private static string DisplayPriority(RmaPriority? value) => value?.ToString() ?? "Not set";
    private static string DisplayOutcome(RmaOutcome? value) => value is null ? "Not recorded" : FormatOutcome(value.Value);
    private static string DisplayBool(bool? value) => value is null ? "Not recorded" : (value.Value ? "Yes" : "No");
    private static string DisplayYesNoUnknown(RmaYesNoUnknown? value) => value?.ToString() ?? "Not recorded";
    private static string DisplayCustomerImpact(RmaCustomerImpact? value) => value?.ToString() ?? "Not recorded";
    private static string DisplayFaultCategory(RmaFaultCategory? value) => value is null ? "Not recorded" : FormatFaultCategory(value.Value);
    private static string DisplayRootCauseCategory(RmaRootCauseCategory? value) => value is null ? "Not recorded" : FormatRootCauseCategory(value.Value);
    private static string DisplayTestResult(RmaTestResult? value) => value is null ? "Not recorded" : FormatTestResult(value.Value);
    private static string DisplayQaResult(RmaQaResult? value) => value is null ? "Not recorded" : FormatQaResult(value.Value);
    private static string DisplayCurrency(decimal? value) => value is null ? "Not recorded" : value.Value.ToString("0.00");

