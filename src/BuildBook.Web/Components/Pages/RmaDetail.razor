        {
            NewStatus = nextStatus
        };

        statusErrors.Clear();
        statusWarnings.Clear();
        confirmStatusWarnings = false;
        statusMessage = null;
        isEditingStatus = AllowedNextStatuses.Count > 0;
    }

    private async Task SaveStatusAsync()
    {
        isSavingStatus = true;
        statusErrors.Clear();
        statusWarnings.Clear();
        statusModel.IgnoreReadinessWarnings = confirmStatusWarnings;

        try
        {
            var result = await RmaRecordService.ChangeStatusAsync(RmaRecordId, statusModel, await GetCurrentUserNameAsync());

            if (result.Succeeded)
            {
                await LoadRmaAsync();
                isEditingStatus = false;
                statusMessage = "RMA status was updated.";
                statusIsError = false;
                confirmStatusWarnings = false;
            }
            else if (result.RequiresConfirmation)
            {
                statusWarnings.AddRange(result.Warnings);
            }
            else
            {
                statusErrors.AddRange(result.Errors);
            }
        }
        catch
        {
            statusErrors.Add("Check the database connection and try again.");
        }
        finally
        {
            isSavingStatus = false;
        }
    }

    private void CancelStatusEdit()
    {
        statusErrors.Clear();
        statusWarnings.Clear();
        confirmStatusWarnings = false;
        isEditingStatus = false;
    }

