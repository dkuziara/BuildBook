                                        <button type="button" class="secondary-button button-small" disabled="@isSavingChecklist" @onclick="@(() => ToggleChecklistItemAsync(checklistItem))">
                                            @(checklistItem.IsCompleted ? "Mark open" : "Mark complete")
                                        </button>
                                    </Authorized>
                                </AuthorizeView>
                            </td>
                        </tr>
                    }
