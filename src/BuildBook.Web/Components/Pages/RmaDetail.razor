    <section class="detail-panel detail-section" aria-labelledby="rma-parts-heading">
        <div class="detail-panel-header">
            <div>
                <h2 id="rma-parts-heading">Parts Replaced</h2>
                <p>Track replacement parts, serialised items and costs used during repair.</p>
            </div>
            <AuthorizeView Policy="@BuildBookRmaPolicies.EditRmas">
                <Authorized>
                    @if (!isEditingPart)
                    {
                        <button type="button" class="secondary-button" @onclick="StartAddingPart">Add part</button>
                    }
                </Authorized>
            </AuthorizeView>
        </div>

        @if (isEditingPart)
        {
            @SectionErrors(partErrors, "Part details could not be saved.")

            <EditForm Model="partModel" OnValidSubmit="SavePartAsync" FormName="edit-rma-part">
                <div class="form-grid">
                    <div class="form-field">
                        <label for="edit-rma-part-name">Part name</label>
                        <InputText id="edit-rma-part-name" class="text-input" @bind-Value="partModel.PartName" />
                    </div>
                    <div class="form-field">
                        <label for="edit-rma-part-number">Part number</label>
                        <InputText id="edit-rma-part-number" class="text-input" @bind-Value="partModel.PartNumber" />
                    </div>
                    <div class="form-field">
                        <label for="edit-rma-part-quantity">Quantity</label>
                        <InputNumber id="edit-rma-part-quantity" class="text-input" @bind-Value="partModel.Quantity" />
                    </div>
                    <div class="form-field">
                        <label for="edit-rma-part-serial-number">Serial number</label>
                        <InputText id="edit-rma-part-serial-number" class="text-input" @bind-Value="partModel.SerialNumber" />
                    </div>
                    <div class="form-field">
                        <label for="edit-rma-part-supplier">Supplier</label>
                        <InputText id="edit-rma-part-supplier" class="text-input" @bind-Value="partModel.Supplier" />
                    </div>
                    <div class="form-field">
                        <label for="edit-rma-part-unit-cost">Unit cost</label>
                        <InputNumber id="edit-rma-part-unit-cost" class="text-input" @bind-Value="partModel.UnitCost" />
                    </div>
                </div>
                <div class="form-field form-field-wide">
                    <label for="edit-rma-part-notes">Notes</label>
                    <InputTextArea id="edit-rma-part-notes" class="text-input" @bind-Value="partModel.Notes" />
                </div>
                <div class="form-actions">
                    <button type="submit" class="primary-button" disabled="@isSavingPart">@(isSavingPart ? "Saving..." : "Save part")</button>
                    <button type="button" class="secondary-button" disabled="@isSavingPart" @onclick="CancelPartEdit">Cancel</button>
                </div>
            </EditForm>
        }

        @if (parts.Count == 0)
        {
            <p class="empty-state">No parts have been recorded for this RMA yet.</p>
        }
        else
        {
            <div class="table-scroll">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th scope="col">Part</th>
                            <th scope="col">Part number</th>
                            <th scope="col">Qty</th>
                            <th scope="col">Serial number</th>
                            <th scope="col">Supplier</th>
                            <th scope="col">Unit cost</th>
                            <th scope="col">Notes</th>
                            <th scope="col">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var part in parts)
                        {
                            <tr>
                                <td>@part.PartName</td>
                                <td>@Display(part.PartNumber)</td>
                                <td>@part.Quantity</td>
                                <td>@Display(part.SerialNumber)</td>
                                <td>@Display(part.Supplier)</td>
                                <td>@DisplayCurrency(part.UnitCost)</td>
                                <td>@Display(part.Notes)</td>
                                <td>
                                    <div class="detail-actions">
                                        <AuthorizeView Policy="@BuildBookRmaPolicies.EditRmas">
                                            <Authorized>
                                                <button type="button" class="secondary-button button-small" @onclick="@(() => StartEditingPart(part.Id))">Edit</button>
                                                <button type="button" class="secondary-button button-small" @onclick="@(() => DeletePartAsync(part.Id))">Remove</button>
                                            </Authorized>
                                        </AuthorizeView>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>

    <section class="detail-panel detail-section" aria-labelledby="rma-checklist-heading">
