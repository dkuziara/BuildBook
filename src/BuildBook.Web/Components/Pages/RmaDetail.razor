                <div><dt>Courier</dt><dd>@Display(rmaRecord.Courier)</dd></div>
                <div><dt>Tracking number</dt><dd>@Display(rmaRecord.TrackingNumber)</dd></div>
                <div><dt>Collection arranged</dt><dd>@DisplayBool(rmaRecord.CollectionArranged)</dd></div>
                <div><dt>Collection date</dt><dd>@Display(rmaRecord.CollectionDate)</dd></div>
                <div><dt>Shipped date</dt><dd>@Display(rmaRecord.ShippedDate)</dd></div>
                <div><dt>Shipped by</dt><dd>@Display(rmaRecord.ShippedBy)</dd></div>
                <div><dt>Proof of delivery received</dt><dd>@DisplayBool(rmaRecord.ProofOfDeliveryReceived)</dd></div>
                <div><dt>Proof of delivery date</dt><dd>@Display(rmaRecord.ProofOfDeliveryDate)</dd></div>
            </dl>

            <div class="detail-section">
                <h3>Return address</h3>
                <p class="empty-state">@Display(rmaRecord.ReturnAddress)</p>
            </div>

            <div class="detail-section">
                <h3>Shipping notes</h3>
                <p class="empty-state">@Display(rmaRecord.ShippingNotes)</p>
            </div>
        }
    </section>

    <section class="detail-panel detail-section" aria-labelledby="rma-customer-summary-heading">
        <div class="detail-panel-header">
            <div>
                <h2 id="rma-customer-summary-heading">Customer-Facing Summary</h2>
                <p>Keep the return summary separate from internal repair notes.</p>
            </div>
            <AuthorizeView Policy="@BuildBookRmaPolicies.EditRmas">
                <Authorized>
                    @if (!isEditingCustomerSummary)
                    {
                        <button type="button" class="secondary-button" @onclick="StartEditingCustomerSummary">Edit</button>
                    }
                </Authorized>
            </AuthorizeView>
        </div>

        @if (isEditingCustomerSummary)
        {
            @SectionErrors(customerSummaryErrors, "Customer-facing summary could not be saved.")

            <EditForm Model="customerSummaryModel" OnValidSubmit="SaveCustomerSummaryAsync" FormName="edit-rma-customer-summary">
                <div class="form-field form-field-wide">
                    <label for="edit-rma-customer-summary">Summary</label>
                    <InputTextArea id="edit-rma-customer-summary" class="text-input" @bind-Value="customerSummaryModel.CustomerFacingSummary" />
                </div>

                <div class="form-actions">
                    <button type="submit" class="primary-button" disabled="@isSavingCustomerSummary">@(isSavingCustomerSummary ? "Saving..." : "Save customer summary")</button>
                    <button type="button" class="secondary-button" disabled="@isSavingCustomerSummary" @onclick="CancelCustomerSummaryEdit">Cancel</button>
                </div>
            </EditForm>
        }
        else
        {
            <p class="empty-state">@Display(rmaRecord.CustomerFacingSummary)</p>
        }
    </section>

    <section class="detail-panel detail-section" aria-labelledby="rma-communication-heading">
        <div class="detail-panel-header">
            <div>
                <h2 id="rma-communication-heading">Customer Communication</h2>
                <p>Record follow-ups separately from technical repair work.</p>
            </div>
        </div>

        @SectionErrors(communicationErrors, "Communication entry could not be saved.")

        <AuthorizeView Policy="@BuildBookRmaPolicies.EditRmas">
            <Authorized Context="communicationAuth">
                <EditForm Model="communicationModel" OnValidSubmit="SaveCommunicationAsync" FormName="add-rma-communication">
                    <div class="form-grid">
                        <div class="form-field">
                            <label for="edit-rma-communication-date">Communication date</label>
                            <InputDate id="edit-rma-communication-date" class="text-input" @bind-Value="communicationModel.CommunicationDate" />
                        </div>
                        <div class="form-field">
                            <label for="edit-rma-contact-method">Contact method</label>
                            <InputSelect id="edit-rma-contact-method" class="text-input" @bind-Value="communicationModel.ContactMethod">
                                <option value="">Select method</option>
                                @foreach (var method in CommunicationMethods)
                                {
                                    <option value="@method">@method</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="form-field">
                            <label for="edit-rma-contact-person">Contact person</label>
                            <InputText id="edit-rma-contact-person" class="text-input" @bind-Value="communicationModel.ContactPerson" />
                        </div>
                        <div class="form-field">
                            <label for="edit-rma-follow-up-required">Follow-up required</label>
                            <InputCheckbox id="edit-rma-follow-up-required" @bind-Value="communicationModel.FollowUpRequired" class="darker-border-checkbox form-check-input" />
                        </div>
                        <div class="form-field">
                            <label for="edit-rma-follow-up-date">Follow-up date</label>
                            <InputDate id="edit-rma-follow-up-date" class="text-input" @bind-Value="communicationModel.FollowUpDate" />
                        </div>
                    </div>

                    <div class="form-field form-field-wide">
                        <label for="edit-rma-communication-summary">Summary</label>
                        <InputTextArea id="edit-rma-communication-summary" class="text-input" @bind-Value="communicationModel.Summary" />
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="primary-button" disabled="@isSavingCommunication">@(isSavingCommunication ? "Saving..." : "Add communication entry")</button>
                    </div>
                </EditForm>
            </Authorized>
        </AuthorizeView>

        @if (communications.Count == 0)
        {
            <p class="empty-state">No customer communication has been recorded yet.</p>
        }
        else
        {
            <div class="table-scroll">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th scope="col">Date</th>
                            <th scope="col">Method</th>
                            <th scope="col">Contact</th>
                            <th scope="col">Summary</th>
                            <th scope="col">Follow-up</th>
                            <th scope="col">Recorded by</th>
                            <AuthorizeView Policy="@BuildBookRmaPolicies.EditRmas">
                                <Authorized>
                                    <th scope="col">Actions</th>
                                </Authorized>
                            </AuthorizeView>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var communication in communications)
                        {
                            <tr>
                                <td>@Display(communication.CommunicationDate)</td>
                                <td>@communication.ContactMethod</td>
                                <td>@Display(communication.ContactPerson)</td>
                                <td>@communication.Summary</td>
                                <td>@(communication.FollowUpRequired ? Display(communication.FollowUpDate) : "Not required")</td>
                                <td>@communication.CreatedBy</td>
                                <AuthorizeView Policy="@BuildBookRmaPolicies.EditRmas">
                                    <Authorized>
                                        <td>
                                            <button type="button" class="button-small" disabled="@isSavingCommunication" @onclick="@(() => DeleteCommunicationAsync(communication.Id))">Delete</button>
                                        </td>
                                    </Authorized>
                                </AuthorizeView>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>

    <section class="detail-panel detail-section" aria-labelledby="rma-attachments-heading">
        <div class="detail-panel-header">
            <div>
                <h2 id="rma-attachments-heading">Attachments</h2>
                <p>Store photos, documents and test evidence with the RMA record.</p>
            </div>
        </div>

        @SectionErrors(attachmentErrors, "Attachment could not be saved.")

        <AuthorizeView Policy="@BuildBookRmaPolicies.EditRmas">
            <Authorized Context="attachmentAuth">
                <EditForm Model="attachmentModel" OnValidSubmit="SaveAttachmentAsync" FormName="add-rma-attachment">
                    <div class="form-grid">
                        <div class="form-field">
                            <label for="edit-rma-attachment-file">File</label>
                            <InputFile id="edit-rma-attachment-file" OnChange="OnAttachmentSelected" />
                        </div>
                        <div class="form-field">
                            <label for="edit-rma-attachment-type">Attachment type</label>
                            <InputSelect id="edit-rma-attachment-type" class="text-input" @bind-Value="attachmentModel.AttachmentType">
                                <option value="">Select type</option>
                                @foreach (var attachmentType in AttachmentTypes)
                                {
                                    <option value="@attachmentType">@attachmentType</option>
                                }
                            </InputSelect>
                        </div>
                    </div>

                    <div class="form-field form-field-wide">
                        <label for="edit-rma-attachment-description">Description</label>
                        <InputTextArea id="edit-rma-attachment-description" class="text-input" @bind-Value="attachmentModel.Description" />
                    </div>

                    @if (!string.IsNullOrWhiteSpace(selectedAttachmentName))
                    {
                        <p class="empty-state">Selected file: @selectedAttachmentName</p>
                    }

                    <div class="form-actions">
                        <button type="submit" class="primary-button" disabled="@isSavingAttachment">@(isSavingAttachment ? "Uploading..." : "Upload attachment")</button>
                    </div>
                </EditForm>
            </Authorized>
        </AuthorizeView>

        @if (attachments.Count == 0)
        {
            <p class="empty-state">No attachments have been uploaded yet.</p>
        }
        else
        {
            <div class="table-scroll">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th scope="col">File</th>
                            <th scope="col">Type</th>
                            <th scope="col">Description</th>
                            <th scope="col">Uploaded</th>
                            <th scope="col">By</th>
                            <AuthorizeView Policy="@BuildBookRmaPolicies.EditRmas">
                                <Authorized>
                                    <th scope="col">Actions</th>
                                </Authorized>
                            </AuthorizeView>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var attachment in attachments)
                        {
                            <tr>
                                <td><a class="table-link" href="@GetAttachmentUrl(attachment.Id)">@attachment.FileName</a></td>
                                <td>@attachment.AttachmentType</td>
                                <td>@Display(attachment.Description)</td>
                                <td>@Display(attachment.UploadedAt)</td>
                                <td>@attachment.UploadedBy</td>
                                <AuthorizeView Policy="@BuildBookRmaPolicies.EditRmas">
                                    <Authorized>
                                        <td>
                                            <button type="button" class="button-small" disabled="@isSavingAttachment" @onclick="@(() => DeleteAttachmentAsync(attachment.Id))">Delete</button>
                                        </td>
                                    </Authorized>
                                </AuthorizeView>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>

    <section class="detail-panel detail-section" aria-labelledby="rma-notes-heading">
        <div class="detail-panel-header">
            <div>
                <h2 id="rma-notes-heading">Typed Notes</h2>
                <p>Separate internal, diagnosis, repair, customer and commercial notes.</p>
            </div>
        </div>

        @SectionErrors(noteErrors, "Note could not be saved.")

        <AuthorizeView Policy="@BuildBookRmaPolicies.EditRmas">
            <Authorized Context="noteAuth">
                <EditForm Model="noteModel" OnValidSubmit="SaveNoteAsync" FormName="add-rma-note">
                    <div class="form-grid">
                        <div class="form-field">
                            <label for="edit-rma-note-type">Note type</label>
                            <InputSelect id="edit-rma-note-type" class="text-input" @bind-Value="noteModel.NoteType">
                                @foreach (var noteType in Enum.GetValues<RmaNoteType>())
                                {
                                    <option value="@noteType">@FormatNoteType(noteType)</option>
                                }
                            </InputSelect>
                        </div>
                    </div>

                    <div class="form-field form-field-wide">
                        <label for="edit-rma-note-text">Note</label>
                        <InputTextArea id="edit-rma-note-text" class="text-input" @bind-Value="noteModel.NoteText" />
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="primary-button" disabled="@isSavingNote">@(isSavingNote ? "Saving..." : "Add note")</button>
                    </div>
                </EditForm>
            </Authorized>
        </AuthorizeView>

        @if (notes.Count == 0)
        {
            <p class="empty-state">No typed notes have been recorded yet.</p>
        }
        else
        {
            <div class="table-scroll">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th scope="col">Type</th>
                            <th scope="col">Note</th>
                            <th scope="col">Recorded</th>
                            <th scope="col">By</th>
                            <AuthorizeView Policy="@BuildBookRmaPolicies.EditRmas">
                                <Authorized>
                                    <th scope="col">Actions</th>
                                </Authorized>
                            </AuthorizeView>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var note in notes)
                        {
                            <tr>
                                <td>@FormatNoteType(note.NoteType)</td>
                                <td>@note.NoteText</td>
                                <td>@Display(note.LastUpdatedAt ?? note.CreatedAt)</td>
                                <td>@(note.LastUpdatedBy ?? note.CreatedBy)</td>
                                <AuthorizeView Policy="@BuildBookRmaPolicies.EditRmas">
                                    <Authorized>
                                        <td>
                                            <button type="button" class="button-small" disabled="@isSavingNote" @onclick="@(() => DeleteNoteAsync(note.Id))">Delete</button>
                                        </td>
                                    </Authorized>
                                </AuthorizeView>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>

    <section class="detail-panel detail-section" aria-labelledby="rma-build-record-link-heading">
        <div class="detail-panel-header">
            <div>
                <h2 id="rma-build-record-link-heading">Build Record link</h2>
                <p>Confirm whether this RMA is linked to an existing Build Record.</p>
            </div>
        </div>

        @if (rmaRecord.BuildRecordId is not null)
        {
            <dl class="summary-list">
                <div><dt>Linked Build Record</dt><dd><a class="table-link" href="@($"/build-records/{rmaRecord.BuildRecordId}")">@Display(rmaRecord.LinkedBuildRecordSerialNumber)</a></dd></div>
                <div><dt>Build product</dt><dd>@Display(rmaRecord.LinkedBuildRecordProductName)</dd></div>
                <div><dt>Build customer</dt><dd>@Display(rmaRecord.LinkedBuildRecordCustomerName)</dd></div>
            </dl>

            <AuthorizeView Policy="@BuildBookRmaPolicies.EditRmas">
                <Authorized>
                    <div class="detail-actions">
                        <button type="button" class="secondary-button" disabled="@isUpdatingLink" @onclick="UnlinkBuildRecordAsync">Unlink Build Record</button>
                    </div>
                </Authorized>
            </AuthorizeView>
        }
        else if (buildRecordSuggestions.Count == 0)
        {
            <p class="empty-state">No Build Record is linked, and no current match suggestions are available.</p>
        }
        else
        {
            <ul class="recent-record-list">
                @foreach (var suggestion in buildRecordSuggestions)
                {
                    <li>
                        <div class="recent-record-link">
                            <span class="recent-record-title">@suggestion.ProductCode - Serial @suggestion.SerialNumber</span>
                            <span class="recent-record-meta">@suggestion.ProductName</span>
                            <span class="recent-record-meta">@Display(suggestion.CustomerName)</span>
                            <span class="recent-record-meta">@string.Join(", ", suggestion.MatchReasons)</span>
                            <AuthorizeView Policy="@BuildBookRmaPolicies.EditRmas">
                                <Authorized>
                                    <span>
                                        <button type="button" class="secondary-button button-small" disabled="@isUpdatingLink" @onclick="@(() => LinkBuildRecordAsync(suggestion.BuildRecordId))">Link Build Record</button>
                                    </span>
                                </Authorized>
                            </AuthorizeView>
                        </div>
                    </li>
                }
            </ul>
        }
    </section>
}

@code {
    [Parameter]
    public int RmaRecordId { get; set; }

    private RmaDetailModel? rmaRecord;
    private UpdateRmaIntakeRequest intakeModel = new();
    private UpdateRmaFaultDetailsRequest faultDetailsModel = new();
    private UpdateRmaRepairDetailsRequest repairDetailsModel = new();
    private UpdateRmaWorkflowRequest workflowModel = new();
    private UpdateRmaShippingRequest shippingModel = new();
    private UpdateRmaCustomerSummaryRequest customerSummaryModel = new();
    private UpdateRmaTestingQaRequest testingQaModel = new();
    private ChangeRmaStatusRequest statusModel = new();
    private SaveRmaPartRequest partModel = new();
    private SaveRmaNoteRequest noteModel = new();
    private SaveRmaCommunicationRequest communicationModel = new()
    {
        CommunicationDate = DateOnly.FromDateTime(DateTime.Today)
    };
    private SaveRmaAttachmentRequest attachmentModel = new();
    private UpdateRmaChecklistItemRequest newChecklistItemModel = new();
    private IReadOnlyList<RmaBuildRecordMatchSuggestion> buildRecordSuggestions = [];
    private IReadOnlyList<RmaStatusHistoryEntry> statusHistoryEntries = [];
    private IReadOnlyList<RmaChecklistItemModel> checklistItems = [];
    private IReadOnlyList<RmaPartModel> parts = [];
    private RmaDurationMetrics? rmaMetrics;
    private RmaRepeatReturnSummary repeatReturnSummary = RmaRepeatReturnSummary.Empty;
    private IReadOnlyList<RmaNoteModel> notes = [];
    private IReadOnlyList<RmaCommunicationModel> communications = [];
    private IReadOnlyList<RmaAttachmentModel> attachments = [];
    private readonly List<string> intakeErrors = [];
    private readonly List<string> faultDetailErrors = [];
    private readonly List<string> repairDetailErrors = [];
    private readonly List<string> workflowErrors = [];
    private readonly List<string> shippingErrors = [];
    private readonly List<string> customerSummaryErrors = [];
    private readonly List<string> testingQaErrors = [];
    private readonly List<string> statusErrors = [];
    private readonly List<string> statusWarnings = [];
    private readonly List<string> partErrors = [];
    private readonly List<string> checklistErrors = [];
    private readonly List<string> noteErrors = [];
    private readonly List<string> communicationErrors = [];
    private readonly List<string> attachmentErrors = [];
    private bool isLoading = true;
    private bool isEditingIntake;
    private bool isEditingFaultDetails;
    private bool isEditingRepairDetails;
    private bool isEditingWorkflow;
    private bool isEditingShipping;
    private bool isEditingCustomerSummary;
    private bool isEditingTestingQa;
    private bool isEditingStatus;
    private bool isEditingPart;
    private bool isSavingIntake;
    private bool isSavingFaultDetails;
    private bool isSavingRepairDetails;
    private bool isSavingWorkflow;
    private bool isSavingShipping;
    private bool isSavingCustomerSummary;
    private bool isSavingTestingQa;
    private bool isSavingStatus;
    private bool isSavingPart;
    private bool isSavingChecklist;
    private bool isSavingNote;
    private bool isSavingCommunication;
    private bool isSavingAttachment;
    private bool isUpdatingLink;
    private bool confirmStatusWarnings;
    private IBrowserFile? selectedAttachmentFile;
    private string? selectedAttachmentName;
    private string? statusMessage;
    private bool statusIsError;
    private int completedChecklistCount;
    private const long MaxAttachmentSizeBytes = 15 * 1024 * 1024;
    private static readonly string[] CommunicationMethods = ["Email", "Phone", "Teams", "Freshdesk", "On site", "Other"];
    private static readonly string[] AttachmentTypes = ["Photo", "Screenshot", "Test result", "Courier document", "Customer email", "Approval", "Other"];
    private string PageTitleText => rmaRecord is null ? "RMA Record" : rmaRecord.RmaNumber;
    private IReadOnlyList<RmaStatus> AllowedNextStatuses => rmaRecord is null ? [] : RmaStatusTransitionService.GetAllowedNextStatuses(rmaRecord.Status);
    private string? CurrentStatusReason => statusHistoryEntries.FirstOrDefault()?.Reason;
    private bool ShouldShowOnHoldReason => statusModel.NewStatus == RmaStatus.OnHold;
    private bool ShouldShowClosureFields => statusModel.NewStatus == RmaStatus.Closed;
    private bool ShouldShowReasonField => statusModel.NewStatus == RmaStatus.OnHold
        || statusModel.NewStatus == RmaStatus.CancelledNoReply
        || statusModel.NewStatus == RmaStatus.CustomerFixed;

    protected override async Task OnParametersSetAsync()
    {
        await LoadRmaAsync();
    }

    private async Task LoadRmaAsync()
    {
        isLoading = true;
        rmaRecord = await RmaRecordService.GetByIdAsync(RmaRecordId);
        rmaMetrics = await RmaReportReader.GetMetricsAsync(RmaRecordId);

        if (rmaRecord is not null)
        {
            await LoadBuildRecordSuggestionsAsync();
            repeatReturnSummary = await RmaRecordService.GetRepeatReturnSummaryAsync(
                new RmaRepeatReturnRequest(
                    RmaRecordId,
                    rmaRecord.BuildRecordId,
                    rmaRecord.SerialNumber));
            statusHistoryEntries = await RmaRecordService.GetStatusHistoryAsync(RmaRecordId);
            checklistItems = await RmaRecordService.GetChecklistAsync(RmaRecordId);
            parts = await RmaRecordService.GetPartsAsync(RmaRecordId);
            notes = await RmaRecordService.GetNotesAsync(RmaRecordId);
            communications = await RmaRecordService.GetCommunicationsAsync(RmaRecordId);
            attachments = await RmaRecordService.GetAttachmentsAsync(RmaRecordId);
            completedChecklistCount = checklistItems.Count(item => item.IsCompleted);
        }
        else
        {
            buildRecordSuggestions = [];
            rmaMetrics = null;
            repeatReturnSummary = RmaRepeatReturnSummary.Empty;
            statusHistoryEntries = [];
            checklistItems = [];
            parts = [];
            notes = [];
            communications = [];
            attachments = [];
            completedChecklistCount = 0;
        }

        isLoading = false;
    }

    private async Task LoadBuildRecordSuggestionsAsync()
    {
        if (rmaRecord is null)
        {
            buildRecordSuggestions = [];
            return;
        }

        buildRecordSuggestions = await RmaRecordService.SuggestBuildRecordMatchesAsync(
            new RmaBuildRecordMatchRequest(
                rmaRecord.SerialNumber,
                rmaRecord.ProductCode,
                rmaRecord.ProductName,
                rmaRecord.CustomerName));

        if (rmaRecord.BuildRecordId is not null)
        {
            buildRecordSuggestions = buildRecordSuggestions.Where(suggestion => suggestion.BuildRecordId != rmaRecord.BuildRecordId).ToList();
        }
    }

    private void StartEditingIntake()
    {
        if (rmaRecord is null)
        {
            return;
        }

        intakeModel = new UpdateRmaIntakeRequest
        {
            CustomerName = rmaRecord.CustomerName ?? string.Empty,
            ProductName = rmaRecord.ProductName,
            ProductCode = rmaRecord.ProductCode,
            SerialNumber = rmaRecord.SerialNumber,
            FaultSummary = rmaRecord.FaultSummary,
            InitialFaultDescription = rmaRecord.InitialFaultDescription,
            ContactName = rmaRecord.ContactName,
            ContactEmail = rmaRecord.ContactEmail,
            ContactPhone = rmaRecord.ContactPhone,
            CustomerAddress = rmaRecord.CustomerAddress,
            CustomerReference = rmaRecord.CustomerReference,
            SupportTicketNumber = rmaRecord.SupportTicketNumber,
            SupportTicketUrl = rmaRecord.SupportTicketUrl,
            OriginalOrderNumber = rmaRecord.OriginalOrderNumber,
            OriginalOrderDate = rmaRecord.OriginalOrderDate,
            OriginalInvoiceNumber = rmaRecord.OriginalInvoiceNumber
        };

        intakeErrors.Clear();
        statusMessage = null;
        isEditingIntake = true;
    }

    private async Task SaveIntakeAsync()
    {
        isSavingIntake = true;
        await ExecuteSaveAsync(
            async () => await RmaRecordService.UpdateIntakeAsync(RmaRecordId, intakeModel, await GetCurrentUserNameAsync()),
            intakeErrors,
            "RMA intake details were saved.",
            () => isEditingIntake = false,
            value => value.Succeeded,
            value => value.Errors);
        isSavingIntake = false;
    }

    private void CancelIntakeEdit()
    {
        intakeErrors.Clear();
        isEditingIntake = false;
    }

    private void StartEditingFaultDetails()
    {
        if (rmaRecord is null)
        {
            return;
        }

        faultDetailsModel = new UpdateRmaFaultDetailsRequest
        {
            FaultSummary = rmaRecord.FaultSummary,
            FaultDescription = rmaRecord.FaultDescription,
            ReportedSymptoms = rmaRecord.ReportedSymptoms,
            FaultCategory = rmaRecord.FaultCategory,
            FaultSubcategory = rmaRecord.FaultSubcategory,
            IntermittentFault = rmaRecord.IntermittentFault,
            SafetyConcern = rmaRecord.SafetyConcern,
            DataLossConcern = rmaRecord.DataLossConcern,
            CustomerImpact = rmaRecord.CustomerImpact,
            Reproducible = rmaRecord.Reproducible,
            InitialDiagnosis = rmaRecord.InitialDiagnosis
        };

        faultDetailErrors.Clear();
        statusMessage = null;
        isEditingFaultDetails = true;
    }

    private async Task SaveFaultDetailsAsync()
    {
        isSavingFaultDetails = true;
        await ExecuteSaveAsync(
            async () => await RmaRecordService.UpdateFaultDetailsAsync(RmaRecordId, faultDetailsModel, await GetCurrentUserNameAsync()),
            faultDetailErrors,
            "Fault details were saved.",
            () => isEditingFaultDetails = false,
            value => value.Succeeded,
            value => value.Errors);
        isSavingFaultDetails = false;
    }

    private void CancelFaultDetailsEdit()
    {
        faultDetailErrors.Clear();
        isEditingFaultDetails = false;
    }

    private void StartEditingRepairDetails()
    {
