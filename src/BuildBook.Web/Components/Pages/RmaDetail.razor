    private void OnAttachmentSelected(InputFileChangeEventArgs args)
    {
        attachmentErrors.Clear();
        selectedAttachmentFile = args.File;
        selectedAttachmentName = selectedAttachmentFile?.Name;
        attachmentModel.FileName = selectedAttachmentFile?.Name ?? string.Empty;
        attachmentModel.ContentType = selectedAttachmentFile?.ContentType;
    }

    private async Task SaveAttachmentAsync()
    {
        isSavingAttachment = true;
        attachmentErrors.Clear();

        try
        {
            if (selectedAttachmentFile is null)
            {
                attachmentErrors.Add("Select a file to upload.");
                return;
            }

            await using var stream = selectedAttachmentFile.OpenReadStream(MaxAttachmentSizeBytes);
            var result = await RmaRecordService.SaveAttachmentAsync(RmaRecordId, attachmentModel, stream, await GetCurrentUserNameAsync());

            if (result.Succeeded)
            {
                attachmentModel = new SaveRmaAttachmentRequest();
                selectedAttachmentFile = null;
                selectedAttachmentName = null;
                await LoadRmaAsync();
                statusMessage = "Attachment was uploaded.";
                statusIsError = false;
            }
            else
            {
                attachmentErrors.AddRange(result.Errors);
            }
        }
        catch (IOException)
        {
            attachmentErrors.Add("The selected file could not be read.");
        }
        catch
        {
            attachmentErrors.Add("Check the database connection and try again.");
        }
        finally
        {
            isSavingAttachment = false;
        }
    }

