                <div class="form-field form-field-wide">
                    <label for="edit-rma-shipping-notes">Shipping notes</label>
                    <InputTextArea id="edit-rma-shipping-notes" class="text-input" @bind-Value="shippingModel.ShippingNotes" />
                </div>

                <div class="form-actions">
                    <button type="submit" class="primary-button" disabled="@isSavingShipping">@(isSavingShipping ? "Saving..." : "Save shipping details")</button>
                    <button type="button" class="secondary-button" disabled="@isSavingShipping" @onclick="CancelShippingEdit">Cancel</button>
                </div>
            </EditForm>
        }
        else
        {
            <dl class="summary-list">
