            <div>
                <dt>Checklist progress</dt>
                <dd>@completedChecklistCount / @checklistItems.Count complete</dd>
            </div>
        </dl>

        @SectionErrors(checklistErrors, "Checklist changes could not be saved.")

        <div class="table-scroll detail-section">
            <table class="data-table">
                <thead>
                    <tr>
                        <th scope="col">Item</th>
                        <th scope="col">Status</th>
                        <th scope="col">Completed by</th>
                        <th scope="col">Completed at</th>
                        <th scope="col">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var checklistItem in checklistItems)
                    {
                        <tr>
                            <td>@checklistItem.Text</td>
                            <td>@(checklistItem.IsCompleted ? "Completed" : "Open")</td>
                            <td>@Display(checklistItem.CompletedBy)</td>
                            <td>@Display(checklistItem.CompletedAt)</td>
                            <td>
                                <AuthorizeView Policy="@BuildBookRmaPolicies.EditRmas">
