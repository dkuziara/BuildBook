@page "/admin"
@rendermode InteractiveServer

@using BuildBook.Application.Security
@using BuildBook.Web.Authorization
@using BuildBook.Web.Configuration
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.Extensions.Options

@attribute [Authorize(Policy = BuildBookPolicies.ManageUsers)]

@inject IApplicationUserManagementService ApplicationUserManagementService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IOptions<BuildBookOptions> BuildBookOptions

<PageTitle>Users &amp; Roles</PageTitle>

@if (isLoading)
{
    <section class="placeholder-panel" aria-live="polite">
        <p>Loading users and roles...</p>
    </section>
}
else
{
    <section class="page-heading">
        <div class="page-heading-copy">
            <p class="eyebrow">Admin</p>
            <h1>Users &amp; Roles</h1>
            <p>Windows Authentication identifies each person. BuildBook roles decide what they can view, edit, reveal and administer.</p>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <div class="status-message @(statusIsError ? "error" : "success")" role="alert">
            <p>@statusMessage</p>
        </div>
    }

    <section class="detail-panel" aria-labelledby="bootstrap-administrators-heading">
        <div class="detail-panel-header">
            <div>
                <h2 id="bootstrap-administrators-heading">Bootstrap administrators</h2>
                <p>These usernames always keep Administrator access while they remain configured in app settings.</p>
            </div>
        </div>

        @if (bootstrapAdministrators.Count == 0)
        {
            <p class="empty-state">No bootstrap administrators are configured.</p>
        }
        else
        {
            <ul class="recent-record-list">
                @foreach (var bootstrapAdministrator in bootstrapAdministrators)
                {
                    <li class="user-name-chip">@bootstrapAdministrator</li>
                }
            </ul>
        }
    </section>

    <section class="form-panel detail-section" aria-labelledby="add-user-heading">
        <h2 id="add-user-heading">Add Windows user</h2>
        <p class="form-introduction">Add the Windows username, then assign the BuildBook roles they need.</p>

        <div class="form-grid">
            <div class="form-field">
                <label for="new-user-name">Windows username</label>
                <InputText id="new-user-name" class="text-input" @bind-Value="newUser.WindowsUserName" />
            </div>
            <div class="form-field">
                <label for="new-display-name">Display name</label>
                <InputText id="new-display-name" class="text-input" @bind-Value="newUser.DisplayName" />
            </div>
            <div class="form-field">
                <label for="new-email-address">Email address</label>
                <InputText id="new-email-address" class="text-input" @bind-Value="newUser.EmailAddress" />
            </div>
        </div>

        <div class="form-actions">
            <button type="button" class="primary-button" disabled="@isSavingNewUser" @onclick="AddUserAsync">Add user</button>
        </div>
    </section>

    <section class="detail-panel detail-section" aria-labelledby="managed-users-heading">
        <div class="detail-panel-header">
            <div>
                <h2 id="managed-users-heading">Managed users</h2>
                <p>Update contact details, activation status and role assignments. BuildBook never stores separate passwords.</p>
            </div>
        </div>

        @if (editableUsers.Count == 0)
        {
            <p class="empty-state">No Windows users have been added yet.</p>
        }
        else
        {
            <div class="table-scroll">
                <table class="data-table managed-users-table">
                    <thead>
                        <tr>
                            <th scope="col">Windows username</th>
                            <th scope="col">Display name</th>
                            <th scope="col">Email address</th>
                            <th scope="col">Status</th>
                            <th scope="col">Roles</th>
                            <th scope="col" class="table-action-column">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in editableUsers)
                        {
                            <tr>
                                <td>
                                    @user.WindowsUserName
                                    @if (user.IsBootstrapAdministrator)
                                    {
                                        <div class="table-meta-text">Bootstrap administrator</div>
                                    }
                                </td>
                                <td>@DisplayValue(user.DisplayName)</td>
                                <td>@DisplayValue(user.EmailAddress)</td>
                                <td>@(user.IsActive ? "Active" : "Inactive")</td>
                                <td>@FormatRoles(user)</td>
                                <td class="table-action-column">
                                    <button type="button" class="subtle-button" @onclick="() => EditUser(user)">Edit user</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (editingUser is not null)
            {
                <section class="form-panel detail-section" aria-labelledby="edit-user-heading">
                    <h3 id="edit-user-heading">Edit user</h3>
                    <p class="form-introduction">Update contact details, active status and assigned BuildBook roles for @editingUser.WindowsUserName.</p>

                    @if (editingUser.Errors.Count > 0)
                    {
                        <div class="status-message error" role="alert">
                            <ul>
                                @foreach (var error in editingUser.Errors)
                                {
                                    <li>@error</li>
                                }
                            </ul>
                        </div>
                    }

                    <div class="form-grid">
                        <div class="form-field">
                            <label for="@($"display-name-{editingUser.Id}")">Display name</label>
                            <InputText id="@($"display-name-{editingUser.Id}")" class="text-input" @bind-Value="editingUser.DisplayName" />
                        </div>
                        <div class="form-field">
                            <label for="@($"email-address-{editingUser.Id}")">Email address</label>
                            <InputText id="@($"email-address-{editingUser.Id}")" class="text-input" @bind-Value="editingUser.EmailAddress" />
                        </div>
                    </div>

                    <div class="role-assignment-section">
                        <label class="user-active-toggle" for="is-active-@editingUser.Id">
                            <input id="is-active-@editingUser.Id"
                                   type="checkbox"
                                   checked="@editingUser.IsActive"
                                   disabled="@editingUser.IsBootstrapAdministrator"
                                   @onchange="args => editingUser.IsActive = args.Value is true" />
                            Active user
                        </label>

                        <div class="role-checkbox-grid">
                            @foreach (var roleName in BuildBookRoles.All)
                            {
                                <label class="role-checkbox" for="@($"role-{editingUser.Id}-{SanitizeRoleName(roleName)}")">
                                    <input id="@($"role-{editingUser.Id}-{SanitizeRoleName(roleName)}")"
                                           type="checkbox"
                                           checked="@editingUser.HasRole(roleName)"
                                           disabled="@IsRoleLocked(editingUser, roleName)"
                                           @onchange="args => editingUser.SetRole(roleName, args.Value is true)" />
                                    @roleName
                                </label>
                            }
                        </div>
                    </div>

                    <div class="form-actions">
                        <button type="button" class="secondary-button" disabled="@editingUser.IsSaving" @onclick="() => SaveUserAsync(editingUser)">Save user</button>
                        <button type="button" class="secondary-button" disabled="@editingUser.IsSaving" @onclick="() => CancelEdit(editingUser)">Cancel</button>
                    </div>
                </section>
            }
        }
    </section>

    <section class="detail-panel detail-section" aria-labelledby="admin-import-heading">
        <div class="detail-panel-header">
            <div>
                <h2 id="admin-import-heading">Spreadsheet Import</h2>
                <p>Upload the existing spreadsheet to begin the import workflow.</p>
            </div>
        </div>

        <div class="detail-actions">
            <a class="primary-button" href="/imports/upload">Open Upload Screen</a>
            <a class="action-link" href="/imports">View Import History</a>
        </div>
    </section>

    <section class="detail-panel detail-section" aria-labelledby="admin-support-contracts-heading">
        <div class="detail-panel-header">
            <div>
                <h2 id="admin-support-contracts-heading">Customer Support Contracts</h2>
                <p>Manage the editable support contract levels used by the Customers module.</p>
            </div>
        </div>

        <div class="detail-actions">
            <a class="primary-button" href="/admin/support-contract-levels">Open Support Contract Levels</a>
            <a class="action-link" href="/customers">Open Customers</a>
        </div>
    </section>

    <section class="detail-panel detail-section" aria-labelledby="admin-system-settings-heading">
        <div class="detail-panel-header">
            <div>
                <h2 id="admin-system-settings-heading">System Settings</h2>
                <p>Manage shared support ticket settings such as the external support site URL template.</p>
            </div>
        </div>

        <div class="detail-actions">
            <a class="primary-button" href="/admin/system-settings">Open System Settings</a>
        </div>
    </section>
}

@code {
    private readonly AddUserModel newUser = new();
    private List<EditableUserModel> editableUsers = [];
    private List<string> bootstrapAdministrators = [];
    private string currentUserName = "Unknown";
    private string? statusMessage;
    private bool statusIsError;
    private bool isLoading = true;
    private bool isSavingNewUser;

    protected override async Task OnInitializedAsync()
    {
        var authenticationState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        currentUserName = authenticationState.User.Identity?.Name ?? "Unknown";
        bootstrapAdministrators = BuildBookOptions.Value.Authorization.BootstrapAdministrators
            .Where(userName => !string.IsNullOrWhiteSpace(userName))
            .Select(userName => userName.Trim())
            .OrderBy(userName => userName, StringComparer.Ordinal)
            .ToList();

        await ReloadUsersAsync();
        isLoading = false;
    }

    private async Task AddUserAsync()
    {
        statusMessage = null;
        statusIsError = false;
        isSavingNewUser = true;

        var result = await ApplicationUserManagementService.CreateAsync(
            new CreateApplicationUserRequest(
                newUser.WindowsUserName ?? string.Empty,
                newUser.DisplayName,
                newUser.EmailAddress),
            currentUserName);

        isSavingNewUser = false;

        if (!result.Succeeded)
        {
            statusMessage = result.Errors.FirstOrDefault() ?? "The Windows user could not be added.";
            statusIsError = true;
            return;
        }

        newUser.WindowsUserName = string.Empty;
        newUser.DisplayName = null;
        newUser.EmailAddress = null;
        statusMessage = "Windows user added. Use Edit user below to assign BuildBook roles.";
        await ReloadUsersAsync();
    }

    private async Task SaveUserAsync(EditableUserModel user)
    {
        user.IsSaving = true;
        user.Errors.Clear();
        statusMessage = null;
        statusIsError = false;

        var result = await ApplicationUserManagementService.UpdateAsync(
            new UpdateApplicationUserRequest(
                user.Id,
                user.DisplayName,
                user.EmailAddress,
                user.IsActive,
                user.SelectedRoles.ToArray()),
            currentUserName);

        user.IsSaving = false;

        if (!result.Succeeded)
        {
            user.Errors.AddRange(result.Errors);
            statusMessage = "The user changes could not be saved.";
            statusIsError = true;
            return;
        }

        statusMessage = $"Saved access changes for {user.WindowsUserName}.";
        user.IsEditing = false;
        await ReloadUsersAsync();
    }

    private async Task ReloadUsersAsync()
    {
        editableUsers = (await ApplicationUserManagementService.ListAsync())
            .Select(user => new EditableUserModel(user))
            .ToList();
    }

    private void EditUser(EditableUserModel user)
    {
        foreach (var editableUser in editableUsers)
        {
            editableUser.IsEditing = false;
            editableUser.Errors.Clear();
        }

        user.IsEditing = true;
    }

    private void CancelEdit(EditableUserModel user)
    {
        user.IsEditing = false;
        user.Errors.Clear();
    }

    private EditableUserModel? editingUser => editableUsers.FirstOrDefault(user => user.IsEditing);

    private static bool IsRoleLocked(EditableUserModel user, string roleName)
    {
        return user.IsBootstrapAdministrator && roleName == BuildBookRoles.Administrator;
    }

    private static string SanitizeRoleName(string roleName)
    {
        return roleName.Replace(" ", "-", StringComparison.Ordinal).ToLowerInvariant();
    }

    private static string DisplayValue(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "Not set" : value;
    }

    private static string FormatRoles(EditableUserModel user)
    {
        return user.SelectedRoles.Count == 0
            ? "No BuildBook roles assigned"
            : string.Join(", ", user.SelectedRoles.OrderBy(role => role, StringComparer.Ordinal));
    }

    private sealed class AddUserModel
    {
        public string? WindowsUserName { get; set; }

        public string? DisplayName { get; set; }

        public string? EmailAddress { get; set; }
    }

    private sealed class EditableUserModel
    {
        private readonly HashSet<string> selectedRoles;

        public EditableUserModel(ApplicationUserSummary user)
        {
            Id = user.Id;
            WindowsUserName = user.WindowsUserName;
            DisplayName = user.DisplayName;
            EmailAddress = user.EmailAddress;
            IsActive = user.IsActive;
            IsBootstrapAdministrator = user.IsBootstrapAdministrator;
            selectedRoles = user.AssignedRoles.ToHashSet(StringComparer.Ordinal);
        }

        public int Id { get; }

        public string WindowsUserName { get; }

        public string? DisplayName { get; set; }

        public string? EmailAddress { get; set; }

        public bool IsActive { get; set; }

        public bool IsBootstrapAdministrator { get; }

        public bool IsEditing { get; set; }

        public bool IsSaving { get; set; }

        public List<string> Errors { get; } = [];

        public IReadOnlyCollection<string> SelectedRoles => selectedRoles;

        public bool HasRole(string roleName)
        {
            return selectedRoles.Contains(roleName);
        }

        public void SetRole(string roleName, bool isSelected)
        {
            if (isSelected)
            {
                selectedRoles.Add(roleName);
                return;
            }

            selectedRoles.Remove(roleName);
        }
    }
}
