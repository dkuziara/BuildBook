@page "/admin"

@attribute [Authorize(Policy = BuildBookPolicies.ManageUsers)]

<PageTitle>Admin</PageTitle>

<section class="page-heading">
    <p class="eyebrow">Admin</p>
    <h1>Admin</h1>
    <p>Internal administration tools will appear here in later backlog items.</p>
</section>

<section class="placeholder-panel" aria-labelledby="admin-placeholder">
    <h2 id="admin-placeholder">Placeholder</h2>
    <p>This page is reserved for internal system settings, access management and import administration.</p>
</section>

<section class="detail-panel" aria-labelledby="admin-import-heading">
    <div class="detail-panel-header">
        <div>
            <h2 id="admin-import-heading">Spreadsheet Import</h2>
            <p>Upload the existing spreadsheet to begin the import workflow.</p>
        </div>
    </div>

    <div class="detail-actions">
        <a class="primary-button" href="/imports/upload">Open Upload Screen</a>
        <a class="secondary-link" href="/imports">View Import History</a>
    </div>
</section>
