@page "/products"
@rendermode InteractiveServer

@using BuildBook.Application.Products

@attribute [Authorize(Policy = BuildBookPolicies.ViewBuildRecords)]

@inject IProductService ProductService
@inject IOptions<BuildBookOptions> BuildBookOptionsAccessor

<PageTitle>Products</PageTitle>

<section class="page-heading">
    <div class="page-heading-copy">
        <p class="eyebrow">Products</p>
        <h1>Products</h1>
        <p>Maintain shared product codes, descriptions and notes in one place for BuildBook users.</p>
    </div>
    <div class="page-actions">
        <AuthorizeView Policy="@BuildBookPolicies.EditBuildRecords">
            <Authorized>
                <a class="primary-button" href="/products/new">Add product</a>
            </Authorized>
        </AuthorizeView>
    </div>
</section>

<section class="table-panel compact-table-panel" aria-labelledby="products-table-heading">
    <div class="table-panel-heading register-toolbar-heading">
        <div>
            <h2 id="products-table-heading">Product records</h2>
            <p>@RecordsSummary</p>
        </div>
        <div class="form-actions register-toolbar-actions">
            <button type="button" class="secondary-button" aria-controls="products-filters-panel" aria-expanded="@showFilters.ToString().ToLowerInvariant()" @onclick="ToggleFilters">
                @(showFilters ? "Hide filters" : "Show filters")
            </button>
        </div>
    </div>

    @if (showFilters)
    {
        <div id="products-filters-panel" class="register-filters-block" aria-labelledby="products-filters-heading">
            <div class="compact-panel-title">
                <h3 id="products-filters-heading">Filters</h3>
                <p>Search product codes, descriptions and notes without opening every product record.</p>
            </div>

            <EditForm Model="filterModel" OnValidSubmit="ApplyFiltersAsync" FormName="products-filters">
                <div class="filter-grid">
                    <div class="form-field">
                        <label for="products-search">Search</label>
                        <InputText id="products-search" class="text-input" @bind-Value="filterModel.Search" />
                    </div>
                </div>

                <div class="form-actions register-actions">
                    <button type="submit" class="secondary-button" disabled="@isLoading">Apply filters</button>
                    <button type="button" class="secondary-button" disabled="@(!canClearFilters)" @onclick="ClearFiltersAsync">Clear filters</button>
                </div>
            </EditForm>
        </div>
    }

    @if (products is null)
    {
        <div class="placeholder-panel table-panel-placeholder" aria-live="polite">
            <p>Loading products...</p>
        </div>
    }
    else if (products.Count == 0)
    {
        <div class="placeholder-panel table-panel-placeholder" aria-labelledby="empty-products-heading">
            <h3 id="empty-products-heading">No products found</h3>
            <p>@(hasActiveFilters ? "No product records match the current filters." : "Add the first product record to start standardising product details.")</p>
        </div>
    }
    else
    {
        <div class="table-scroll">
            <table class="data-table">
                <thead>
                    <tr>
                        <th scope="col"><button type="button" class="sort-button" @onclick="@(() => SortByAsync(ProductSortColumn.ProductCode))">Product code @SortIndicator(ProductSortColumn.ProductCode)</button></th>
                        <th scope="col"><button type="button" class="sort-button" @onclick="@(() => SortByAsync(ProductSortColumn.Description))">Description @SortIndicator(ProductSortColumn.Description)</button></th>
                        <th scope="col">Notes</th>
                        <th scope="col"><button type="button" class="sort-button" @onclick="@(() => SortByAsync(ProductSortColumn.LastUpdated))">Last updated @SortIndicator(ProductSortColumn.LastUpdated)</button></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var product in products)
                    {
                        <tr>
                            <td><a class="table-link" href="@($"/products/{product.Id}")">@product.ProductCode</a></td>
                            <td>@Display(product.Description)</td>
                            <td>@Display(product.Notes)</td>
                            <td>@product.LastUpdatedAt.ToLocalTime().ToString("d MMM yyyy HH:mm")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <ListPager AriaLabel="Products pagination"
                   ItemLabel="records"
                   TotalCount="@productsPage!.TotalCount"
                   PageNumber="@productsPage!.PageNumber"
                   TotalPages="@productsPage!.TotalPages"
                   PageSize="@productsPage!.PageSize"
                   Disabled="@isLoading"
                   PageNumberChanged="OnPageNumberChangedAsync"
                   PageSizeChanged="OnPageSizeChangedAsync" />
    }
</section>

@code {
    private PagedResult<ProductListItem>? productsPage;
    private ProductListFilter filterModel = new();
    private bool hasActiveFilters;
    private bool isLoading;
    private bool showFilters;
    private int pageNumber = 1;
    private int pageSize = 10;
    private IReadOnlyList<ProductListItem>? products => productsPage?.Items;
    private bool canClearFilters => !isLoading && hasActiveFilters;
    private string RecordsSummary => productsPage is null
        ? "Loading products..."
        : $"{productsPage.TotalCount} {(hasActiveFilters ? "matching" : "available")} records";

    protected override async Task OnInitializedAsync()
    {
        pageSize = NormalizePageSize(BuildBookOptionsAccessor.Value.DefaultPageSize);
        await LoadProductsAsync();
    }

    private async Task ApplyFiltersAsync()
    {
        pageNumber = 1;
        await LoadProductsAsync(filterModel);
    }

    private async Task ClearFiltersAsync()
    {
        filterModel = new ProductListFilter();
        pageNumber = 1;
        await LoadProductsAsync();
    }

    private async Task SortByAsync(ProductSortColumn column)
    {
        if (filterModel.SortBy == column)
        {
            filterModel.SortDescending = !filterModel.SortDescending;
        }
        else
        {
            filterModel.SortBy = column;
            filterModel.SortDescending = column == ProductSortColumn.LastUpdated;
        }

        pageNumber = 1;
        await LoadProductsAsync(filterModel);
    }

    private async Task LoadProductsAsync(ProductListFilter? filter = null)
    {
        isLoading = true;
        var activeFilter = filter ?? new ProductListFilter();
        hasActiveFilters = activeFilter.HasAnyFilter();
        showFilters = hasActiveFilters || showFilters;
        productsPage = await ProductService.SearchPageAsync(activeFilter, pageNumber, pageSize);
        pageNumber = productsPage.PageNumber;
        isLoading = false;
    }

    private async Task OnPageNumberChangedAsync(int newPageNumber)
    {
        pageNumber = newPageNumber;
        await LoadProductsAsync(filterModel);
    }

    private async Task OnPageSizeChangedAsync(int newPageSize)
    {
        pageSize = NormalizePageSize(newPageSize);
        pageNumber = 1;
        await LoadProductsAsync(filterModel);
    }

    private void ToggleFilters()
    {
        showFilters = !showFilters;
    }

    private string SortIndicator(ProductSortColumn column)
    {
        if (filterModel.SortBy != column)
        {
            return string.Empty;
        }

        return filterModel.SortDescending ? "v" : "^";
    }

    private static string Display(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "Not recorded" : value;
    }

    private static int NormalizePageSize(int requestedPageSize)
    {
        return requestedPageSize switch
        {
            <= 10 => 10,
            <= 50 => 50,
            _ => 100
        };
    }
}
