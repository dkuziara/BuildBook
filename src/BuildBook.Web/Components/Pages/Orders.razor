@page "/orders"
@rendermode InteractiveServer

@using BuildBook.Application.Orders
@using BuildBook.Application.Security

@attribute [Authorize(Policy = BuildBookOrderPolicies.ViewOrders)]

<PageTitle>Orders</PageTitle>

<section class="page-heading">
    <div class="page-heading-copy">
        <p class="eyebrow">Orders</p>
        <h1>Orders</h1>
        <p>The Orders module foundation is in place, and Planner import is now the first operational step for bringing historic order workflow into BuildBook.</p>
    </div>
</section>

<section class="detail-panel" aria-labelledby="orders-foundation-heading">
    <div class="detail-panel-header">
        <div>
            <h2 id="orders-foundation-heading">Foundation ready</h2>
            <p>Use the Planner import flow to bring existing order tasks into the new Orders data model while the register and detail screens are still being added.</p>
        </div>
        <AuthorizeView Policy="@BuildBookOrderPolicies.ImportOrders">
            <Authorized>
                <a class="primary-button" href="/orders/import">Import Planner Export</a>
            </Authorized>
        </AuthorizeView>
    </div>

    <div class="detail-grid">
        <div>
            <h3>Default workflow statuses</h3>
            <ul class="recent-record-list">
                @foreach (var status in BuildBookOrderStatuses.DefaultWorkflow)
                {
                    <li>@status</li>
                }
            </ul>
        </div>
        <div>
            <h3>Planned next slices</h3>
            <ul class="recent-record-list">
                <li>Orders register and dashboard</li>
                <li>Order detail and manual create/edit</li>
                <li>Orders register and detail screens</li>
            </ul>
        </div>
    </div>
</section>
