    private void StartEditingSecret(SecretType secretType)
    {
        if (!canManageSensitiveData)
        {
            return;
        }

        secretSaveErrors.Clear();
        saveSucceeded = false;
        saveMessage = string.Empty;
        saveWarnings.Clear();
        editingSecretType = secretType;
        secretEditModel = new SecretEditModel();
    }

    private void CancelSecretEdit()
    {
        secretSaveErrors.Clear();
        editingSecretType = null;
        secretEditModel = new SecretEditModel();
    }

    private async Task SaveSecretAsync()
    {
        if (buildRecord is null || editingSecretType is not { } secretType || !savingSecretTypes.Add(secretType))
        {
            return;
        }

        saveSucceeded = false;
        saveMessage = string.Empty;
        saveWarnings.Clear();
        secretSaveErrors.Clear();

        try
        {
            if (!string.Equals(secretEditModel.NewValue, secretEditModel.ConfirmValue, StringComparison.Ordinal))
            {
                secretSaveErrors.Add("The new value and confirmation value must match.");
                return;
            }

            var authenticationState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authenticationState.User;
            var userName = user.Identity?.Name ?? "Unknown";

            await BuildBookPermissionService.EnsureAuthorizedAsync(
                user,
                BuildBookPolicies.ManageSensitiveData);

            var result = IsSecretSet(secretType)
                ? await BuildRecordSecretService.UpdateAsync(BuildRecordId, secretType, secretEditModel.NewValue ?? string.Empty, userName)
                : await BuildRecordSecretService.SaveAsync(BuildRecordId, secretType, secretEditModel.NewValue ?? string.Empty, userName);

            if (result.Succeeded)
            {
                buildRecord = await BuildRecordDetailReader.GetByIdAsync(BuildRecordId);
                auditHistory = await BuildRecordAuditHistoryReader.ListByBuildRecordIdAsync(BuildRecordId);
                revealedSecrets.Remove(secretType);
                secretRevealErrors.Remove(secretType);
                saveSucceeded = true;
                saveMessage = $"{GetSecretLabel(secretType)} was saved.";
                editingSecretType = null;
                secretEditModel = new SecretEditModel();
            }
            else
            {
                secretSaveErrors.AddRange(result.Errors);
            }
        }
        catch (UnauthorizedAccessException)
        {
            secretSaveErrors.Add("You are not authorised to set or update this value.");
        }
        catch
        {
            secretSaveErrors.Add("This value could not be saved. Try again.");
        }
        finally
        {
            savingSecretTypes.Remove(secretType);
        }
    }

    private async Task RevealSecretAsync(SecretType secretType)
    {
        if (buildRecord is null || !revealingSecretTypes.Add(secretType))
        {
            return;
        }

        secretRevealErrors.Remove(secretType);

        try
        {
            var authenticationState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authenticationState.User;
            var userName = user.Identity?.Name ?? "Unknown";

            await BuildBookPermissionService.EnsureAuthorizedAsync(
                user,
                BuildBookPolicies.RevealSensitiveData);

            var result = await BuildRecordSecretService.RetrieveAsync(BuildRecordId, secretType, userName);

            if (result.Succeeded)
            {
                revealedSecrets[secretType] = result.SecretValue;
                auditHistory = await BuildRecordAuditHistoryReader.ListByBuildRecordIdAsync(BuildRecordId);
            }
            else
            {
                secretRevealErrors[secretType] = string.Join(" ", result.Errors);
            }
        }
        catch (UnauthorizedAccessException)
        {
            secretRevealErrors[secretType] = "You are not authorised to reveal this value.";
        }
        catch
        {
            secretRevealErrors[secretType] = "This value could not be revealed. Try again.";
        }
        finally
        {
            revealingSecretTypes.Remove(secretType);
        }
    }

    private bool IsSecretRevealed(SecretType secretType)
    {
        return revealedSecrets.ContainsKey(secretType);
    }

    private void HideSecret(SecretType secretType)
    {
        revealedSecrets.Remove(secretType);
        secretRevealErrors.Remove(secretType);
    }

    private bool IsSecretSet(SecretType secretType)
    {
        return buildRecord?.SecretTypesSet.Contains(secretType) == true;
    }

    private bool IsRevealingSecret(SecretType secretType)
    {
        return revealingSecretTypes.Contains(secretType);
    }

    private bool IsSavingSecret(SecretType secretType)
    {
        return savingSecretTypes.Contains(secretType);
    }

    private bool IsEditingSecret(SecretType secretType)
    {
        return editingSecretType == secretType;
    }

    private string? GetSecretRevealError(SecretType secretType)
    {
        return secretRevealErrors.TryGetValue(secretType, out var error) ? error : null;
    }

    private string DisplaySecret(SecretType secretType)
    {
        if (!IsSecretSet(secretType))
        {
            return "Not set";
        }

        return revealedSecrets.TryGetValue(secretType, out var secretValue)
            ? Display(secretValue)
            : MaskedSecretDisplay;
    }

    private string SecretValueCssClass(SecretType secretType)
    {
        if (!IsSecretSet(secretType))
        {
            return string.Empty;
        }

        return IsSecretRevealed(secretType) ? "secret-value" : "secret-mask";
    }

    private static string GetSecretLabel(SecretType secretType)
    {
        return secretType switch
        {
            SecretType.RadSightUserPassword => "RadSight user password",
            SecretType.WindowsAdminPassword => "Windows admin password",
            SecretType.KioskPassword => "Kiosk password",
            SecretType.WifiPassword => "Wi-Fi password",
            SecretType.RouterPassword => "Router password",
            SecretType.BitLockerRecoveryKey => "BitLocker recovery key",
            _ => secretType.ToString()
        };
    }

    private string SecretStatus(SecretType secretType)
    {
        return IsSecretSet(secretType) ? "Set" : "Not set";
    }

    private static string SanitizeSecretType(SecretType secretType)
    {
        return secretType.ToString().ToLowerInvariant();
    }

