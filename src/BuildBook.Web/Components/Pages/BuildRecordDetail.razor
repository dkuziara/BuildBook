    private async Task SaveCustomerShippingAsync()
    {
        isSavingCustomerShipping = true;
        saveSucceeded = false;
        saveMessage = string.Empty;
        customerShippingErrors.Clear();

        try
        {
            var authenticationState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var userName = authenticationState.User.Identity?.Name ?? "Unknown";
            var result = await CustomerShippingUpdater.UpdateAsync(BuildRecordId, customerShippingModel, userName);

            if (result.Succeeded)
            {
                buildRecord = await BuildRecordDetailReader.GetByIdAsync(BuildRecordId);
                isEditingCustomerShipping = false;
                saveSucceeded = true;
                saveMessage = "Customer and shipping details were saved.";
            }
            else
            {
                customerShippingErrors.AddRange(result.Errors);
            }
        }
        catch
        {
            customerShippingErrors.Add("Check the database connection and try again.");
        }
        finally
        {
            isSavingCustomerShipping = false;
        }
    }

    private void CancelCustomerShippingEdit()
    {
        customerShippingErrors.Clear();
        isEditingCustomerShipping = false;
    }

