    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        buildRecord = await BuildRecordDetailReader.GetByIdAsync(BuildRecordId);
        if (buildRecord is not null)
        {
            var authenticationState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authenticationState.User;
            var userName = user.Identity?.Name;
            RecentlyViewedBuildRecordTracker.TrackView(buildRecord.Id, userName);
            auditHistory = await BuildRecordAuditHistoryReader.ListByBuildRecordIdAsync(BuildRecordId);
            linkedRmas = await RmaRecordService.GetBuildRecordHistoryAsync(BuildRecordId);
            canRevealSensitiveData = await BuildBookPermissionService.IsAuthorizedAsync(
                user,
                BuildBookPolicies.RevealSensitiveData);
            canManageSensitiveData = await BuildBookPermissionService.IsAuthorizedAsync(
                user,
                BuildBookPolicies.ManageSensitiveData);
        }
        else
        {
            auditHistory = [];
            linkedRmas = [];
            canRevealSensitiveData = false;
            canManageSensitiveData = false;
        }

        customerOptions = await CustomerOptionsReader.ListActiveAsync();
        saveWarnings.Clear();
        isEditingProductDetails = false;
        isEditingBuildDetails = false;
        isEditingCustomerShipping = false;
        isEditingHardwareDetails = false;
        isEditingSoftwareFirmware = false;
        isEditingNetworkDetails = false;
        isEditingNotes = false;
        productDetailErrors.Clear();
        buildDetailErrors.Clear();
        customerShippingErrors.Clear();
        hardwareDetailErrors.Clear();
        softwareFirmwareErrors.Clear();
        networkDetailErrors.Clear();
        notesErrors.Clear();
        revealedSecrets.Clear();
        secretRevealErrors.Clear();
        revealingSecretTypes.Clear();
        savingSecretTypes.Clear();
        secretSaveErrors.Clear();
        editingSecretType = null;
        secretEditModel = new();
        isLoading = false;
    }

    private void StartEditingProductDetails()
    {
        if (buildRecord is null)
        {
            return;
        }

        productDetailsModel = new UpdateProductDetailsRequest
