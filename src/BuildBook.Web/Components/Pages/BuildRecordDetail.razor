@page "/build-records/{BuildRecordId:int}"
@rendermode InteractiveServer

@using BuildBook.Application.Rmas
@using BuildBook.Domain.Rmas

@attribute [Authorize(Policy = BuildBookPolicies.ViewBuildRecords)]

@inject IBuildRecordDetailReader BuildRecordDetailReader
@inject IBuildRecordAuditHistoryReader BuildRecordAuditHistoryReader
@inject IProductDetailsUpdater ProductDetailsUpdater
@inject IBuildDetailsUpdater BuildDetailsUpdater
@inject ICustomerOptionsReader CustomerOptionsReader
@inject ICustomerShippingUpdater CustomerShippingUpdater
@inject IHardwareDetailsUpdater HardwareDetailsUpdater
@inject ISoftwareFirmwareUpdater SoftwareFirmwareUpdater
@inject INetworkNotesUpdater NetworkNotesUpdater
@inject IBuildRecordSecretService BuildRecordSecretService
@inject IRmaRecordService RmaRecordService
@inject IRecentlyViewedBuildRecordTracker RecentlyViewedBuildRecordTracker
@inject BuildBook.Web.Authorization.IBuildBookPermissionService BuildBookPermissionService
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>@PageTitleText</PageTitle>

@if (isLoading)
{
    <section class="placeholder-panel" aria-live="polite">
        <p>Loading Build Record...</p>
    </section>
}
else if (buildRecord is null)
{
    <section class="page-heading">
        <div class="page-heading-copy">
            <p class="eyebrow">Build Records</p>
            <h1>Build Record not found.</h1>
            <p>The record may not exist, or it may no longer be active.</p>
        </div>
    </section>

    <p>
        <a class="secondary-link" href="/build-register">Back to Build Register</a>
    </p>
}
else
{
    <section class="page-heading">
        <div class="page-heading-copy">
            <p class="eyebrow">Build Record</p>
            <h1>@buildRecord.ProductName</h1>
            <p>@buildRecord.ProductCode - Serial @buildRecord.SerialNumber</p>
        </div>
        <div class="page-actions">
            <a class="secondary-button" href="/build-register">Back to Build Register</a>
        </div>
    </section>

    <nav class="section-chip-nav" aria-label="Build Record detail sections">
        <a class="section-chip" href="@RecordSectionLink("build-record-summary")">Summary</a>
        <a class="section-chip" href="@RecordSectionLink("product-details")">Product</a>
        <a class="section-chip" href="@RecordSectionLink("build-details")">Build</a>
        <a class="section-chip" href="@RecordSectionLink("customer-shipping")">Customer</a>
        <a class="section-chip" href="@RecordSectionLink("hardware-details")">Hardware</a>
        <a class="section-chip" href="@RecordSectionLink("software-firmware")">Software</a>
        <a class="section-chip" href="@RecordSectionLink("network")">Network</a>
        <a class="section-chip" href="@RecordSectionLink("credentials-recovery")">Credentials</a>
        <a class="section-chip" href="@RecordSectionLink("notes")">Notes</a>
        <a class="section-chip" href="@RecordSectionLink("linked-orders")">Orders</a>
        <a class="section-chip" href="@RecordSectionLink("linked-rmas")">RMAs</a>
        <a class="section-chip" href="@RecordSectionLink("history")">History</a>
    </nav>

    @if (saveSucceeded)
    {
        <div class="status-message success" role="status">
            @saveMessage
        </div>
    }

    @if (saveWarnings.Count > 0)
    {
        <div class="status-message warning" role="status">
            <p>Saved with warnings.</p>
            <ul>
                @foreach (var warning in saveWarnings)
                {
                    <li>@warning</li>
                }
            </ul>
        </div>
    }

    <section id="build-record-summary" class="detail-panel" aria-labelledby="build-record-summary-heading">
        <div class="detail-panel-header">
            <div>
                <h2 id="build-record-summary-heading">Summary</h2>
                <p>Important information for this device.</p>
            </div>
        </div>

        <dl class="summary-list">
            <div>
                <dt>Product code</dt>
                <dd>@buildRecord.ProductCode</dd>
            </div>
            <div>
                <dt>Serial number</dt>
                <dd>@buildRecord.SerialNumber</dd>
            </div>
            <div>
                <dt>Classification</dt>
                <dd>@Display(buildRecord.ProductClassification)</dd>
            </div>
            <div>
                <dt>Status</dt>
                <dd>@Display(buildRecord.InternalStatus)</dd>
            </div>
            <div>
                <dt>Customer</dt>
                <dd>@Display(buildRecord.CustomerName)</dd>
            </div>
            <div>
                <dt>Machine name</dt>
                <dd>@Display(buildRecord.MachineName)</dd>
            </div>
            <div>
                <dt>RadSight version</dt>
                <dd>@Display(buildRecord.RadSightVersion)</dd>
            </div>
            <div>
                <dt>Windows version</dt>
                <dd>@Display(buildRecord.WindowsVersion)</dd>
            </div>
            <div>
                <dt>Date shipped</dt>
                <dd>@Display(buildRecord.DateShipped)</dd>
            </div>
            <div>
                <dt>Last updated</dt>
                <dd>@buildRecord.LastUpdatedAt.ToLocalTime().ToString("d MMM yyyy HH:mm")</dd>
            </div>
        </dl>
    </section>

    <section id="product-details" class="detail-panel detail-section" aria-labelledby="product-details-heading">
        <div class="detail-panel-header">
            <div>
                <h2 id="product-details-heading">Product Details</h2>
                <p>Product identity, classification, serial number and internal status.</p>
            </div>
            <AuthorizeView Policy="@BuildBookPolicies.EditBuildRecords">
                <Authorized>
                    @if (!isEditingProductDetails)
                    {
                        <button type="button" class="secondary-button" @onclick="StartEditingProductDetails">Edit</button>
                    }
                </Authorized>
            </AuthorizeView>
        </div>

        @if (isEditingProductDetails)
        {
            @if (productDetailErrors.Count > 0)
            {
                <div class="status-message error" role="alert">
                    <p>Product details could not be saved.</p>
                    <ul>
                        @foreach (var error in productDetailErrors)
                        {
                            <li>@error</li>
                        }
                    </ul>
                </div>
            }

            <EditForm Model="productDetailsModel" OnValidSubmit="SaveProductDetailsAsync" FormName="edit-product-details">
                <div class="form-grid">
                    <div class="form-field">
                        <label for="edit-product-code">Product code</label>
                        <InputText id="edit-product-code" class="text-input" @bind-Value="productDetailsModel.ProductCode" />
                    </div>

                    <div class="form-field">
                        <label for="edit-product-name">Product name</label>
                        <InputText id="edit-product-name" class="text-input" @bind-Value="productDetailsModel.ProductName" />
                    </div>

                    <div class="form-field">
                        <label for="edit-product-classification">Classification</label>
                        <InputText id="edit-product-classification" class="text-input" @bind-Value="productDetailsModel.ProductClassification" />
                    </div>

                    <div class="form-field">
                        <label for="edit-serial-number">Serial number</label>
                        <InputText id="edit-serial-number" class="text-input" @bind-Value="productDetailsModel.SerialNumber" />
                    </div>

                    <div class="form-field">
                        <label for="edit-internal-status">Status</label>
                        <InputSelect id="edit-internal-status" class="text-input" @bind-Value="productDetailsModel.InternalStatus">
                            <option value="">Not recorded</option>
                            @foreach (var status in InternalStatusOptions)
                            {
                                <option value="@status">@status</option>
                            }
                        </InputSelect>
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="primary-button" disabled="@isSavingProductDetails">
                        @(isSavingProductDetails ? "Saving..." : "Save Product Details")
                    </button>
                    <button type="button" class="secondary-button" disabled="@isSavingProductDetails" @onclick="CancelProductDetailsEdit">Cancel</button>
                </div>
            </EditForm>
        }
        else
        {
            <dl class="summary-list">
                <div>
                    <dt>Product code</dt>
                    <dd>@buildRecord.ProductCode</dd>
                </div>
                <div>
                    <dt>Product name</dt>
                    <dd>@buildRecord.ProductName</dd>
                </div>
                <div>
                    <dt>Classification</dt>
                    <dd>@Display(buildRecord.ProductClassification)</dd>
                </div>
                <div>
                    <dt>Serial number</dt>
                    <dd>@buildRecord.SerialNumber</dd>
                </div>
                <div>
                    <dt>Status</dt>
                    <dd>@Display(buildRecord.InternalStatus)</dd>
                </div>
            </dl>
        }
    </section>

    <section id="build-details" class="detail-panel detail-section" aria-labelledby="build-details-heading">
        <div class="detail-panel-header">
            <div>
                <h2 id="build-details-heading">Build Details</h2>
                <p>Assembly, manufacturer, QA and checking information.</p>
            </div>
            <AuthorizeView Policy="@BuildBookPolicies.EditBuildRecords">
                <Authorized>
                    @if (!isEditingBuildDetails)
                    {
                        <button type="button" class="secondary-button" @onclick="StartEditingBuildDetails">Edit</button>
                    }
                </Authorized>
            </AuthorizeView>
        </div>

        @if (isEditingBuildDetails)
        {
            @if (buildDetailErrors.Count > 0)
            {
                <div class="status-message error" role="alert">
                    <p>Build details could not be saved.</p>
                    <ul>
                        @foreach (var error in buildDetailErrors)
                        {
                            <li>@error</li>
                        }
                    </ul>
                </div>
            }

            <EditForm Model="buildDetailsModel" OnValidSubmit="SaveBuildDetailsAsync" FormName="edit-build-details">
                <div class="form-grid">
                    <div class="form-field">
                        <label for="edit-assembled-in">Assembled in</label>
                        <InputText id="edit-assembled-in" class="text-input" @bind-Value="buildDetailsModel.AssembledIn" />
                    </div>

                    <div class="form-field">
                        <label for="edit-assembled-by">Assembled by</label>
                        <InputText id="edit-assembled-by" class="text-input" @bind-Value="buildDetailsModel.AssembledBy" />
                    </div>

                    <div class="form-field">
                        <label for="edit-date-assembled">Date assembled</label>
                        <InputDate id="edit-date-assembled" class="text-input" @bind-Value="buildDetailsModel.DateAssembled" />
                    </div>

                    <div class="form-field">
                        <label for="edit-hardware-manufacturer">H/W manufacturer</label>
                        <InputText id="edit-hardware-manufacturer" class="text-input" @bind-Value="buildDetailsModel.HardwareManufacturer" />
                    </div>

                    <div class="form-field">
                        <label for="edit-manufacturer-part-number">Manufacturer part no.</label>
                        <InputText id="edit-manufacturer-part-number" class="text-input" @bind-Value="buildDetailsModel.ManufacturerPartNumber" />
                    </div>

                    <div class="form-field">
                        <label for="edit-manufacturer-revision">Manufacturer revision</label>
                        <InputText id="edit-manufacturer-revision" class="text-input" @bind-Value="buildDetailsModel.ManufacturerRevision" />
                    </div>

                    <div class="form-field">
                        <label for="edit-manufacturer-serial-number">Manufacturer serial no.</label>
                        <InputText id="edit-manufacturer-serial-number" class="text-input" @bind-Value="buildDetailsModel.ManufacturerSerialNumber" />
                    </div>

                    <div class="form-field">
                        <label for="edit-packing-list">Packing list</label>
                        <InputText id="edit-packing-list" class="text-input" @bind-Value="buildDetailsModel.PackingList" />
                    </div>

                    <div class="form-field">
                        <label for="edit-checked-by">Checked by</label>
                        <InputText id="edit-checked-by" class="text-input" @bind-Value="buildDetailsModel.CheckedBy" />
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="primary-button" disabled="@isSavingBuildDetails">
                        @(isSavingBuildDetails ? "Saving..." : "Save Build Details")
                    </button>
                    <button type="button" class="secondary-button" disabled="@isSavingBuildDetails" @onclick="CancelBuildDetailsEdit">Cancel</button>
                </div>
            </EditForm>
        }
        else
        {
            <dl class="summary-list">
                <div>
                    <dt>Assembled in</dt>
                    <dd>@Display(buildRecord.AssembledIn)</dd>
                </div>
                <div>
                    <dt>Assembled by</dt>
                    <dd>@Display(buildRecord.AssembledBy)</dd>
                </div>
                <div>
                    <dt>Date assembled</dt>
                    <dd>@Display(buildRecord.DateAssembled)</dd>
                </div>
                <div>
                    <dt>H/W manufacturer</dt>
                    <dd>@Display(buildRecord.HardwareManufacturer)</dd>
                </div>
                <div>
                    <dt>Manufacturer part no.</dt>
                    <dd>@Display(buildRecord.ManufacturerPartNumber)</dd>
                </div>
                <div>
                    <dt>Manufacturer revision</dt>
                    <dd>@Display(buildRecord.ManufacturerRevision)</dd>
                </div>
                <div>
                    <dt>Manufacturer serial no.</dt>
                    <dd>@Display(buildRecord.ManufacturerSerialNumber)</dd>
                </div>
                <div>
                    <dt>Packing list</dt>
                    <dd>@Display(buildRecord.PackingList)</dd>
                </div>
                <div>
                    <dt>Checked by</dt>
                    <dd>@Display(buildRecord.CheckedBy)</dd>
                </div>
            </dl>
        }
    </section>

    <section id="customer-shipping" class="detail-panel detail-section" aria-labelledby="customer-shipping-heading">
        <div class="detail-panel-header">
            <div>
                <h2 id="customer-shipping-heading">Customer &amp; Shipping</h2>
                <p>Customer, order and shipping reference information.</p>
            </div>
            <AuthorizeView Policy="@BuildBookPolicies.EditBuildRecords">
                <Authorized>
                    @if (!isEditingCustomerShipping)
                    {
                        <button type="button" class="secondary-button" @onclick="StartEditingCustomerShipping">Edit</button>
                    }
                </Authorized>
            </AuthorizeView>
        </div>

        @if (isEditingCustomerShipping)
        {
            @if (customerShippingErrors.Count > 0)
            {
                <div class="status-message error" role="alert">
                    <p>Customer and shipping details could not be saved.</p>
                    <ul>
                        @foreach (var error in customerShippingErrors)
                        {
                            <li>@error</li>
                        }
                    </ul>
                </div>
            }

            <EditForm Model="customerShippingModel" OnValidSubmit="SaveCustomerShippingAsync" FormName="edit-customer-shipping">
                <div class="form-grid">
                    <div class="form-field">
                        <label for="edit-customer">Customer</label>
                        <InputSelect id="edit-customer" class="text-input" @bind-Value="customerShippingModel.CustomerId">
                            <option value="">Not recorded</option>
                            @foreach (var customer in customerOptions)
                            {
                                <option value="@customer.Id">@customer.Name</option>
                            }
                        </InputSelect>
                    </div>

                    <div class="form-field">
                        <label for="edit-customer-order">Customer order</label>
                        <InputText id="edit-customer-order" class="text-input" @bind-Value="customerShippingModel.CustomerOrder" />
                    </div>

                    <div class="form-field">
                        <label for="edit-oa-number">OA number</label>
                        <InputText id="edit-oa-number" class="text-input" @bind-Value="customerShippingModel.OANumber" />
                    </div>

                    <div class="form-field">
                        <label for="edit-invoice-number">Invoice number</label>
                        <InputText id="edit-invoice-number" class="text-input" @bind-Value="customerShippingModel.InvoiceNumber" />
                    </div>

                    <div class="form-field">
                        <label for="edit-date-shipped">Date shipped</label>
                        <InputDate id="edit-date-shipped" class="text-input" @bind-Value="customerShippingModel.DateShipped" />
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="primary-button" disabled="@isSavingCustomerShipping">
                        @(isSavingCustomerShipping ? "Saving..." : "Save Customer & Shipping")
                    </button>
                    <button type="button" class="secondary-button" disabled="@isSavingCustomerShipping" @onclick="CancelCustomerShippingEdit">Cancel</button>
                </div>
            </EditForm>
        }
        else
        {
            <dl class="summary-list">
                <div>
                    <dt>Customer</dt>
                    <dd>@Display(buildRecord.CustomerName)</dd>
                </div>
                <div>
                    <dt>Customer order</dt>
                    <dd>@Display(buildRecord.CustomerOrder)</dd>
                </div>
                <div>
                    <dt>OA number</dt>
                    <dd>@Display(buildRecord.OANumber)</dd>
                </div>
                <div>
                    <dt>Invoice number</dt>
                    <dd>@Display(buildRecord.InvoiceNumber)</dd>
                </div>
                <div>
                    <dt>Date shipped</dt>
                    <dd>@Display(buildRecord.DateShipped)</dd>
                </div>
            </dl>
        }
    </section>

    <section id="hardware-details" class="detail-panel detail-section" aria-labelledby="hardware-details-heading">
        <div class="detail-panel-header">
            <div>
                <h2 id="hardware-details-heading">Hardware</h2>
                <p>Panel, machine, radio and router information.</p>
            </div>
            <AuthorizeView Policy="@BuildBookPolicies.EditBuildRecords">
                <Authorized>
                    @if (!isEditingHardwareDetails)
                    {
                        <button type="button" class="secondary-button" @onclick="StartEditingHardwareDetails">Edit</button>
                    }
                </Authorized>
            </AuthorizeView>
        </div>

        @if (isEditingHardwareDetails)
        {
            @if (hardwareDetailErrors.Count > 0)
            {
                <div class="status-message error" role="alert">
                    <p>Hardware details could not be saved.</p>
                    <ul>
                        @foreach (var error in hardwareDetailErrors)
                        {
                            <li>@error</li>
                        }
                    </ul>
                </div>
            }

            <EditForm Model="hardwareDetailsModel" OnValidSubmit="SaveHardwareDetailsAsync" FormName="edit-hardware-details">
                <div class="form-grid">
                    <div class="form-field">
                        <label for="edit-panel-device-model">Panel device model</label>
                        <InputText id="edit-panel-device-model" class="text-input" @bind-Value="hardwareDetailsModel.PanelDeviceModel" />
                    </div>

                    <div class="form-field">
                        <label for="edit-panel-device-serial">Panel device serial</label>
                        <InputText id="edit-panel-device-serial" class="text-input" @bind-Value="hardwareDetailsModel.PanelDeviceSerial" />
                    </div>

                    <div class="form-field">
                        <label for="edit-panel-firmware-version">Panel firmware version</label>
                        <InputText id="edit-panel-firmware-version" class="text-input" @bind-Value="hardwareDetailsModel.PanelFirmwareVersion" />
                    </div>

                    <div class="form-field">
                        <label for="edit-machine-name">Machine name</label>
                        <InputText id="edit-machine-name" class="text-input" @bind-Value="hardwareDetailsModel.MachineName" />
                    </div>

                    <div class="form-field">
                        <label for="edit-radio-serial-number">Radio serial number</label>
                        <InputText id="edit-radio-serial-number" class="text-input" @bind-Value="hardwareDetailsModel.RadioSerialNumber" />
                    </div>

                    <div class="form-field form-field-wide">
                        <label for="edit-hardware-notes">Hardware notes</label>
                        <InputTextArea id="edit-hardware-notes" class="text-input" @bind-Value="hardwareDetailsModel.HardwareNotes" />
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="primary-button" disabled="@isSavingHardwareDetails">
                        @(isSavingHardwareDetails ? "Saving..." : "Save Hardware")
                    </button>
                    <button type="button" class="secondary-button" disabled="@isSavingHardwareDetails" @onclick="CancelHardwareDetailsEdit">Cancel</button>
                </div>
            </EditForm>
        }
        else
        {
            <dl class="summary-list">
                <div>
                    <dt>Panel device model</dt>
                    <dd>@Display(buildRecord.PanelDeviceModel)</dd>
                </div>
                <div>
                    <dt>Panel device serial</dt>
                    <dd>@Display(buildRecord.PanelDeviceSerial)</dd>
                </div>
                <div>
                    <dt>Panel firmware version</dt>
                    <dd>@Display(buildRecord.PanelFirmwareVersion)</dd>
                </div>
                <div>
                    <dt>Machine name</dt>
                    <dd>@Display(buildRecord.MachineName)</dd>
                </div>
                <div>
                    <dt>Radio serial number</dt>
                    <dd>@Display(buildRecord.RadioSerialNumber)</dd>
                </div>
                <div>
                    <dt>Hardware notes</dt>
                    <dd>@Display(buildRecord.HardwareNotes)</dd>
                </div>
            </dl>
        }
    </section>

    <section id="software-firmware" class="detail-panel detail-section" aria-labelledby="software-firmware-heading">
        <div class="detail-panel-header">
            <div>
                <h2 id="software-firmware-heading">Software &amp; Firmware</h2>
                <p>RadSight, Windows, disk image and firmware versions.</p>
            </div>
            <AuthorizeView Policy="@BuildBookPolicies.EditBuildRecords">
                <Authorized>
                    @if (!isEditingSoftwareFirmware)
                    {
                        <button type="button" class="secondary-button" @onclick="StartEditingSoftwareFirmware">Edit</button>
                    }
                </Authorized>
            </AuthorizeView>
        </div>

        @if (isEditingSoftwareFirmware)
        {
            @if (softwareFirmwareErrors.Count > 0)
            {
                <div class="status-message error" role="alert">
                    <p>Software and firmware details could not be saved.</p>
                    <ul>
                        @foreach (var error in softwareFirmwareErrors)
                        {
                            <li>@error</li>
                        }
                    </ul>
                </div>
            }

            <EditForm Model="softwareFirmwareModel" OnValidSubmit="SaveSoftwareFirmwareAsync" FormName="edit-software-firmware">
                <div class="form-grid">
                    <div class="form-field">
                        <label for="edit-disk-image-version">Disk image version</label>
                        <InputText id="edit-disk-image-version" class="text-input" @bind-Value="softwareFirmwareModel.DiskImageVersion" />
                    </div>

                    <div class="form-field">
                        <label for="edit-radsight-version">RadSight version</label>
                        <InputText id="edit-radsight-version" class="text-input" @bind-Value="softwareFirmwareModel.RadSightVersion" />
                    </div>

                    <div class="form-field">
                        <label for="edit-windows-version">Windows version</label>
                        <InputText id="edit-windows-version" class="text-input" @bind-Value="softwareFirmwareModel.WindowsVersion" />
                    </div>

                    <div class="form-field">
                        <label for="edit-windows-latest-patch">Windows latest patch</label>
                        <InputText id="edit-windows-latest-patch" class="text-input" @bind-Value="softwareFirmwareModel.WindowsLatestPatch" />
                    </div>

                    <div class="form-field">
                        <label for="edit-bleuvio-firmware-version">Bleuvio firmware version</label>
                        <InputText id="edit-bleuvio-firmware-version" class="text-input" @bind-Value="softwareFirmwareModel.BleuvioFirmwareVersion" />
                    </div>

                    <div class="form-field">
                        <label for="edit-charthouse-irda-firmware-version">Charthouse IRDA firmware version</label>
                        <InputText id="edit-charthouse-irda-firmware-version" class="text-input" @bind-Value="softwareFirmwareModel.CharthouseIrdaFirmwareVersion" />
                    </div>

                    <div class="form-field">
                        <label for="edit-radio-firmware">Radio firmware</label>
                        <InputText id="edit-radio-firmware" class="text-input" @bind-Value="softwareFirmwareModel.RadioFirmware" />
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="primary-button" disabled="@isSavingSoftwareFirmware">
                        @(isSavingSoftwareFirmware ? "Saving..." : "Save Software & Firmware")
                    </button>
                    <button type="button" class="secondary-button" disabled="@isSavingSoftwareFirmware" @onclick="CancelSoftwareFirmwareEdit">Cancel</button>
                </div>
            </EditForm>
        }
        else
        {
            <dl class="summary-list">
                <div>
                    <dt>Disk image version</dt>
                    <dd>@Display(buildRecord.DiskImageVersion)</dd>
                </div>
                <div>
                    <dt>RadSight version</dt>
                    <dd>@Display(buildRecord.RadSightVersion)</dd>
                </div>
                <div>
                    <dt>Windows version</dt>
                    <dd>@Display(buildRecord.WindowsVersion)</dd>
                </div>
                <div>
                    <dt>Windows latest patch</dt>
                    <dd>@Display(buildRecord.WindowsLatestPatch)</dd>
                </div>
                <div>
                    <dt>Bleuvio firmware version</dt>
                    <dd>@Display(buildRecord.BleuvioFirmwareVersion)</dd>
                </div>
                <div>
                    <dt>Charthouse IRDA firmware version</dt>
                    <dd>@Display(buildRecord.CharthouseIrdaFirmwareVersion)</dd>
                </div>
                <div>
                    <dt>Radio firmware</dt>
                    <dd>@Display(buildRecord.RadioFirmware)</dd>
                </div>
            </dl>
        }
    </section>

    <section id="network" class="detail-panel detail-section" aria-labelledby="network-heading">
        <div class="detail-panel-header">
            <div>
                <h2 id="network-heading">Network</h2>
                <p>Wi-Fi SSID and router details. Passwords are stored separately.</p>
            </div>
            <AuthorizeView Policy="@BuildBookPolicies.EditBuildRecords">
                <Authorized>
                    @if (!isEditingNetworkDetails)
                    {
                        <button type="button" class="secondary-button" @onclick="StartEditingNetworkDetails">Edit</button>
                    }
                </Authorized>
            </AuthorizeView>
        </div>

        @if (isEditingNetworkDetails)
        {
            @if (networkDetailErrors.Count > 0)
            {
                <div class="status-message error" role="alert">
                    <p>Network details could not be saved.</p>
                    <ul>
                        @foreach (var error in networkDetailErrors)
                        {
                            <li>@error</li>
                        }
                    </ul>
                </div>
            }

            <EditForm Model="networkDetailsModel" OnValidSubmit="SaveNetworkDetailsAsync" FormName="edit-network-details">
                <div class="form-grid">
                    <div class="form-field">
                        <label for="edit-wifi-ssid">Wi-Fi SSID</label>
                        <InputText id="edit-wifi-ssid" class="text-input" @bind-Value="networkDetailsModel.WifiSsid" />
                    </div>

                    <div class="form-field">
                        <label for="edit-router-used">Router used</label>
                        <InputText id="edit-router-used" class="text-input" @bind-Value="networkDetailsModel.RouterUsed" />
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="primary-button" disabled="@isSavingNetworkDetails">
                        @(isSavingNetworkDetails ? "Saving..." : "Save Network")
                    </button>
                    <button type="button" class="secondary-button" disabled="@isSavingNetworkDetails" @onclick="CancelNetworkDetailsEdit">Cancel</button>
                </div>
            </EditForm>
        }
        else
        {
            <dl class="summary-list">
                <div>
                    <dt>Wi-Fi SSID</dt>
                    <dd>@Display(buildRecord.WifiSsid)</dd>
                </div>
                <div>
                    <dt>Router used</dt>
                    <dd>@Display(buildRecord.RouterUsed)</dd>
                </div>
            </dl>
        }
    </section>

    <section id="credentials-recovery" class="detail-panel detail-section" aria-labelledby="credentials-recovery-heading">
        <div class="detail-panel-header">
            <div>
                <h2 id="credentials-recovery-heading">Credentials &amp; Recovery</h2>
                <p>User account names and protected recovery information. Secret values stay hidden unless an authorised user explicitly reveals or updates them.</p>
            </div>
        </div>

        <dl class="summary-list">
            <div>
                <dt>RadSight user login</dt>
                <dd>@Display(buildRecord.RadSightUserLogin)</dd>
            </div>
            <div>
                <dt>Kiosk user</dt>
                <dd>@Display(buildRecord.KioskUser)</dd>
            </div>
            <div>
                <dt>Windows admin user</dt>
                <dd>@Display(buildRecord.WindowsAdminUser)</dd>
            </div>
            @foreach (var secretType in SupportedSecretTypes)
            {
                <div class="secret-summary-item">
                    <dt>@GetSecretLabel(secretType)</dt>
                    <dd>
                        <div class="secret-status-row">
                            <span class="validation-badge @(IsSecretSet(secretType) ? "warning" : "error")">@SecretStatus(secretType)</span>
                            <span class="@SecretValueCssClass(secretType)">@DisplaySecret(secretType)</span>
                        </div>

                        <div class="form-actions">
                            @if (canRevealSensitiveData && IsSecretSet(secretType) && !IsSecretRevealed(secretType))
                            {
                                <button type="button" class="secondary-button button-small secret-action-button" disabled="@IsRevealingSecret(secretType)" @onclick="() => RevealSecretAsync(secretType)">
                                    @(IsRevealingSecret(secretType) ? "Revealing..." : "Reveal")
                                </button>
                            }
                            else if (canRevealSensitiveData && IsSecretRevealed(secretType))
                            {
                                <button type="button" class="secondary-button button-small secret-action-button" @onclick="() => HideSecret(secretType)">
                                    Hide
                                </button>
                            }

                            @if (canManageSensitiveData && !IsEditingSecret(secretType))
                            {
                                <button type="button" class="secondary-button button-small secret-action-button" @onclick="() => StartEditingSecret(secretType)">
                                    @(IsSecretSet(secretType) ? "Update" : "Set")
                                </button>
                            }
                        </div>

                        @if (GetSecretRevealError(secretType) is { } revealError)
                        {
                            <span class="field-message error">@revealError</span>
                        }

                        @if (IsEditingSecret(secretType))
                        {
                            @if (secretSaveErrors.Count > 0)
                            {
                                <div class="status-message error" role="alert">
                                    <p>@GetSecretLabel(secretType) could not be saved.</p>
                                    <ul>
                                        @foreach (var error in secretSaveErrors)
                                        {
                                            <li>@error</li>
                                        }
                                    </ul>
                                </div>
                            }

                            <EditForm Model="secretEditModel" OnValidSubmit="SaveSecretAsync" FormName="@($"edit-secret-{SanitizeSecretType(secretType)}")">
                                <div class="form-grid secret-edit-grid">
                                    <div class="form-field">
                                        <label for="@($"secret-value-{SanitizeSecretType(secretType)}")">New value</label>
                                        <InputText id="@($"secret-value-{SanitizeSecretType(secretType)}")" class="text-input secret-edit-input" type="password" @bind-Value="secretEditModel.NewValue" />
                                        @if (secretType == SecretType.BitLockerRecoveryKey)
                                        {
                                            <span class="field-message">Use eight groups of six digits separated by hyphens.</span>
                                        }
                                    </div>
                                    <div class="form-field">
                                        <label for="@($"secret-confirm-{SanitizeSecretType(secretType)}")">Confirm value</label>
                                        <InputText id="@($"secret-confirm-{SanitizeSecretType(secretType)}")" class="text-input secret-edit-input" type="password" @bind-Value="secretEditModel.ConfirmValue" />
                                    </div>
                                </div>

                                <div class="form-actions">
                                    <button type="submit" class="primary-button" disabled="@IsSavingSecret(secretType)">
                                        @(IsSavingSecret(secretType) ? "Saving..." : "Save")
                                    </button>
                                    <button type="button" class="secondary-button" disabled="@IsSavingSecret(secretType)" @onclick="CancelSecretEdit">Cancel</button>
                                </div>
                            </EditForm>
                        }
                    </dd>
                </div>
            }
        </dl>
    </section>

    <section id="notes" class="detail-panel detail-section" aria-labelledby="notes-heading">
        <div class="detail-panel-header">
            <div>
                <h2 id="notes-heading">Notes</h2>
                <p>General non-sensitive notes for this Build Record.</p>
            </div>
            <AuthorizeView Policy="@BuildBookPolicies.EditBuildRecords">
                <Authorized>
                    @if (!isEditingNotes)
                    {
                        <button type="button" class="secondary-button" @onclick="StartEditingNotes">Edit</button>
                    }
                </Authorized>
            </AuthorizeView>
        </div>

        @if (isEditingNotes)
        {
            @if (notesErrors.Count > 0)
            {
                <div class="status-message error" role="alert">
                    <p>Notes could not be saved.</p>
                    <ul>
                        @foreach (var error in notesErrors)
                        {
                            <li>@error</li>
                        }
                    </ul>
                </div>
            }

            <EditForm Model="notesModel" OnValidSubmit="SaveNotesAsync" FormName="edit-notes">
                <div class="form-grid">
                    <div class="form-field form-field-wide">
                        <label for="edit-note">Note</label>
                        <InputTextArea id="edit-note" class="text-input" @bind-Value="notesModel.Note" />
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="primary-button" disabled="@isSavingNotes">
                        @(isSavingNotes ? "Saving..." : "Save Notes")
                    </button>
                    <button type="button" class="secondary-button" disabled="@isSavingNotes" @onclick="CancelNotesEdit">Cancel</button>
                </div>
            </EditForm>
        }
        else
        {
            <dl class="summary-list">
                <div>
                    <dt>Note</dt>
                    <dd>@Display(buildRecord.Note)</dd>
                </div>
            </dl>
        }
    </section>

    <section id="linked-rmas" class="detail-panel detail-section" aria-labelledby="linked-rmas-heading">
        <div class="detail-panel-header">
            <div>
                <h2 id="linked-rmas-heading">Linked RMAs</h2>
                <p>Previous and current RMAs linked to this Build Record.</p>
            </div>
            <AuthorizeView Policy="@BuildBookRmaPolicies.CreateRmas">
                <Authorized>
                    <a class="secondary-button" href="@($"/rmas/new?buildRecordId={BuildRecordId}")">Create RMA</a>
                </Authorized>
            </AuthorizeView>
        </div>

        @if (linkedRmas.Count == 0)
        {
            <p class="empty-state">No RMAs are currently linked to this Build Record.</p>
        }
        else
        {
            <div class="table-scroll">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th scope="col">RMA number</th>
                            <th scope="col">Status</th>
                            <th scope="col">Fault summary</th>
                            <th scope="col">Created</th>
                            <th scope="col">Closed</th>
                            <th scope="col">Outcome</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var linkedRma in linkedRmas)
                        {
                            <tr>
                                <td><a class="table-link" href="@($"/rmas/{linkedRma.Id}")">@linkedRma.RmaNumber</a></td>
                                <td>@DisplayRmaStatus(linkedRma.Status)</td>
                                <td>@linkedRma.FaultSummary</td>
                                <td>@linkedRma.CreatedAt.ToLocalTime().ToString("d MMM yyyy HH:mm")</td>
                                <td>@Display(linkedRma.ClosedAt)</td>
                                <td>@DisplayRmaOutcome(linkedRma.Outcome)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>

    <section id="linked-orders" class="detail-panel detail-section" aria-labelledby="linked-orders-heading">
        <div class="detail-panel-header">
            <div>
                <h2 id="linked-orders-heading">Linked Orders</h2>
                <p>Orders currently connected to this Build Record.</p>
            </div>
        </div>

        @if (buildRecord.LinkedOrders.Count == 0)
        {
            <p class="empty-state">No Orders are currently linked to this Build Record.</p>
        }
        else
        {
            <div class="table-scroll">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th scope="col">Order</th>
                            <th scope="col">Status</th>
                            <th scope="col">Customer</th>
                            <th scope="col">Link type</th>
                            <th scope="col">Linked at</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var linkedOrder in buildRecord.LinkedOrders)
                        {
                            <tr>
                                <td><a class="table-link" href="@($"/orders/{linkedOrder.OrderId}")">@linkedOrder.OrderNumber / @linkedOrder.OrderTitle</a></td>
                                <td>@linkedOrder.Status</td>
                                <td>@Display(linkedOrder.CustomerName)</td>
                                <td>@Display(linkedOrder.LinkType)</td>
                                <td>@linkedOrder.LinkedAt.ToLocalTime().ToString("d MMM yyyy HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>

    <section id="history" class="detail-panel detail-section" aria-labelledby="history-heading">
        <div class="detail-panel-header">
            <div>
                <h2 id="history-heading">History</h2>
                <p>Audit history for this Build Record.</p>
            </div>
        </div>

        @if (auditHistory.Count == 0)
        {
            <p class="empty-state">No audit history has been recorded yet.</p>
        }
        else
        {
            <div class="table-scroll">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th scope="col">Date/time</th>
                            <th scope="col">User</th>
                            <th scope="col">Action</th>
                            <th scope="col">Field changed</th>
                            <th scope="col">Old value</th>
                            <th scope="col">New value</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var auditEntry in auditHistory)
                        {
                            <tr>
                                <td>@auditEntry.OccurredAt.ToLocalTime().ToString("d MMM yyyy HH:mm")</td>
                                <td>@DisplayAuditValue(auditEntry.User)</td>
                                <td>@DisplayAuditAction(auditEntry.Action)</td>
                                <td>@DisplayAuditValue(auditEntry.FieldChanged)</td>
                                <td>@DisplayAuditValue(auditEntry.OldValue)</td>
                                <td>@DisplayAuditValue(auditEntry.NewValue)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>

    <p class="detail-actions">
        <a class="secondary-link" href="/build-register">Back to Build Register</a>
    </p>
}

@code {
