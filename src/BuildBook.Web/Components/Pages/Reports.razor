@page "/reports"
@rendermode InteractiveServer

@attribute [Authorize(Policy = BuildBookPolicies.ExportNonSensitiveData)]

@inject IBuildRegisterReader BuildRegisterReader
@inject ICustomerOptionsReader CustomerOptionsReader

<PageTitle>Reports</PageTitle>

<section class="page-heading">
    <p class="eyebrow">Reports</p>
    <h1>Reports</h1>
    <p>Export current Build Register results to CSV or Excel, and review non-sensitive device lists for a selected customer.</p>
</section>

<section class="detail-panel" aria-labelledby="reports-export-heading">
    <div class="detail-panel-header">
        <div>
            <h2 id="reports-export-heading">Current search results</h2>
            <p>Start from the Build Register to export the current filtered results to CSV or Excel.</p>
        </div>
    </div>

    <div class="detail-actions">
        <a class="primary-button" href="/build-register">Open Build Register</a>
    </div>
</section>

<section class="detail-panel" aria-labelledby="customer-report-heading">
    <div class="detail-panel-header">
        <div>
            <h2 id="customer-report-heading">Devices by customer</h2>
            <p>Select a customer to list their Build Records without exposing sensitive data.</p>
        </div>
    </div>

    <div class="filter-grid">
        <div class="form-field">
            <label for="report-customer">Customer</label>
            <InputSelect id="report-customer" class="text-input" @bind-Value="selectedCustomerId">
                <option value="">Select customer</option>
                @foreach (var customer in customerOptions)
                {
                    <option value="@customer.Id">@customer.Name</option>
                }
            </InputSelect>
        </div>
    </div>

    <div class="form-actions">
        <button type="button" class="primary-button" disabled="@(!canRunReport)" @onclick="LoadCustomerReportAsync">Show report</button>
        <button type="button" class="secondary-button" disabled="@(!canClearReport)" @onclick="ClearCustomerReportAsync">Clear</button>
    </div>

    @if (!string.IsNullOrWhiteSpace(reportError))
    {
        <div class="status-message error" role="alert">
            <p>@reportError</p>
        </div>
    }

    @if (isLoadingCustomers)
    {
        <div class="placeholder-panel" aria-live="polite">
            <p>Loading customers...</p>
        </div>
    }
    else if (customerOptions.Count == 0)
    {
        <div class="placeholder-panel">
            <p>No customers are available yet.</p>
        </div>
    }
    else if (selectedCustomer is null)
    {
        <div class="placeholder-panel">
            <p>Select a customer to list all matching Build Records.</p>
        </div>
    }
    else if (isLoadingReport)
    {
        <div class="placeholder-panel" aria-live="polite">
            <p>Loading customer report...</p>
        </div>
    }
    else if (customerBuildRecords.Count == 0)
    {
        <div class="placeholder-panel">
            <p>No Build Records were found for the selected customer.</p>
        </div>
    }
    else
    {
        <div class="table-panel-heading">
            <h3>@selectedCustomer.Name</h3>
            <p>@customerBuildRecords.Count active Build Records</p>
        </div>

        <div class="table-scroll">
            <table class="data-table">
                <thead>
                    <tr>
                        <th scope="col">Product code</th>
                        <th scope="col">Product name</th>
                        <th scope="col">Serial number</th>
                        <th scope="col">Machine name</th>
                        <th scope="col">RadSight version</th>
                        <th scope="col">Windows version</th>
                        <th scope="col">Date shipped</th>
                        <th scope="col">Last updated</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var buildRecord in customerBuildRecords)
                    {
                        <tr>
                            <td>@Display(buildRecord.ProductCode)</td>
                            <td>@Display(buildRecord.ProductName)</td>
                            <td>
                                <a class="table-link" href="@($"/build-records/{buildRecord.Id}")">@buildRecord.SerialNumber</a>
                            </td>
                            <td>@Display(buildRecord.MachineName)</td>
                            <td>@Display(buildRecord.RadSightVersion)</td>
                            <td>@Display(buildRecord.WindowsVersion)</td>
                            <td>@Display(buildRecord.DateShipped)</td>
                            <td>@buildRecord.LastUpdatedAt.ToLocalTime().ToString("d MMM yyyy HH:mm")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>

<section class="placeholder-panel" aria-labelledby="reports-placeholder">
    <h2 id="reports-placeholder">Coming later</h2>
    <p>This page is reserved for product, version, shipped-date and missing-data reports.</p>
</section>

@code {
    private IReadOnlyList<CustomerOption> customerOptions = [];
    private IReadOnlyList<BuildRegisterRow> customerBuildRecords = [];
    private CustomerOption? selectedCustomer;
    private int? selectedCustomerId;
    private bool isLoadingCustomers;
    private bool isLoadingReport;
    private string? reportError;
    private bool canRunReport => !isLoadingCustomers && !isLoadingReport && selectedCustomerId is not null;
    private bool canClearReport => !isLoadingReport && (selectedCustomerId is not null || selectedCustomer is not null || customerBuildRecords.Count > 0);

    protected override async Task OnInitializedAsync()
    {
        isLoadingCustomers = true;
        customerOptions = await CustomerOptionsReader.ListActiveAsync();
        isLoadingCustomers = false;
    }

    private async Task LoadCustomerReportAsync()
    {
        reportError = null;
        customerBuildRecords = [];
        selectedCustomer = customerOptions.FirstOrDefault(customer => customer.Id == selectedCustomerId);

        if (selectedCustomer is null)
        {
            return;
        }

        isLoadingReport = true;

        try
        {
            customerBuildRecords = await BuildRegisterReader.ListAsync(new BuildRegisterFilter
            {
                CustomerId = selectedCustomer.Id
            });
        }
        catch
        {
            selectedCustomer = null;
            reportError = "The customer report could not be loaded. Refresh the page and try again.";
        }
        finally
        {
            isLoadingReport = false;
        }
    }

    private Task ClearCustomerReportAsync()
    {
        selectedCustomerId = null;
        selectedCustomer = null;
        customerBuildRecords = [];
        reportError = null;
        return Task.CompletedTask;
    }

    private static string Display(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "Not recorded" : value;
    }

    private static string Display(DateOnly? value)
    {
        return value?.ToString("d MMM yyyy") ?? "Not recorded";
    }
}
