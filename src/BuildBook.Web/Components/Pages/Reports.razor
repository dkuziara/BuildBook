@page "/reports"

@attribute [Authorize(Policy = BuildBookPolicies.ExportNonSensitiveData)]

<PageTitle>Reports</PageTitle>

<section class="page-heading">
    <p class="eyebrow">Reports</p>
    <h1>Reports</h1>
    <p>Export current Build Register results to CSV or Excel, and use this area for additional non-sensitive reporting as later items arrive.</p>
</section>

<section class="detail-panel" aria-labelledby="reports-export-heading">
    <div class="detail-panel-header">
        <div>
            <h2 id="reports-export-heading">Current search results</h2>
            <p>Start from the Build Register to export the current filtered results to CSV or Excel.</p>
        </div>
    </div>

    <div class="detail-actions">
        <a class="primary-button" href="/build-register">Open Build Register</a>
    </div>
</section>

<section class="placeholder-panel" aria-labelledby="reports-placeholder">
    <h2 id="reports-placeholder">Coming later</h2>
    <p>This page is reserved for customer, product, version, shipped-date and missing-data reports.</p>
</section>
