@page "/reports"
@rendermode InteractiveServer

@attribute [Authorize(Policy = BuildBookPolicies.ExportNonSensitiveData)]

@using Microsoft.AspNetCore.Components

@inject IBuildRegisterReader BuildRegisterReader
@inject ICustomerOptionsReader CustomerOptionsReader
@inject IMissingDataReportReader MissingDataReportReader

<PageTitle>Reports</PageTitle>

<section class="page-heading">
    <div class="page-heading-copy">
        <p class="eyebrow">Reports</p>
        <h1>Reports</h1>
        <p>Export current Build Register results to CSV or Excel, and review non-sensitive customer, software version and missing-data reports.</p>
    </div>
</section>

<section class="detail-panel" aria-labelledby="reports-export-heading">
        <div class="detail-panel-header">
            <div>
                <h2 id="reports-export-heading">Current search results</h2>
                <p>Use the Build Register when you need to export the current filtered result set.</p>
            </div>
        </div>

    <div class="detail-actions">
        <a class="primary-button" href="/build-register">Open Build Register</a>
    </div>
</section>

<section class="detail-panel" aria-labelledby="customer-report-heading">
        <div class="detail-panel-header">
            <div>
                <h2 id="customer-report-heading">Devices by customer</h2>
                <p>Select a customer to list matching Build Records without exposing sensitive data.</p>
            </div>
        </div>

    <div class="filter-grid">
        <div class="form-field">
            <label for="report-customer">Customer</label>
            <InputSelect id="report-customer" class="text-input" @bind-Value="selectedCustomerId">
                <option value="">Select customer</option>
                @foreach (var customer in customerOptions)
                {
                    <option value="@customer.Id">@customer.Name</option>
                }
            </InputSelect>
        </div>
    </div>

    <div class="form-actions">
        <button type="button" class="primary-button" disabled="@(!canRunReport)" @onclick="LoadCustomerReportAsync">Show report</button>
        <button type="button" class="secondary-button" disabled="@(!canClearReport)" @onclick="ClearCustomerReportAsync">Clear</button>
    </div>

    @if (!string.IsNullOrWhiteSpace(reportError))
    {
        <div class="status-message error" role="alert">
            <p>@reportError</p>
        </div>
    }

    @if (isLoadingCustomers)
    {
        <div class="placeholder-panel" aria-live="polite">
            <p>Loading customers...</p>
        </div>
    }
    else if (customerOptions.Count == 0)
    {
        <div class="placeholder-panel">
            <p>No customers are available yet.</p>
        </div>
    }
    else if (selectedCustomer is null)
    {
        <div class="placeholder-panel">
            <p>Select a customer to list all matching Build Records.</p>
        </div>
    }
    else if (isLoadingReport)
    {
        <div class="placeholder-panel" aria-live="polite">
            <p>Loading customer report...</p>
        </div>
    }
    else if (customerBuildRecords.Count == 0)
    {
        <div class="placeholder-panel">
            <p>No Build Records were found for the selected customer.</p>
        </div>
    }
    else
    {
        <div class="table-panel-heading">
            <h3>@selectedCustomer.Name</h3>
            <p>@customerBuildRecords.Count active Build Records</p>
        </div>

        <div class="table-scroll">
            <table class="data-table">
                <thead>
                    <tr>
                        <th scope="col">Product code</th>
                        <th scope="col">Product name</th>
                        <th scope="col">Serial number</th>
                        <th scope="col">Machine name</th>
                        <th scope="col">RadSight version</th>
                        <th scope="col">Windows version</th>
                        <th scope="col">Date shipped</th>
                        <th scope="col">Last updated</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var buildRecord in customerBuildRecords)
                    {
                        <tr>
                            <td>@Display(buildRecord.ProductCode)</td>
                            <td>@Display(buildRecord.ProductName)</td>
                            <td>
                                <a class="table-link" href="@($"/build-records/{buildRecord.Id}")">@buildRecord.SerialNumber</a>
                            </td>
                            <td>@Display(buildRecord.MachineName)</td>
                            <td>@Display(buildRecord.RadSightVersion)</td>
                            <td>@Display(buildRecord.WindowsVersion)</td>
                            <td>@Display(buildRecord.DateShipped)</td>
                            <td>@buildRecord.LastUpdatedAt.ToLocalTime().ToString("d MMM yyyy HH:mm")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>

<section class="detail-panel" aria-labelledby="missing-data-reports-heading">
    <div class="detail-panel-header">
        <div>
            <h2 id="missing-data-reports-heading">Missing data reports</h2>
            <p>Find active Build Records that still need customer, shipped date or recovery information.</p>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(missingDataReportError))
    {
        <div class="status-message error" role="alert">
            <p>@missingDataReportError</p>
        </div>
    }
    else if (isLoadingMissingDataReports)
    {
        <div class="placeholder-panel" aria-live="polite">
            <p>Loading missing data reports...</p>
        </div>
    }
    else
    {
        <div class="home-activity-grid">
            <section class="table-panel" aria-labelledby="missing-customer-heading">
                <div class="table-panel-heading">
                    <div>
                        <h3 id="missing-customer-heading">Missing customer</h3>
                        <p>@missingCustomerRecords.Count active Build Records</p>
                    </div>
                    <a class="secondary-button" aria-disabled="@(missingCustomerRecords.Count == 0)" href="@MissingDataReportLink(MissingDataReportType.Customer)">
                        Show missing records
                    </a>
                </div>
            </section>

            <section class="table-panel" aria-labelledby="missing-qa-heading">
                <div class="table-panel-heading">
                    <div>
                        <h3 id="missing-qa-heading">Missing QA number</h3>
                        <p>Not yet available</p>
                    </div>
                </div>
                <p>QA number reporting will be available once the field is added to Build Records.</p>
            </section>

            <section class="table-panel" aria-labelledby="missing-recovery-heading">
                <div class="table-panel-heading">
                    <div>
                        <h3 id="missing-recovery-heading">Missing recovery key</h3>
                        <p>@missingRecoveryRecords.Count active Build Records</p>
                    </div>
                    <a class="secondary-button" aria-disabled="@(missingRecoveryRecords.Count == 0)" href="@MissingDataReportLink(MissingDataReportType.RecoveryData)">
                        Show missing records
                    </a>
                </div>
            </section>

            <section class="table-panel" aria-labelledby="missing-shipped-date-heading">
                <div class="table-panel-heading">
                    <div>
                        <h3 id="missing-shipped-date-heading">Missing shipped date</h3>
                        <p>@missingShippedDateRecords.Count active Build Records</p>
                    </div>
                    <a class="secondary-button" aria-disabled="@(missingShippedDateRecords.Count == 0)" href="@MissingDataReportLink(MissingDataReportType.DateShipped)">
                        Show missing records
                    </a>
                </div>
            </section>
        </div>

        @if (selectedMissingDataReport is not null)
        {
            <section id="missing-data-records-section" class="table-panel detail-section report-scroll-target" aria-labelledby="missing-data-records-heading">
                <div class="table-panel-heading">
                    <div>
                        <h3 id="missing-data-records-heading" class="report-scroll-heading">@selectedMissingDataReportTitle</h3>
                        <p>@selectedMissingDataRecords.Count active Build Records</p>
                    </div>
                    <a class="secondary-button" href="/reports">Clear</a>
                </div>

                @if (selectedMissingDataRecords.Count == 0)
                {
                    <div class="placeholder-panel">
                        <p>No Build Records match this missing-data report.</p>
                    </div>
                }
                else
                {
                    <div class="table-scroll">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th scope="col">Product code</th>
                                    <th scope="col">Product name</th>
                                    <th scope="col">Serial number</th>
                                    <th scope="col">Customer</th>
                                    <th scope="col">Machine name</th>
                                    <th scope="col">RadSight version</th>
                                    <th scope="col">Windows version</th>
                                    <th scope="col">Date shipped</th>
                                    <th scope="col">Last updated</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var buildRecord in selectedMissingDataRecords)
                                {
                                    <tr>
                                        <td>@Display(buildRecord.ProductCode)</td>
                                        <td>@Display(buildRecord.ProductName)</td>
                                        <td>
                                            <a class="table-link" href="@($"/build-records/{buildRecord.Id}")">@buildRecord.SerialNumber</a>
                                        </td>
                                        <td>@Display(buildRecord.CustomerName)</td>
                                        <td>@Display(buildRecord.MachineName)</td>
                                        <td>@Display(buildRecord.RadSightVersion)</td>
                                        <td>@Display(buildRecord.WindowsVersion)</td>
                                        <td>@Display(buildRecord.DateShipped)</td>
                                        <td>@buildRecord.LastUpdatedAt.ToLocalTime().ToString("d MMM yyyy HH:mm")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </section>
        }
    }
</section>

<section class="detail-panel" aria-labelledby="software-version-reports-heading">
    <div class="detail-panel-header">
        <div>
            <h2 id="software-version-reports-heading">Software and version reports</h2>
            <p>Review active device counts by RadSight version and Windows version.</p>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(versionReportError))
    {
        <div class="status-message error" role="alert">
            <p>@versionReportError</p>
        </div>
    }
    else if (isLoadingVersionReports)
    {
        <div class="placeholder-panel" aria-live="polite">
            <p>Loading version reports...</p>
        </div>
    }
    else
    {
        <div class="home-activity-grid">
            <section class="table-panel" aria-labelledby="radsight-version-report-heading">
                <div class="table-panel-heading">
                    <div>
                        <h3 id="radsight-version-report-heading">RadSight versions</h3>
                        <p>Grouped from active Build Records.</p>
                    </div>
                </div>

                @if (radSightVersionRows.Count == 0)
                {
                    <div class="placeholder-panel">
                        <p>No RadSight versions have been recorded yet.</p>
                    </div>
                }
                else
                {
                    <div class="table-scroll">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th scope="col">Version</th>
                                    <th scope="col">Devices</th>
                                    <th scope="col">Open records</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in radSightVersionRows)
                                {
                                    <tr>
                                        <td>@row.Label</td>
                                        <td>@row.Count</td>
                                        <td>
                                            @if (row.HasFilterValue)
                                            {
                                                <a class="table-link" href="@BuildVersionReportLink("radSightVersion", row.FilterValue!)">Open matching records</a>
                                            }
                                            else
                                            {
                                                <span>Unavailable</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </section>

            <section class="table-panel" aria-labelledby="windows-version-report-heading">
                <div class="table-panel-heading">
                    <div>
                        <h3 id="windows-version-report-heading">Windows versions</h3>
                        <p>Grouped from active Build Records.</p>
                    </div>
                </div>

                @if (windowsVersionRows.Count == 0)
                {
                    <div class="placeholder-panel">
                        <p>No Windows versions have been recorded yet.</p>
                    </div>
                }
                else
                {
                    <div class="table-scroll">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th scope="col">Version</th>
                                    <th scope="col">Devices</th>
                                    <th scope="col">Open records</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in windowsVersionRows)
                                {
                                    <tr>
                                        <td>@row.Label</td>
                                        <td>@row.Count</td>
                                        <td>
                                            @if (row.HasFilterValue)
                                            {
                                                <a class="table-link" href="@BuildVersionReportLink("windowsVersion", row.FilterValue!)">Open matching records</a>
                                            }
                                            else
                                            {
                                                <span>Unavailable</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </section>
        </div>
    }
</section>

<section class="placeholder-panel" aria-labelledby="reports-placeholder">
    <h2 id="reports-placeholder">Coming later</h2>
    <p>This page is reserved for product reports and future QA-number tracking once that field is added.</p>
</section>

@code {
    [SupplyParameterFromQuery(Name = "missingData")]
    public string? MissingDataReportQuery { get; set; }

    private IReadOnlyList<CustomerOption> customerOptions = [];
    private IReadOnlyList<BuildRegisterRow> customerBuildRecords = [];
    private IReadOnlyList<MissingDataReportRow> missingDataRecords = [];
    private IReadOnlyList<VersionReportRow> radSightVersionRows = [];
    private IReadOnlyList<VersionReportRow> windowsVersionRows = [];
    private CustomerOption? selectedCustomer;
    private int? selectedCustomerId;
    private bool isLoadingCustomers;
    private bool isLoadingReport;
    private bool isLoadingMissingDataReports;
    private bool isLoadingVersionReports;
    private string? reportError;
    private string? missingDataReportError;
    private string? versionReportError;
    private MissingDataReportType? selectedMissingDataReport;
    private bool canRunReport => !isLoadingCustomers && !isLoadingReport && selectedCustomerId is not null;
    private bool canClearReport => !isLoadingReport && (selectedCustomerId is not null || selectedCustomer is not null || customerBuildRecords.Count > 0);
    private IReadOnlyList<MissingDataReportRow> missingCustomerRecords => missingDataRecords.Where(record => record.IsMissingCustomer).ToList();
    private IReadOnlyList<MissingDataReportRow> missingRecoveryRecords => missingDataRecords.Where(record => record.IsMissingRecoveryData).ToList();
    private IReadOnlyList<MissingDataReportRow> missingShippedDateRecords => missingDataRecords.Where(record => record.IsMissingDateShipped).ToList();
    private IReadOnlyList<MissingDataReportRow> selectedMissingDataRecords => selectedMissingDataReport switch
    {
        MissingDataReportType.Customer => missingCustomerRecords,
        MissingDataReportType.RecoveryData => missingRecoveryRecords,
        MissingDataReportType.DateShipped => missingShippedDateRecords,
        _ => []
    };
    private string selectedMissingDataReportTitle => selectedMissingDataReport switch
    {
        MissingDataReportType.Customer => "Build Records missing customer",
        MissingDataReportType.RecoveryData => "Build Records missing recovery key",
        MissingDataReportType.DateShipped => "Build Records missing shipped date",
        _ => "Missing data"
    };

    protected override async Task OnInitializedAsync()
    {
        isLoadingCustomers = true;
        isLoadingMissingDataReports = true;
        isLoadingVersionReports = true;

        await LoadCustomerOptionsAsync();
        await LoadMissingDataReportsAsync();
        await LoadVersionReportsAsync();
    }

    protected override void OnParametersSet()
    {
        selectedMissingDataReport = ParseMissingDataReport(MissingDataReportQuery);
    }

    private async Task LoadCustomerReportAsync()
    {
        reportError = null;
        customerBuildRecords = [];
        selectedCustomer = customerOptions.FirstOrDefault(customer => customer.Id == selectedCustomerId);

        if (selectedCustomer is null)
        {
            return;
        }

        isLoadingReport = true;

        try
        {
            customerBuildRecords = await BuildRegisterReader.ListAsync(new BuildRegisterFilter
            {
                CustomerId = selectedCustomer.Id
            });
        }
        catch
        {
            selectedCustomer = null;
            reportError = "The customer report could not be loaded. Refresh the page and try again.";
        }
        finally
        {
            isLoadingReport = false;
        }
    }

    private Task ClearCustomerReportAsync()
    {
        selectedCustomerId = null;
        selectedCustomer = null;
        customerBuildRecords = [];
        reportError = null;
        return Task.CompletedTask;
    }

    private async Task LoadCustomerOptionsAsync()
    {
        try
        {
            customerOptions = await CustomerOptionsReader.ListActiveAsync();
        }
        finally
        {
            isLoadingCustomers = false;
        }
    }

    private async Task LoadMissingDataReportsAsync()
    {
        try
        {
            missingDataRecords = await MissingDataReportReader.ListActiveAsync();
            missingDataReportError = null;
        }
        catch
        {
            missingDataReportError = "The missing data reports could not be loaded. Refresh the page and try again.";
        }
        finally
        {
            isLoadingMissingDataReports = false;
        }
    }

    private async Task LoadVersionReportsAsync()
    {
        try
        {
            var activeBuildRecords = await BuildRegisterReader.ListAsync();
            radSightVersionRows = BuildVersionReportRows(activeBuildRecords, row => row.RadSightVersion);
            windowsVersionRows = BuildVersionReportRows(activeBuildRecords, row => row.WindowsVersion);
            versionReportError = null;
        }
        catch
        {
            versionReportError = "The version reports could not be loaded. Refresh the page and try again.";
        }
        finally
        {
            isLoadingVersionReports = false;
        }
    }

    private static string Display(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "Not recorded" : value;
    }

    private static string Display(DateOnly? value)
    {
        return value?.ToString("d MMM yyyy") ?? "Not recorded";
    }

    private static IReadOnlyList<VersionReportRow> BuildVersionReportRows(
        IReadOnlyList<BuildRegisterRow> buildRecords,
        Func<BuildRegisterRow, string?> selector)
    {
        return buildRecords
            .GroupBy(buildRecord => NormalizeVersion(selector(buildRecord)))
            .Select(group => new VersionReportRow(
                group.Key,
                string.IsNullOrWhiteSpace(group.Key) ? "Not recorded" : group.Key,
                group.Count()))
            .OrderByDescending(row => row.Count)
            .ThenBy(row => row.Label, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private static string? NormalizeVersion(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? null : value.Trim();
    }

    private static string BuildVersionReportLink(string filterKey, string filterValue)
    {
        return $"/build-register?{Uri.EscapeDataString(filterKey)}={Uri.EscapeDataString(filterValue)}";
    }

    private static string MissingDataReportLink(MissingDataReportType reportType)
    {
        return $"/reports?missingData={Uri.EscapeDataString(reportType.ToString())}#missing-data-records-heading";
    }

    private static MissingDataReportType? ParseMissingDataReport(string? value)
    {
        return Enum.TryParse<MissingDataReportType>(value, ignoreCase: true, out var reportType)
            ? reportType
            : null;
    }

    private sealed record VersionReportRow(string? FilterValue, string Label, int Count)
    {
        public bool HasFilterValue => !string.IsNullOrWhiteSpace(FilterValue);
    }

    private enum MissingDataReportType
    {
        Customer,
        RecoveryData,
        DateShipped
    }
}
