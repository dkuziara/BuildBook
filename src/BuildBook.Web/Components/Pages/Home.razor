@page "/"

@attribute [Authorize(Policy = BuildBookPolicies.ViewBuildRecords)]

<PageTitle>BuildBook</PageTitle>

<section class="page-heading">
    <p class="eyebrow">BuildBook</p>
    <h1>Find and manage internal build records.</h1>
    <p>
        Foundation screens are being added in backlog order. Use the navigation to move between the Version 1 work areas.
    </p>
    <AuthorizeView Policy="@BuildBookPolicies.EditBuildRecords">
        <Authorized>
            <p class="page-actions">
                <a class="primary-button" href="/build-records/new">Add Build Record</a>
            </p>
        </Authorized>
    </AuthorizeView>
</section>

<section class="placeholder-panel" aria-labelledby="foundation-status">
    <h2 id="foundation-status">Foundation status</h2>
    <p>Navigation and layout are available. Search, record entry, reports and administration will be added in later backlog items.</p>
</section>
