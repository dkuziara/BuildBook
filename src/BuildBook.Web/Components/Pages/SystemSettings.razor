@page "/admin/system-settings"
@rendermode InteractiveServer

@using BuildBook.Application.Settings

@attribute [Authorize(Policy = BuildBookPolicies.ManageSystemSettings)]

@inject ISystemSettingsService SystemSettingsService
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>System Settings</PageTitle>

@if (isLoading)
{
    <section class="placeholder-panel" aria-live="polite">
        <p>Loading system settings...</p>
    </section>
}
else
{
    <section class="page-heading">
        <div class="page-heading-copy">
            <p class="eyebrow">Admin</p>
            <h1>System Settings</h1>
            <p>Manage shared settings that control support ticket links across the RMA and Customers modules.</p>
        </div>
        <div class="page-actions">
            <a class="secondary-button" href="/admin">Back to Admin</a>
        </div>
    </section>

    @if (errors.Count > 0)
    {
        <div class="status-message error" role="alert">
            <p>The system settings could not be saved.</p>
            <ul>
                @foreach (var error in errors)
                {
                    <li>@error</li>
                }
            </ul>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <div class="status-message success" role="status">
            <p>@statusMessage</p>
        </div>
    }

    <section class="form-panel" aria-labelledby="support-ticket-settings-heading">
        <h2 id="support-ticket-settings-heading">Support Ticket Settings</h2>
        <p class="form-introduction">Use a URL template with <code>@("{1}")</code> where the support ticket number should be inserted.</p>

        <EditForm Model="model" OnValidSubmit="SaveAsync" FormName="edit-system-settings">
            <div class="form-grid">
                <div class="form-field">
                    <label for="support-ticket-label">Support ticket label</label>
                    <InputText id="support-ticket-label" class="text-input" @bind-Value="model.SupportTicketLabel" />
                </div>

                <div class="form-field">
                    <label for="support-ticket-url-template">Support Site URL Template</label>
                    <InputText id="support-ticket-url-template" class="text-input" @bind-Value="model.SupportTicketUrlTemplate" />
                </div>
            </div>

            <div class="detail-section">
                <p class="empty-state">Example: <code>https://charthousedatamanagement.freshdesk.com/a/tickets/@("{1}")</code></p>
                <p class="empty-state">Leave the template blank if BuildBook should show the ticket number without an external link.</p>
            </div>

            <div class="form-actions">
                <button type="submit" class="primary-button" disabled="@isSaving">
                    @(isSaving ? "Saving..." : "Save settings")
                </button>
            </div>
        </EditForm>
    </section>
}

@code {
    private UpdateSupportTicketSettingsRequest model = new();
    private readonly List<string> errors = [];
    private bool isLoading = true;
    private bool isSaving;
    private string? statusMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadSettingsAsync();
        isLoading = false;
    }

    private async Task LoadSettingsAsync()
    {
        var settings = await SystemSettingsService.GetSupportTicketSettingsAsync();
        model = new UpdateSupportTicketSettingsRequest
        {
            SupportTicketLabel = settings.SupportTicketLabel,
            SupportTicketUrlTemplate = settings.SupportTicketUrlTemplate
        };
    }

    private async Task SaveAsync()
    {
        isSaving = true;
        statusMessage = null;
        errors.Clear();

        var authenticationState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var userName = authenticationState.User.Identity?.Name ?? "Unknown";
        var result = await SystemSettingsService.UpdateSupportTicketSettingsAsync(model, userName);

        isSaving = false;

        if (!result.Succeeded)
        {
            errors.AddRange(result.Errors);
            return;
        }

        await LoadSettingsAsync();
        statusMessage = "System settings were saved.";
    }
}
